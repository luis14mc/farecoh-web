---
import "../styles/global.css";
import "../styles/admin-shadcn.css";
import { AdminShell } from "@/components/admin/react/AdminShell";
import { getPublicSupabaseConfig, isAuthConfigured, type UserProfile } from "@/lib/auth";
import { SITE_LANG } from "@/lib/locale";
import { ROBOTS_NOINDEX } from "@/lib/seo";
import { ADMIN_NAV_ITEMS, type AdminNavKey } from "@/lib/admin-nav";
import { canAccessRoute } from "@/lib/rbac";

interface Props {
  title: string;
  description: string;
  active?: AdminNavKey;
}

const { title, description, active = "dashboard" } = Astro.props;
const { supabaseUrl, supabaseAnonKey } = getPublicSupabaseConfig();
const authConfigured = isAuthConfigured({ supabaseUrl, supabaseAnonKey });
const staffProfile = Astro.locals.staffProfile as UserProfile | undefined;

const navItems = ADMIN_NAV_ITEMS.filter(
  (item) => staffProfile && canAccessRoute(staffProfile.role, item.href),
);
---

<!doctype html>
<html class="light" lang={SITE_LANG}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content={ROBOTS_NOINDEX} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="admin-shell min-h-screen antialiased" style="font-family: Inter, ui-sans-serif, system-ui, sans-serif;">
    <AdminShell
      client:load
      active={active}
      navItems={navItems}
      staffProfile={staffProfile}
      authConfigured={authConfigured}
    />

    <div class="min-w-0 md:pl-64">
      <main class="min-h-screen pt-[var(--admin-mobile-top)] md:pt-0">
        <slot />
      </main>
    </div>
  </body>
</html>
