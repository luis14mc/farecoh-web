---
import "../styles/global.css";
import AdminSidebar from "@/components/admin/AdminSidebar.astro";
import MobileAdminNav from "@/components/admin/ui/MobileAdminNav.astro";
import { getPublicSupabaseConfig, isAuthConfigured } from "@/lib/auth";
import { SITE_LANG } from "@/lib/locale";
import { ROBOTS_NOINDEX } from "@/lib/seo";
import type { AdminNavKey } from "@/lib/admin-nav";

interface Props {
  title: string;
  description: string;
  active?: AdminNavKey;
}

const { title, description, active = "dashboard" } = Astro.props;
const { supabaseUrl, supabaseAnonKey } = getPublicSupabaseConfig();
const authConfigured = isAuthConfigured({ supabaseUrl, supabaseAnonKey });
---

<!doctype html>
<html class="light" lang={SITE_LANG}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content={ROBOTS_NOINDEX} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,0&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-zinc-50 text-on-surface antialiased">
    <MobileAdminNav active={active} />
    <AdminSidebar active={active} />

    <div class="md:pl-64">
      <main class="min-h-screen pt-14 md:pt-0">
        <slot />
      </main>
    </div>
  </body>
</html>

<script define:vars={{ authConfigured }}>
  import { createSupabaseBrowserClient } from "@/lib/auth";

  const supabase = authConfigured ? createSupabaseBrowserClient() : null;

  document.querySelectorAll("[data-admin-logout]").forEach((button) => {
    button.addEventListener("click", async () => {
      if (supabase) await supabase.auth.signOut();
      window.location.assign("/admin/login");
    });
  });
</script>
