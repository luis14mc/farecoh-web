---
import "../styles/global.css";
import Navbar from "@/components/layout/Navbar.astro";
import Footer from "@/components/layout/Footer.astro";

interface Props {
  title: string;
  description: string;
  active?: "home" | "events" | "tickets";
  variant?: "light" | "dark" | "concert";
}

const { title, description, active, variant = "light" } = Astro.props;

const bodyClass =
  variant === "concert"
    ? "universe-concert min-h-screen selection:bg-concert-orange selection:text-white"
    : variant === "dark"
      ? "min-h-screen bg-brand-neutral text-surface-bright selection:bg-primary-container selection:text-on-primary-container"
      : "min-h-screen bg-surface text-on-surface selection:bg-primary-container selection:text-on-primary-container";

const mainClass =
  variant === "light" ? "pt-20" : variant === "concert" ? "pt-20" : "";
---

<!doctype html>
<html class={variant} lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,0&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class={bodyClass}>
    <a class="sr-only" href="#main-content">Saltar al contenido</a>
    <Navbar active={active} variant={variant} />
    <main id="main-content" class={mainClass}>
      <slot />
    </main>
    <Footer variant={variant} />
  </body>
</html>

<style is:global>
  .reveal-section {
    transition: all 0.7s ease;
  }
</style>
