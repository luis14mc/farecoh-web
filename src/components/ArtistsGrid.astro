---
import type { Artist } from "@/data/events";

interface Props {
  artists: Artist[];
}

const { artists } = Astro.props;
---

<section class="py-20 sm:py-28">
  <div class="mx-auto w-[min(1120px,calc(100%-32px))] md:w-[min(1120px,calc(100%-64px))]">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-[#35c7ff]">Artistas</p>
      <h2 class="mt-4 text-3xl font-black text-white sm:text-5xl">Elenco y producción visual.</h2>
    </div>
    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        artists.map((artist) => (
          <article class="rounded-lg border border-white/12 bg-white/7 p-5 shadow-2xl backdrop-blur-xl">
            <div class="mb-5 h-28 rounded-md bg-[linear-gradient(135deg,rgba(255,59,95,0.32),rgba(255,209,102,0.2),rgba(53,199,255,0.28))]"></div>
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-[#ffd166]">{artist.role}</p>
            <h3 class="mt-3 text-xl font-bold text-white">{artist.name}</h3>
            <p class="mt-3 text-sm leading-6 text-[#a8a4b2]">{artist.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
