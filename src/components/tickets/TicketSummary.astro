---
interface Props {
  price: number;
}

import { formatSiteCurrency } from "@/lib/locale";

const { price } = Astro.props;
const formattedPrice = formatSiteCurrency(price);
---

<div class="event-v2-tickets-summary">
  <div class="flex items-end justify-between gap-4">
    <div>
      <p class="caption uppercase tracking-wider text-white/50">Total a aportar</p>
      <p class="body-md mt-1 text-white/65">{formattedPrice} c/u</p>
    </div>
    <p class="event-v2-cta-price text-concert-orange" id="total-price">{formattedPrice}</p>
  </div>
</div>

<script define:vars={{ ticketPrice: price }}>
  const qtyInput = document.getElementById("ticket_count");
  const totalPriceNode = document.getElementById("total-price");

  const formatTotal = (qty) =>
    new Intl.NumberFormat("es-HN", {
      style: "currency",
      currency: "HNL",
      maximumFractionDigits: 0,
    }).format(qty * Number(ticketPrice));

  qtyInput?.addEventListener("input", () => {
    const qty = parseInt(qtyInput.value, 10) || 1;
    if (totalPriceNode) totalPriceNode.textContent = formatTotal(qty);
  });
</script>
