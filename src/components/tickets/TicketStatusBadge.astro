---
import type { PhysicalTicketStatus } from "@/types/ticketing";

interface Props {
  status: PhysicalTicketStatus;
}

const { status } = Astro.props;

const labels: Record<PhysicalTicketStatus, string> = {
  available: "Disponible",
  assigned: "Asignado",
  reserved: "Reservado",
  sold: "Vendido",
  validated: "Validado",
  cancelled: "Anulado",
};

const classes: Record<PhysicalTicketStatus, string> = {
  available: "bg-slate-100 text-slate-700",
  assigned: "bg-blue-100 text-blue-700",
  reserved: "bg-yellow-100 text-yellow-700",
  sold: "bg-green-100 text-green-700",
  validated: "bg-primary-container text-primary",
  cancelled: "bg-red-100 text-red-700",
};
---

<span class={`inline-block rounded-full px-3 py-1 text-caption font-caption font-bold ${classes[status]}`}>
  {labels[status]}
</span>
