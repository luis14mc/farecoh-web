---
import InputField from "@/components/Forms/InputField.astro";
import TicketSummary from "@/components/tickets/TicketSummary.astro";
import type { EventData } from "@/lib/events";

interface Props {
  event: EventData;
}

const { event } = Astro.props;
const ticketPrice = event.ticket_price;
const eventSchedule = `${event.dateDisplay} · ${event.time}`;
---

<div class="event-v2-tickets-panel">
  <div id="form-container">
    <div class="mb-8 border-b border-white/10 pb-6">
      <span class="event-v2-badge">Reservación</span>
      <h2 class="headline-md mt-4 uppercase italic text-white">Asegura tu lugar</h2>
      <p class="body-md mt-2 text-white/70">
        Ingrese sus datos para generar la reservación de boletos.
      </p>
    </div>

    <form id="ticket-form" class="space-y-5">
      <InputField
        variant="concert"
        label="Nombre completo"
        id="name"
        name="name"
        placeholder="Ej. Juan Pérez"
        required={true}
      />

      <InputField
        variant="concert"
        label="Correo electrónico"
        id="email"
        name="email"
        type="email"
        placeholder="Ej. juan.perez@correo.com"
        required={true}
      />

      <InputField
        variant="concert"
        label="Teléfono"
        id="phone"
        name="phone"
        type="tel"
        placeholder="Ej. +504 9999-9999"
        required={true}
      />

      <InputField
        variant="concert"
        label="Cantidad de boletos"
        id="ticket_count"
        name="ticket_count"
        type="number"
        placeholder="1"
        required={true}
        value={1}
        min={1}
        max={10}
      />

      <TicketSummary price={ticketPrice} />

      <div
        id="booking-error"
        class="hidden rounded border border-red-400/40 bg-red-950/40 p-3 body-md text-red-200"
        role="alert"
        aria-live="polite"
      ></div>

      <button type="submit" id="submit-btn" class="event-rock-button w-full gap-3 py-4">
        <span class="label-caps tracking-widest">Reservar boletos</span>
        <span class="material-symbols-outlined text-xl" aria-hidden="true">confirmation_number</span>
      </button>
    </form>
  </div>

  <div id="success-container" class="hidden space-y-6">
    <div class="text-center">
      <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full border border-concert-orange/40 bg-concert-orange/10 text-concert-orange">
        <span class="material-symbols-outlined text-4xl" aria-hidden="true">check_circle</span>
      </div>
      <p class="label-caps text-concert-orange">Reservación exitosa</p>
      <h2 class="headline-md mt-2 uppercase italic text-white">¡Lugar asegurado!</h2>
      <p class="body-md mt-2 text-white/70">
        Hemos registrado su solicitud. Su reservación está en estado <strong class="text-white">pendiente de pago</strong>.
      </p>
    </div>

    <div class="event-v2-tickets-summary space-y-4">
      <div class="event-v2-tickets-summary-row">
        <div>
          <p class="caption uppercase tracking-wider text-white/50">Evento</p>
          <p class="body-md font-bold text-white">{event.name}</p>
        </div>
        <div>
          <p class="caption uppercase tracking-wider text-white/50">Fecha / hora</p>
          <p class="body-md text-white">{eventSchedule}</p>
        </div>
      </div>

      <div class="event-v2-tickets-summary-row">
        <div>
          <p class="caption uppercase tracking-wider text-white/50">Reservado a nombre de</p>
          <p class="body-md font-bold text-white" id="summary-name">Juan Pérez</p>
        </div>
        <div>
          <p class="caption uppercase tracking-wider text-white/50">Cantidad</p>
          <p class="body-md text-white" id="summary-qty">1 boleto(s)</p>
        </div>
      </div>

      <div>
        <p class="caption mb-3 uppercase tracking-wider text-white/50">Sus códigos de boleto</p>
        <div class="grid grid-cols-1 gap-2 sm:grid-cols-2" id="summary-codes"></div>
      </div>
    </div>

    <div class="space-y-3 pt-2">
      <p class="caption text-center text-white/50">
        Presente estos códigos en taquilla o realice su transferencia para validación.
      </p>
      <div class="flex flex-col gap-3 sm:flex-row">
        <a
          href="/"
          class="inline-flex flex-1 items-center justify-center border border-white/25 px-6 py-4 label-caps tracking-widest text-white transition hover:border-concert-orange hover:text-concert-orange"
        >
          Ir al inicio
        </a>
        <a href="/eventos/pink-floyd" class="event-rock-button flex-1 py-4 text-center">
          <span class="label-caps tracking-widest">Volver al evento</span>
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  const form = document.getElementById("ticket-form") as HTMLFormElement | null;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null;

  const formContainer = document.getElementById("form-container");
  const successContainer = document.getElementById("success-container");
  const bookingError = document.getElementById("booking-error");
  const summaryName = document.getElementById("summary-name");
  const summaryQty = document.getElementById("summary-qty");
  const summaryCodes = document.getElementById("summary-codes");

  function clearBookingError() {
    if (!bookingError) return;
    bookingError.textContent = "";
    bookingError.classList.add("hidden");
  }

  function showBookingError(message: string) {
    if (!bookingError) return;
    bookingError.textContent = message;
    bookingError.classList.remove("hidden");
  }

  function getBookingErrorMessage(err: unknown): string {
    const supabaseErr = err as {
      message?: string;
      details?: string;
      hint?: string;
      code?: string;
    };

    if (supabaseErr?.message && supabaseErr.message.trim()) {
      return supabaseErr.message;
    }

    if (err instanceof Error && err.message.trim()) {
      return err.message;
    }

    return "Ocurrió un error al procesar su reservación. Por favor intente de nuevo.";
  }

  if (form && submitBtn) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      clearBookingError();
      const formData = new FormData(form);
      const name = formData.get("name") as string;
      const email = formData.get("email") as string;
      const phone = formData.get("phone") as string;
      const qty = parseInt(formData.get("ticket_count") as string) || 1;

      submitBtn.disabled = true;
      const originalText = submitBtn.innerHTML;
      submitBtn.innerHTML = `<span class="material-symbols-outlined animate-spin text-xl" aria-hidden="true">sync</span><span class="label-caps tracking-widest">Procesando...</span>`;

      try {
        const response = await fetch("/api/tickets/reserve", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({
            eventSlug: "pink-floyd",
            fullName: name,
            email,
            phone,
            quantity: qty,
          }),
        });

        const payload = await response.json().catch(() => ({}));
        if (!response.ok) {
          throw new Error(typeof payload.error === "string" ? payload.error : "No se pudo crear la orden.");
        }

        const ticketCodes = Array.isArray(payload.ticketCodes) ? payload.ticketCodes : [];
        if (!ticketCodes.length) throw new Error("No se pudo crear la orden.");

        if (summaryName) summaryName.innerText = name;
        if (summaryQty) summaryQty.innerText = `${qty} boleto(s)`;
        if (summaryCodes) {
          summaryCodes.innerHTML = ticketCodes
            .map(
              (code: string) => `
              <div class="event-v2-tickets-code">${code}</div>
            `,
            )
            .join("");
        }

        if (formContainer && successContainer) {
          formContainer.classList.add("hidden");
          successContainer.classList.remove("hidden");
        }
      } catch (err: unknown) {
        const supabaseErr = err as {
          message?: string;
          details?: string;
          hint?: string;
          code?: string;
        };

        console.error("Booking error full:", {
          message: supabaseErr?.message,
          details: supabaseErr?.details,
          hint: supabaseErr?.hint,
          code: supabaseErr?.code,
          raw: err,
        });

        showBookingError(getBookingErrorMessage(err));
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalText;
      }
    });
  }
</script>
