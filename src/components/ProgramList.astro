---
import type { Lang } from "@/i18n/types";
import { getDictionary } from "@/i18n";
import { getFeaturedPrograms } from "@/data/programs";
import { getLocalizedPath } from "@/i18n/routes";
import SectionHeader from "./SectionHeader.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const p = getDictionary(lang).home.programs;
const items = getDictionary(lang).programsPage.items;
const featured = getFeaturedPrograms();
---

<section class="prism-section bg-[var(--prism-surface-low)]">
  <div class="prism-container">
    <SectionHeader label={p.label} title={p.title} />
    <div class="mt-16 grid gap-px bg-[var(--prism-divider)] md:grid-cols-3">
      {
        featured.map((program) => {
          const copy = items[program.slug];
          return (
            <article class="bg-[var(--prism-surface-low)] p-8 md:p-10">
              <h3 class="headline-md text-[var(--prism-text)]">{copy.title}</h3>
              <p class="body-md mt-5 text-[var(--prism-text-secondary)]">{copy.body}</p>
            </article>
          );
        })
      }
    </div>
    <a class="label-caps mt-10 inline-flex text-[var(--prism-gold)] transition-colors hover:text-[var(--prism-soft-gold)]" href={getLocalizedPath(lang, "programs")}>
      {p.link} →
    </a>
  </div>
</section>
