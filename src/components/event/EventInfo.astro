---
import { eventPage } from "@/data/event-page";
---

<section class="reveal-section event-v2-section border-b border-white/5 bg-black">
  <div class="landing-shell grid grid-cols-1 items-center gap-20 md:grid-cols-2">
    <div class="space-y-4">
      <div class="mb-6 h-1 w-12 bg-concert-orange" aria-hidden="true"></div>
      <h2 class="headline-lg uppercase tracking-tight text-white">
        {eventPage.experience.titleLead}{" "}
        <span class="text-concert-orange">{eventPage.experience.titleAccent}</span>
      </h2>
      <p class="body-lg leading-relaxed text-white/80">{eventPage.experience.body}</p>
      <p class="body-md border-l-2 border-white/10 pl-6 leading-relaxed text-white/50">
        {eventPage.experience.bodySecondary}
      </p>
    </div>

    <div class="group relative aspect-video overflow-hidden border border-white/10 bg-white/5">
      <img
        class="event-v2-bw h-full w-full object-cover opacity-60 transition-transform duration-1000 group-hover:scale-105"
        src={eventPage.experience.image}
        alt={eventPage.experience.imageAlt}
        loading="lazy"
        width="1200"
        height="675"
      />
      <div class="absolute inset-0 bg-gradient-to-tr from-black/80 to-transparent" aria-hidden="true"></div>
    </div>
  </div>
</section>

<section id="proposito" class="reveal-section event-v2-section bg-black">
  <div class="landing-shell relative z-10">
    <div class="event-v2-cause space-y-4 border border-white/10 bg-gradient-to-b from-white/5 to-transparent p-12 text-center md:p-24">
      <span class="material-symbols-outlined mb-4 block text-5xl text-concert-orange md:text-6xl" aria-hidden="true">
        album
      </span>
      <h2 class="headline-lg uppercase tracking-tighter text-white">{eventPage.purpose.title}</h2>
      <p class="body-lg mx-auto max-w-2xl font-light italic text-white/60">"{eventPage.purpose.quote}"</p>
      <p class="body-md mx-auto max-w-xl text-white/40">{eventPage.purpose.body}</p>
      <div class="mx-auto mt-8 h-px w-32 bg-white/20" aria-hidden="true"></div>
    </div>
  </div>
</section>
