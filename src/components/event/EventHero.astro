---
interface Props {
  name: string;
  venue: string;
  date: string;
  time: string;
  price: string;
}

import ArrowRight from "@lucide/astro/icons/arrow-right";
import { eventPage } from "@/data/event-page";

const { name, venue, date, time, price } = Astro.props;

const titleMatch = name.match(/^(Tributo a)\s+(.+)$/i);
const titleLead = titleMatch?.[1] ?? name;
const titleAccent = titleMatch?.[2] ?? "";
const venueBadge = venue.split(",")[0]?.trim() || venue;
---

<section class="event-v2-hero relative flex items-end overflow-hidden bg-black">
  <div class="absolute inset-0 z-0">
    <div class="parallax-layer h-full w-full" data-parallax data-parallax-speed="0.3" data-parallax-scale="1.08">
      <img
        class="event-v2-bw h-full w-full object-cover"
        src={eventPage.hero.image}
        alt={eventPage.hero.imageAlt}
        fetchpriority="high"
        width="1600"
        height="1067"
      />
    </div>
    <div class="event-v2-hero-gradient absolute inset-0" aria-hidden="true"></div>
    <div class="event-v2-hero-scrim absolute inset-0 bg-black/45" aria-hidden="true"></div>
  </div>

  <div class="landing-shell event-v2-hero-content relative z-10 w-full">
    <div class="max-w-3xl space-y-3 md:space-y-4">
      <span class="event-v2-badge">{venueBadge}</span>

      <h1 class="event-v2-display uppercase italic text-white">
        {titleAccent ? (
          <>
            {titleLead}{" "}
            <span class="text-concert-orange">{titleAccent}</span>
          </>
        ) : (
          name
        )}
      </h1>

      <p class="body-lg max-w-xl font-light text-white/90">{eventPage.hero.tagline}</p>

      <ul class="event-v2-meta-list" role="list">
        <li class="flex items-center gap-3 text-white">
          <span class="material-symbols-outlined text-concert-orange" aria-hidden="true">calendar_month</span>
          <span class="label-caps">{date}</span>
        </li>
        <li class="flex items-center gap-3 text-white">
          <span class="material-symbols-outlined text-concert-orange" aria-hidden="true">schedule</span>
          <span class="label-caps">{time}</span>
        </li>
        <li class="flex items-center gap-3 text-white">
          <span class="material-symbols-outlined text-concert-orange" aria-hidden="true">payments</span>
          <span class="label-caps">{price}</span>
        </li>
      </ul>

      <div class="event-v2-actions pt-2 md:pt-4">
        <a href="/eventos/pink-floyd/boletos" class="event-rock-button group inline-flex items-center justify-center gap-4 px-8 py-4 sm:gap-6 sm:px-10 sm:py-5">
          <span class="label-caps tracking-widest">{eventPage.hero.ctaPrimary}</span>
          <ArrowRight size={20} stroke-width={2} class="transition-transform group-hover:translate-x-1" aria-hidden="true" />
        </a>
      </div>
    </div>
  </div>

  <div class="event-prism-accent absolute bottom-0 left-0 right-0" aria-hidden="true"></div>
</section>
