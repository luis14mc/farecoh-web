---
interface Props {
  price: string;
}

import { eventPage } from "@/data/event-page";

const { price } = Astro.props;
---

<section class="reveal-section event-v2-section pb-section-gap">
  <div class="landing-shell">
    <div class="event-v2-cta relative flex flex-col items-center justify-between gap-8 overflow-hidden border border-concert-orange/20 bg-[#111111] md:flex-row">
      <div class="absolute right-0 top-0 -z-0 h-64 w-64 bg-concert-orange/5 blur-3xl" aria-hidden="true"></div>

      <div class="relative z-10 space-y-4 text-center md:text-left">
        <h3 class="headline-lg uppercase italic leading-tight text-white">
          {eventPage.cta.titleLead}{" "}
          <span class="text-concert-orange">{eventPage.cta.titleAccent}</span>
          <br />
          {eventPage.cta.titleTail}
        </h3>
        <p class="body-md text-white/50">{eventPage.cta.body}</p>
      </div>

      <div class="relative z-10 flex w-full flex-col items-center md:w-auto md:items-end">
        <p class="event-v2-cta-price text-concert-orange">{price}</p>
        <a href="/eventos/pink-floyd/boletos" class="event-rock-button mt-6 w-full px-12 py-5 text-center md:w-auto">
          <span class="label-caps tracking-widest">{eventPage.cta.button}</span>
        </a>
      </div>
    </div>

    <div class="event-prism-accent mt-12 opacity-50" aria-hidden="true"></div>
  </div>
</section>
