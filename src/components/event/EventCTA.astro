---
interface Props {
  price: number;
}

import LandingButton from "@/components/landing/LandingButton.astro";
import { eventPage } from "@/data/event-page";
import { formatSiteCurrency } from "@/lib/locale";

const { price } = Astro.props;
---

<section class="reveal-section event-section pb-section-gap">
  <div class="landing-shell">
    <div class="event-cta-panel flex flex-col items-center justify-between gap-stack-lg md:flex-row">
      <div class="max-w-xl space-y-3 text-center md:text-left">
        <p class="concert-eyebrow landing-eyebrow">Reserva</p>
        <h3 class="landing-headline text-white">{eventPage.cta.title}</h3>
        <p class="landing-body text-white/75">{eventPage.cta.body}</p>
      </div>
      <div class="flex w-full flex-col items-center gap-4 md:w-auto md:items-end">
        <p class="event-cta-price">{formatSiteCurrency(price)}</p>
        <LandingButton href="/eventos/pink-floyd/boletos" variant="concert-primary" class="w-full md:w-auto">
          {eventPage.cta.button}
        </LandingButton>
      </div>
    </div>
  </div>
</section>
