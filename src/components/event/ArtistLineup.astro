---
import {
  musicalDirector,
  ensembleMembers,
  ensembleOnStageCount,
  lineupPhotoFallback,
} from "@/data/artists";
import { eventPage } from "@/data/event-page";
---

<section class="reveal-section lineup-section" id="lineup-stage" aria-labelledby="lineup-heading">
  <div class="landing-shell lineup-section__shell">
    <article class="lineup-director" aria-label="Dirección musical">
      <div class="lineup-director__photo">
        <img
          src={musicalDirector.image}
          alt={musicalDirector.imageAlt}
          loading="eager"
          width="640"
          height="800"
          data-lineup-photo
          data-fallback={lineupPhotoFallback}
        />
      </div>

      <div class="lineup-director__panel">
        <div class="lineup-director__prism" aria-hidden="true">
          <span class="lineup-director__prism-triangle"></span>
          <span class="lineup-director__prism-beam"></span>
        </div>

        <p class="lineup-director__badge">{eventPage.lineup.directorBadge}</p>
        <h2 class="lineup-director__name">{musicalDirector.name}</h2>
        <p class="lineup-director__role">{musicalDirector.role}</p>
        {musicalDirector.description && (
          <p class="lineup-director__note">{musicalDirector.description}</p>
        )}
        <p class="lineup-director__count">
          {ensembleOnStageCount} {eventPage.lineup.onStageLabel}
        </p>
      </div>
    </article>

    <div class="lineup-ensemble">
      <header class="lineup-ensemble__header">
        <h2 id="lineup-heading" class="lineup-ensemble__title">{eventPage.lineup.label}</h2>
        <p class="lineup-ensemble__subtitle">{eventPage.lineup.subtitle}</p>
      </header>

      <ul class="lineup-ensemble__grid" role="list">
        {ensembleMembers.map((member) => (
          <li class="lineup-card">
            <div class="lineup-card__photo">
              <img
                src={member.image}
                alt={member.imageAlt}
                loading="lazy"
                width="480"
                height="600"
                data-lineup-photo
                data-fallback={lineupPhotoFallback}
              />
              <span class="lineup-card__index" aria-hidden="true">
                {String(member.order).padStart(2, "0")}
              </span>
            </div>
            <div class="lineup-card__body">
              <h3 class="lineup-card__name">{member.name}</h3>
              <p class="lineup-card__role">{member.role}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>

    <footer class="lineup-footer" aria-label="Marca del tributo">
      <span class="material-symbols-outlined lineup-footer__icon" aria-hidden="true">graphic_eq</span>
      <p class="lineup-footer__label">{eventPage.lineup.footer}</p>
    </footer>
  </div>
</section>

<script>
  import { animate, stagger } from "@motionone/dom";

  function initLineupPhotos() {
    document.querySelectorAll<HTMLImageElement>("[data-lineup-photo]").forEach((img) => {
      img.addEventListener(
        "error",
        () => {
          const fallback = img.dataset.fallback;
          if (!fallback || img.src.endsWith(fallback)) return;
          img.src = fallback;
        },
        { once: true },
      );
    });
  }

  function initLineupStage() {
    const section = document.getElementById("lineup-stage");
    if (!section) return;

    initLineupPhotos();

    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (prefersReducedMotion) return;

    const playEntrance = () => {
      if (!section.classList.contains("is-visible")) return;

      const director = section.querySelector(".lineup-director");
      const cards = section.querySelectorAll(".lineup-card");

      if (director) {
        animate(
          director,
          { opacity: [0, 1], transform: ["translateY(20px)", "translateY(0)"] },
          { duration: 0.6, easing: [0.22, 1, 0.36, 1] },
        );
      }

      if (cards.length) {
        animate(
          Array.from(cards),
          { opacity: [0, 1], transform: ["translateY(12px)", "translateY(0)"] },
          { duration: 0.45, delay: stagger(0.04, { start: 0.15 }), easing: "ease-out" },
        );
      }
    };

    if (section.classList.contains("is-visible")) {
      playEntrance();
      return;
    }

    const observer = new MutationObserver(playEntrance);
    observer.observe(section, { attributes: true, attributeFilter: ["class"] });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initLineupStage);
  } else {
    initLineupStage();
  }
</script>
