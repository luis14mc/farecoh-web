---
import type { Lang } from "@/i18n/types";
import { getDictionary } from "@/i18n";
import { pinkFloydMusicians } from "@/data/artists";
import SectionHeader from "./SectionHeader.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const m = getDictionary(lang).event.musicians;
const roles = getDictionary(lang).musicianRoles;
---

<section class="prism-section bg-[var(--prism-surface-lowest)]">
  <div class="prism-container">
    <SectionHeader label={m.label} title={m.title} />

    <ul class="mt-16 grid gap-px bg-[var(--prism-divider)] sm:grid-cols-2 lg:grid-cols-3">
      {
        pinkFloydMusicians.map((musician) => (
          <li class="bg-[var(--prism-surface-lowest)] px-6 py-7 md:px-8">
            <p class="body-lg text-[var(--prism-text)]">{musician.name}</p>
            <p class="label-caps mt-2 text-[var(--prism-outline)]">
              {roles[musician.roleKey as keyof typeof roles]}
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
