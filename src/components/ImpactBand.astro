---
import type { Lang } from "@/i18n/types";
import { getDictionary } from "@/i18n";
import SectionHeader from "./SectionHeader.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = getDictionary(lang).home.impact;
---

<section class="prism-section">
  <div class="prism-container">
    <div class="grid gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:items-end">
      <SectionHeader label={i.label} title={i.title} />
      <div class="grid gap-px bg-[var(--prism-divider)] sm:grid-cols-3">
        {
          i.metrics.map((metric) => (
            <div class="bg-[var(--prism-bg)] px-6 py-8 md:px-8 md:py-10">
              <p class="display text-[var(--prism-gold)]">{metric.value}</p>
              <p class="body-md mt-4 text-[var(--prism-text-secondary)]">{metric.label}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
