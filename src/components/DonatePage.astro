---
import type { Lang } from "@/i18n/types";
import { getDictionary } from "@/i18n";
import PageHero from "./PageHero.astro";
import SectionHeader from "./SectionHeader.astro";
import InterestForm from "./InterestForm.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const d = getDictionary(lang).donatePage;
---

<PageHero label={d.label} title={d.title} intro={d.intro} />

<section class="prism-section bg-[var(--prism-surface-low)]">
  <div class="prism-container">
    <SectionHeader label={d.impact.label} title={d.impact.title} />
    <ul class="mt-16 grid gap-px bg-[var(--prism-divider)] md:grid-cols-2">
      {
        d.impact.items.map((item) => (
          <li class="bg-[var(--prism-surface-low)] p-8 md:p-10">
            <h3 class="headline-md text-[var(--prism-text)]">{item.title}</h3>
            <p class="body-md mt-4 text-[var(--prism-text-secondary)]">{item.body}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<section class="prism-section">
  <div class="prism-container grid gap-16 lg:grid-cols-[1fr_1fr]">
    <div>
      <SectionHeader label={d.ways.label} title={d.ways.title} />
      <ul class="mt-10 space-y-4">
        {
          d.ways.items.map((item) => (
            <li class="flex items-start gap-4 border-b border-[var(--prism-divider)] pb-4">
              <span class="mt-2 h-px w-6 shrink-0 bg-[var(--prism-gold)]" aria-hidden="true"></span>
              <p class="body-md text-[var(--prism-text)]">{item}</p>
            </li>
          ))
        }
      </ul>
    </div>
    <figure class="editorial-image">
      <img src="/images/farecoh-welcome.webp" alt={getDictionary(lang).home.heroImageAlt} width="1920" height="1080" loading="lazy" />
    </figure>
  </div>
</section>

<section class="prism-section bg-[var(--prism-surface-lowest)]">
  <div class="prism-container">
    <div class="border border-[var(--prism-outline-variant)] p-8 md:p-12 lg:p-16">
      <div class="grid gap-12 lg:grid-cols-[1fr_0.9fr]">
        <div>
          <p class="subheader text-[var(--prism-gold)]">{d.form.label}</p>
          <h2 class="headline-lg mt-6 text-[var(--prism-text)]">{d.form.title}</h2>
          <p class="body-lg mt-6 text-[var(--prism-text-secondary)]">{d.form.body}</p>
          <div class="mt-10 border-t border-[var(--prism-divider)] pt-8">
            <p class="subheader text-[var(--prism-outline)]">{d.trust.label}</p>
            <p class="body-md mt-4 text-[var(--prism-text-secondary)]">{d.trust.body}</p>
          </div>
        </div>
        <InterestForm lang={lang} />
      </div>
    </div>
  </div>
</section>
