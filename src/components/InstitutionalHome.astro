---
import type { Event } from "@/data/events";

interface Props {
  lang?: "es" | "en";
  event: Event;
  eventHref: string;
}

const { lang = "es", event, eventHref } = Astro.props;
const ticketHref = `${eventHref}#tickets`;

const c = {
  es: {
    heroEyebrow: "FARECOH",
    heroTitle: "Transformando vidas a través del arte, la educación y la esperanza",
    heroText:
      "Utilizamos la música, las artes y la educación como herramientas para construir oportunidades, fortalecer comunidades y transformar vidas en Honduras.",
    eventButton: "Conocer el evento",
    ticketButton: "Reservar boletos",
    storyTitle: "Una historia que comenzó en 2013",
    storyText1:
      "FARECOH nació con un propósito claro: demostrar que el arte puede convertirse en una poderosa herramienta de transformación social.",
    storyText2:
      "Desde entonces trabajamos para que niños, niñas y jóvenes descubran sus talentos, fortalezcan sus valores y construyan un futuro lleno de oportunidades.",
    storyCta: "Nuestra historia",
    challengeTitle: "Miles de jóvenes necesitan oportunidades",
    challengeText:
      "En muchas comunidades, la violencia, la exclusión social y la falta de oportunidades limitan el desarrollo de miles de niños y jóvenes.",
    challengeClosing: "Creemos que el arte puede cambiar esta realidad.",
    modelTitle: "No formamos únicamente músicos",
    modelText1: "Formamos ciudadanos comprometidos con la cultura, la paz y el desarrollo de Honduras.",
    modelText2:
      "A través del aprendizaje colectivo fortalecemos liderazgo, disciplina, empatía, responsabilidad y sentido de pertenencia.",
    programsTitle: "Programas que transforman comunidades",
    programsText: "Cada programa une excelencia artística, acompañamiento humano y pertenencia comunitaria.",
    impactTitle: "Transformando vidas todos los días",
    galleryTitle: "Historias que inspiran",
    featuredTitle: "Tributo a Pink Floyd",
    featuredSubtitle: "Una noche. Una experiencia. Un viaje inolvidable.",
    featuredText:
      "Una experiencia audiovisual creada para celebrar la música de Pink Floyd y apoyar los programas educativos y artísticos de FARECOH.",
    featuredCta: "Ver detalles del evento",
    whyTitle: "Cada boleto genera oportunidades",
    quote: "La música me permitió descubrir capacidades que nunca imaginé tener.",
    quoteName: "Participante FARECOH",
    statement1: "Donde otros ven vulnerabilidad, nosotros vemos talento.",
    statement2: "Donde existe riesgo, sembramos esperanza.",
    statement3: "Donde hay silencio, hacemos sonar la música del cambio.",
    finalTitle: "Sé parte de esta transformación",
    finalText:
      "Acompáñanos en una experiencia musical que celebra el talento, la cultura y el poder transformador del arte.",
    finalCta: "Reservar boletos",
    challenges: ["Violencia", "Exclusión social", "Falta de oportunidades"],
    programs: [
      "Coros y Orquestas",
      "Escuelas de Música Comunitarias",
      "Artes para la Transformación Social",
      "Cultura de Paz",
      "Intercambios Culturales",
      "Fortalecimiento Comunitario",
    ],
    kpis: [
      ["+500", "Niños y jóvenes beneficiados"],
      ["+10", "Programas activos"],
      ["+12", "Años de impacto"],
      ["Miles", "De oportunidades creadas"],
    ],
    why: [
      ["Becas artísticas", "Acceso a formación para jóvenes con talento y vocación."],
      ["Instrumentos musicales", "Recursos concretos para aprender, ensayar y presentarse."],
      ["Educación y formación", "Procesos sostenidos con docentes, ensambles y comunidad."],
      ["Oportunidades para jóvenes", "Escenarios donde el talento se convierte en futuro."],
    ],
  },
  en: {
    heroEyebrow: "FARECOH",
    heroTitle: "Transforming lives through art, education and hope",
    heroText:
      "We use music, the arts and education as tools to build opportunities, strengthen communities and transform lives in Honduras.",
    eventButton: "Explore the event",
    ticketButton: "Reserve tickets",
    storyTitle: "A story that began in 2013",
    storyText1:
      "FARECOH was born with a clear purpose: to prove that art can become a powerful tool for social transformation.",
    storyText2:
      "Since then, we have worked so children and young people can discover their talents, strengthen their values and build a future full of opportunity.",
    storyCta: "Our story",
    challengeTitle: "Thousands of young people need opportunity",
    challengeText:
      "In many communities, violence, social exclusion and lack of opportunity limit the development of children and young people.",
    challengeClosing: "We believe art can change this reality.",
    modelTitle: "We do not only train musicians",
    modelText1: "We form citizens committed to culture, peace and the development of Honduras.",
    modelText2:
      "Through collective learning, we strengthen leadership, discipline, empathy, responsibility and belonging.",
    programsTitle: "Programs that transform communities",
    programsText: "Each program combines artistic excellence, human support and community belonging.",
    impactTitle: "Transforming lives every day",
    galleryTitle: "Stories that inspire",
    featuredTitle: "Pink Floyd Tribute",
    featuredSubtitle: "One night. One experience. An unforgettable journey.",
    featuredText:
      "An audiovisual experience created to celebrate Pink Floyd's music and support FARECOH's educational and artistic programs.",
    featuredCta: "View event details",
    whyTitle: "Every ticket creates opportunity",
    quote: "Music allowed me to discover abilities I never imagined I had.",
    quoteName: "FARECOH participant",
    statement1: "Where others see vulnerability, we see talent.",
    statement2: "Where there is risk, we plant hope.",
    statement3: "Where there is silence, we make the music of change sound.",
    finalTitle: "Be part of this transformation",
    finalText:
      "Join us in a musical experience that celebrates talent, culture and the transformative power of art.",
    finalCta: "Reserve tickets",
    challenges: ["Violence", "Social exclusion", "Lack of opportunity"],
    programs: [
      "Choirs and Orchestras",
      "Community Music Schools",
      "Arts for Social Transformation",
      "Culture of Peace",
      "Cultural Exchanges",
      "Community Strengthening",
    ],
    kpis: [
      ["+500", "Children and youth reached"],
      ["+10", "Active programs"],
      ["+12", "Years of impact"],
      ["Thousands", "Of opportunities created"],
    ],
    why: [
      ["Arts scholarships", "Access to training for young people with talent and vocation."],
      ["Musical instruments", "Concrete resources to learn, rehearse and perform."],
      ["Education and training", "Sustained processes with teachers, ensembles and community."],
      ["Opportunities for youth", "Stages where talent becomes future."],
    ],
  },
}[lang];

const storyId = lang === "es" ? "historia" : "story";
const programsId = lang === "es" ? "programas" : "programs";
const impactId = lang === "es" ? "impacto" : "impact";
const donateId = lang === "es" ? "donar" : "donate";
---

<section class="relative min-h-[92vh] overflow-hidden bg-[var(--farecoh-dark)] text-white">
  <img class="absolute inset-0 h-full w-full object-cover" src="/images/farecoh-hero-orchestra.png" alt="" width="1536" height="1024" />
  <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(16,20,21,.86)_0%,rgba(16,20,21,.48)_52%,rgba(16,20,21,.16)_100%)]"></div>
  <div class="container relative flex min-h-[92vh] items-end pb-16 pt-28 md:pb-24">
    <div class="max-w-4xl">
      <p class="eyebrow text-white/78">{c.heroEyebrow}</p>
      <h1 class="mt-5 max-w-5xl text-[clamp(3rem,7vw,6.75rem)] font-extrabold leading-[0.96] tracking-[-0.04em]">{c.heroTitle}</h1>
      <p class="mt-7 max-w-2xl text-lg leading-8 text-white/86 md:text-xl">{c.heroText}</p>
      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <a class="btn-primary" href={eventHref}>{c.eventButton}</a>
        <a class="inline-flex min-h-12 items-center justify-center rounded-lg border border-white/40 px-6 py-3 font-bold text-white transition hover:bg-white hover:text-[var(--farecoh-dark)]" href={ticketHref}>{c.ticketButton}</a>
      </div>
    </div>
  </div>
  <a class="absolute bottom-6 left-1/2 hidden -translate-x-1/2 text-xs font-semibold uppercase tracking-[0.18em] text-white/70 md:block" href={`#${storyId}`}>Scroll</a>
</section>

<section id={storyId} class="section bg-[var(--farecoh-bg)]">
  <div class="container grid items-center gap-12 lg:grid-cols-[0.95fr_1.05fr]">
    <figure>
      <img class="aspect-[4/3] w-full rounded-2xl object-cover" src="/images/farecoh-welcome.webp" alt={lang === "es" ? "Niñas presentándose en una actividad artística de FARECOH" : "Children performing in a FARECOH arts activity"} width="1920" height="1080" />
    </figure>
    <div>
      <p class="eyebrow">{lang === "es" ? "Nuestra historia" : "Our story"}</p>
      <h2 class="heading-lg mt-4">{c.storyTitle}</h2>
      <div class="mt-6 space-y-5 text-lg leading-8 text-[var(--farecoh-gray)]">
        <p>{c.storyText1}</p>
        <p>{c.storyText2}</p>
      </div>
      <a class="btn-secondary mt-8" href={`#${impactId}`}>{c.storyCta}</a>
    </div>
  </div>
</section>

<section class="section bg-white text-center">
  <div class="container max-w-5xl">
    <p class="eyebrow">{lang === "es" ? "El desafío" : "The challenge"}</p>
    <h2 class="heading-lg mt-4">{c.challengeTitle}</h2>
    <p class="body-lg mx-auto mt-6 max-w-3xl">{c.challengeText}</p>
    <div class="mt-10 grid gap-4 md:grid-cols-3">
      {c.challenges.map((item) => <div class="border-y border-[var(--farecoh-border)] py-8 text-xl font-bold text-[var(--farecoh-gray)]">{item}</div>)}
    </div>
    <p class="mt-10 text-2xl font-bold text-[var(--farecoh-navy)]">{c.challengeClosing}</p>
  </div>
</section>

<section class="section">
  <div class="container grid items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]">
    <div>
      <p class="eyebrow">{lang === "es" ? "Nuestro modelo" : "Our model"}</p>
      <h2 class="heading-lg mt-4">{c.modelTitle}</h2>
      <div class="mt-6 space-y-5 text-lg leading-8 text-[var(--farecoh-gray)]">
        <p>{c.modelText1}</p>
        <p>{c.modelText2}</p>
      </div>
    </div>
    <img class="aspect-[4/3] w-full rounded-2xl object-cover" src="/images/bg-musica.webp" alt={lang === "es" ? "Instrumento de cuerda como símbolo de educación musical" : "String instrument as a symbol of music education"} width="1920" height="1080" />
  </div>
</section>

<section id={programsId} class="section bg-white">
  <div class="container">
    <div class="max-w-3xl">
      <p class="eyebrow">{lang === "es" ? "Programas" : "Programs"}</p>
      <h2 class="heading-lg mt-4">{c.programsTitle}</h2>
      <p class="body-lg mt-5">{c.programsText}</p>
    </div>
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {c.programs.map((program, index) => (
        <article class="overflow-hidden rounded-2xl bg-[var(--farecoh-bg)]">
          <img class="h-52 w-full object-cover" src={index % 2 === 0 ? "/images/farecoh-welcome.webp" : "/images/bg-musica.webp"} alt="" width="960" height="540" />
          <div class="p-6">
            <h3 class="text-xl font-bold text-[var(--farecoh-text)]">{program}</h3>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<section id={impactId} class="section bg-[var(--farecoh-navy)] text-white">
  <div class="container">
    <p class="eyebrow text-white/70">{lang === "es" ? "Impacto" : "Impact"}</p>
    <h2 class="heading-lg mt-4 text-white">{c.impactTitle}</h2>
    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {c.kpis.map(([value, label]) => (
        <div class="border-t border-white/25 pt-6">
          <p class="text-5xl font-extrabold md:text-6xl">{value}</p>
          <p class="mt-4 text-sm font-semibold uppercase tracking-[0.08em] text-white/78">{label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <p class="eyebrow">{lang === "es" ? "Galería de impacto" : "Impact gallery"}</p>
    <h2 class="heading-lg mt-4">{c.galleryTitle}</h2>
    <div class="mt-12 grid gap-5 md:grid-cols-[1.2fr_0.8fr]">
      <img class="h-[520px] w-full rounded-2xl object-cover" src="/images/farecoh-welcome.webp" alt="" width="1920" height="1080" />
      <div class="grid gap-5">
        <img class="h-[250px] w-full rounded-2xl object-cover" src="/images/bg-musica.webp" alt="" width="1920" height="1080" />
        <img class="h-[250px] w-full rounded-2xl object-cover" src="/images/farecoh-hero-orchestra.png" alt="" width="1536" height="1024" />
      </div>
    </div>
  </div>
</section>

<section class="section bg-white">
  <div class="container">
    <div class="card-event-dark grid overflow-hidden lg:grid-cols-[0.92fr_1.08fr]">
      <div class="p-8 md:p-12">
        <span class="rounded-full bg-[var(--farecoh-blue)] px-4 py-2 text-xs font-bold uppercase tracking-[0.14em] text-white">{lang === "es" ? "Evento destacado" : "Featured event"}</span>
        <h2 class="mt-8 text-4xl font-extrabold text-white md:text-6xl">{c.featuredTitle}</h2>
        <p class="mt-4 text-2xl font-semibold text-white/88">{c.featuredSubtitle}</p>
        <p class="mt-5 max-w-2xl leading-7 text-white/72">{c.featuredText}</p>
        <dl class="mt-8 grid gap-4 text-sm font-semibold text-white/86 sm:grid-cols-2">
          <div>29 Agosto 2026</div>
          <div>8:00 PM</div>
          <div>Escuela Nacional de Música</div>
          <div>L.500.00</div>
        </dl>
        <a class="btn-primary mt-8" href={eventHref}>{c.featuredCta}</a>
      </div>
      <img class="h-full min-h-[360px] w-full object-cover opacity-78" src="/images/bg-musica.webp" alt="" width="1920" height="1080" />
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <h2 class="heading-lg">{c.whyTitle}</h2>
    <div class="mt-10 grid gap-6 md:grid-cols-4">
      {c.why.map(([title, body]) => (
        <article class="border-t border-[var(--farecoh-border)] pt-6">
          <h3 class="text-xl font-bold">{title}</h3>
          <p class="mt-4 leading-7 text-[var(--farecoh-gray)]">{body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="section bg-white">
  <div class="container grid items-center gap-10 lg:grid-cols-[0.88fr_1.12fr]">
    <img class="aspect-[4/3] w-full rounded-2xl object-cover" src="/images/farecoh-welcome.webp" alt="" width="1920" height="1080" />
    <blockquote>
      <p class="text-3xl font-bold leading-tight text-[var(--farecoh-text)] md:text-5xl">“{c.quote}”</p>
      <footer class="mt-6 text-sm font-bold uppercase tracking-[0.14em] text-[var(--farecoh-blue)]">{c.quoteName}</footer>
    </blockquote>
  </div>
</section>

<section class="section bg-[var(--farecoh-dark)] text-center text-white">
  <div class="container max-w-5xl">
    <p class="text-3xl font-extrabold leading-tight md:text-6xl">{c.statement1}</p>
    <p class="mt-6 text-3xl font-extrabold leading-tight md:text-6xl">{c.statement2}</p>
    <p class="mt-6 text-3xl font-extrabold leading-tight text-[var(--farecoh-gold)] md:text-6xl">{c.statement3}</p>
    <p class="mt-10 text-sm font-bold uppercase tracking-[0.2em] text-white/62">FARECOH</p>
  </div>
</section>

<section id={donateId} class="relative overflow-hidden bg-[var(--farecoh-dark)] text-white">
  <img class="absolute inset-0 h-full w-full object-cover opacity-44" src="/images/farecoh-hero-orchestra.png" alt="" width="1536" height="1024" />
  <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(16,20,21,.9),rgba(16,20,21,.55))]"></div>
  <div class="container relative py-24 md:py-32">
    <div class="max-w-3xl">
      <h2 class="text-4xl font-extrabold md:text-6xl">{c.finalTitle}</h2>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-white/82">{c.finalText}</p>
      <a class="btn-primary mt-9" href={ticketHref}>{c.finalCta}</a>
    </div>
  </div>
</section>
