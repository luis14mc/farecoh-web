---
import type { Lang } from "@/i18n/types";
import { getDictionary } from "@/i18n";
import SectionHeader from "./SectionHeader.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const w = getDictionary(lang).home.whoWeAre;
---

<section class="prism-section">
  <div class="prism-container grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:gap-20">
    <SectionHeader label={w.label} title={w.title} />
    <p class="body-lg text-[var(--prism-text-secondary)]">{w.body}</p>
  </div>
</section>
