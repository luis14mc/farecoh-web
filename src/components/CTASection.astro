---
import type { Lang } from "@/i18n/types";
import { getDictionary } from "@/i18n";
import { getLocalizedPath } from "@/i18n/routes";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const d = getDictionary(lang).home.donate;
const donateHref = getLocalizedPath(lang, "donate");
---

<section class="prism-section bg-[var(--prism-surface-low)]">
  <div class="prism-container">
    <div class="grid gap-12 border border-[var(--prism-outline-variant)] p-8 md:grid-cols-[1.1fr_0.9fr] md:p-12 lg:p-16">
      <div>
        <p class="subheader text-[var(--prism-outline)]">{d.label}</p>
        <h2 class="headline-lg mt-6 text-[var(--prism-text)]">{d.title}</h2>
        <p class="body-lg mt-6 text-[var(--prism-text-secondary)]">{d.body}</p>
      </div>
      <div class="flex flex-col justify-center border-t border-[var(--prism-divider)] pt-8 md:border-l md:border-t-0 md:pl-12 md:pt-0">
        <a class="btn-prism-primary w-full text-center" href={donateHref}>{d.cta}</a>
        <p class="body-md mt-6 text-[var(--prism-outline)]">{d.note}</p>
      </div>
    </div>
  </div>
</section>
