---
import type { Lang } from "@/i18n/types";
import { getDictionary } from "@/i18n";
import { getLocalizedPath } from "@/i18n/routes";
import { site } from "@/data/site";
import LanguageSwitcher from "./LanguageSwitcher.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getDictionary(lang).footer;
const nav = getDictionary(lang).nav;
const event = getDictionary(lang).event;
const currentPath = Astro.url.pathname;
---

<footer class="border-t border-[var(--prism-divider)] bg-[var(--prism-surface-lowest)]">
  <div class="prism-container grid gap-12 py-16 md:grid-cols-[1.5fr_1fr_1fr] md:py-20">
    <div>
      <img class="h-14 w-auto" src="/images/Logo Farecoh VARIANTE.png" alt="FARECOH" width="128" height="128" />
      <p class="body-md mt-6 max-w-sm text-[var(--prism-text-secondary)]">{t.text}</p>
    </div>

    <div>
      <h2 class="label-caps text-[var(--prism-outline)]">{t.explore}</h2>
      <nav class="mt-6 flex flex-col gap-3" aria-label={t.explore}>
        <a class="body-md text-[var(--prism-text-secondary)] transition-colors hover:text-[var(--prism-gold)]" href={getLocalizedPath(lang, "about")}>{nav.about}</a>
        <a class="body-md text-[var(--prism-text-secondary)] transition-colors hover:text-[var(--prism-gold)]" href={getLocalizedPath(lang, "programs")}>{nav.programs}</a>
        <a class="body-md text-[var(--prism-text-secondary)] transition-colors hover:text-[var(--prism-gold)]" href={getLocalizedPath(lang, "events")}>{nav.events}</a>
        <a class="body-md text-[var(--prism-text-secondary)] transition-colors hover:text-[var(--prism-gold)]" href={getLocalizedPath(lang, "pinkFloyd")}>{event.name}</a>
        <a class="body-md text-[var(--prism-text-secondary)] transition-colors hover:text-[var(--prism-gold)]" href={getLocalizedPath(lang, "donate")}>{nav.donate}</a>
      </nav>
    </div>

    <div>
      <h2 class="label-caps text-[var(--prism-outline)]">{t.contact}</h2>
      <div class="mt-6 flex flex-col gap-3">
        <a class="body-md text-[var(--prism-text-secondary)] transition-colors hover:text-[var(--prism-gold)]" href={`mailto:${site.email}`}>{site.email}</a>
        <LanguageSwitcher lang={lang} currentPath={currentPath} />
      </div>
    </div>
  </div>

  <div class="prism-container border-t border-[var(--prism-divider)] py-6">
    <p class="label-caps text-[var(--prism-outline)]">{t.rights}</p>
  </div>
</footer>
