---
interface Props {
  index: number;
  title: string;
  body: string;
}

const { index, title, body } = Astro.props;
const num = String(index).padStart(2, "0");
---

<li class="grid gap-6 bg-[var(--prism-bg)] p-8 md:grid-cols-[80px_1fr] md:p-12 lg:grid-cols-[120px_1fr]">
  <span class="label-caps text-[var(--prism-gold)]">{num}</span>
  <div>
    <h2 class="headline-md text-[var(--prism-text)]">{title}</h2>
    <p class="body-lg mt-5 max-w-3xl text-[var(--prism-text-secondary)]">{body}</p>
  </div>
</li>
