---
import type { Lang } from "@/i18n/types";
import { getDictionary } from "@/i18n";
import { getLocalizedPath } from "@/i18n/routes";
import { boardMembers } from "@/data/team";
import PageHero from "./PageHero.astro";
import SectionHeader from "./SectionHeader.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const a = getDictionary(lang).about;
const roles = a.boardRoles;
---

<PageHero label={a.label} title={a.title} intro={a.intro} />

<section class="prism-section">
  <div class="prism-container grid gap-16 lg:grid-cols-2 lg:gap-20">
    <div>
      <SectionHeader label={a.history.label} title={a.history.title} />
      <p class="body-lg mt-8 text-[var(--prism-text-secondary)]">{a.history.body}</p>
    </div>
    <figure class="editorial-image">
      <img src="/images/farecoh-welcome.webp" alt={getDictionary(lang).home.heroImageAlt} width="1920" height="1080" loading="lazy" />
    </figure>
  </div>
</section>

<section class="prism-section bg-[var(--prism-surface-low)]">
  <div class="prism-container grid gap-16 md:grid-cols-2">
    <div>
      <SectionHeader label={a.mission.label} title={a.mission.title} />
      <p class="body-lg mt-8 text-[var(--prism-text-secondary)]">{a.mission.body}</p>
    </div>
    <div>
      <SectionHeader label={a.vision.label} title={a.vision.title} />
      <p class="body-lg mt-8 text-[var(--prism-text-secondary)]">{a.vision.body}</p>
    </div>
  </div>
</section>

<section class="prism-section">
  <div class="prism-container">
    <SectionHeader label={a.values.label} title={a.values.title} />
    <ul class="mt-16 grid gap-px bg-[var(--prism-divider)] md:grid-cols-2 lg:grid-cols-3">
      {
        a.values.items.map((item) => (
          <li class="bg-[var(--prism-bg)] p-8 md:p-10">
            <h3 class="headline-md text-[var(--prism-text)]">{item.title}</h3>
            <p class="body-md mt-4 text-[var(--prism-text-secondary)]">{item.body}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<section class="prism-section bg-[var(--prism-surface-lowest)]">
  <div class="prism-container">
    <SectionHeader label={a.team.label} title={a.team.title} />
    <ul class="mt-16 grid gap-px bg-[var(--prism-divider)] sm:grid-cols-2 lg:grid-cols-3">
      {
        boardMembers.map((member) => (
          <li class="bg-[var(--prism-surface-lowest)] px-6 py-8">
            <p class="body-lg text-[var(--prism-text)]">{member.name}</p>
            <p class="label-caps mt-2 text-[var(--prism-gold)]">
              {roles[member.roleKey as keyof typeof roles]}
            </p>
          </li>
        ))
      }
    </ul>
    <a class="btn-prism-secondary mt-12" href={getLocalizedPath(lang, "programs")}>
      {lang === "es" ? "Conocer programas" : "Explore programs"}
    </a>
  </div>
</section>
