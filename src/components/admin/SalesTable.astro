---
import { supabase } from "@/lib/supabase";
import { formatSiteDate, formatSiteCurrency } from "@/lib/locale";

// Fetch sales with tickets joined
const { data: sales = [] } = await supabase
  .from("sales")
  .select("*, ticket:tickets(*)")
  .order("created_at", { ascending: false });

const formatDate = (isoString: string) =>
  formatSiteDate(isoString, {
    day: "2-digit",
    month: "short",
    year: "numeric",
    hour: "2-digit",
    minute: "2-digit"
  });
---

<div class="overflow-hidden rounded-lg border border-outline-variant bg-white shadow-sm text-on-surface">
  <div class="flex flex-col gap-4 border-b border-outline-variant p-4 md:flex-row md:items-center md:justify-between md:p-6">
    <div>
      <h3 class="text-base font-semibold text-on-surface">Historial de ventas</h3>
      <p class="text-sm text-on-surface-variant">Vea y filtre las transacciones registradas</p>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-4 border-b border-outline-variant bg-surface-container-low p-4 sm:grid-cols-3 md:p-6">
    <div>
      <label class="mb-2 block text-xs font-medium uppercase tracking-wide text-on-surface-variant">Buscar</label>
      <div class="relative">
        <input
          id="search-input"
          type="text"
          placeholder="Comprador, vendedor o código..."
          class="flex h-11 w-full rounded-md border border-outline-variant bg-white pl-10 pr-3 text-sm outline-none focus-visible:ring-2 focus-visible:ring-primary/30"
        />
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant">search</span>
      </div>
    </div>

    <div>
      <label class="mb-2 block text-xs font-medium uppercase tracking-wide text-on-surface-variant">Método de pago</label>
      <select
        id="payment-filter"
        class="flex h-11 w-full rounded-md border border-outline-variant bg-white px-3 text-sm outline-none focus-visible:ring-2 focus-visible:ring-primary/30"
      >
        <option value="all">Todos</option>
        <option value="cash">Efectivo</option>
        <option value="transfer">Transferencia</option>
        <option value="card">Tarjeta</option>
      </select>
    </div>

    <div>
      <label class="mb-2 block text-xs font-medium uppercase tracking-wide text-on-surface-variant">Fecha</label>
      <div class="relative">
        <input
          id="date-filter"
          type="date"
          class="flex h-11 w-full rounded-md border border-outline-variant bg-white pl-10 pr-3 text-sm outline-none focus-visible:ring-2 focus-visible:ring-primary/30"
        />
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant">calendar_today</span>
      </div>
    </div>
  </div>

  <div class="overflow-x-auto">
    <table class="w-full min-w-[760px] text-left text-sm" id="sales-table">
      <thead class="border-b border-outline-variant bg-surface-container-low">
        <tr>
          <th class="h-11 px-4 text-xs font-medium uppercase tracking-wide text-on-surface-variant">Boleto</th>
          <th class="h-11 px-4 text-xs font-medium uppercase tracking-wide text-on-surface-variant">Comprador</th>
          <th class="h-11 px-4 text-xs font-medium uppercase tracking-wide text-on-surface-variant">Monto</th>
          <th class="h-11 px-4 text-xs font-medium uppercase tracking-wide text-on-surface-variant">Método</th>
          <th class="h-11 px-4 text-xs font-medium uppercase tracking-wide text-on-surface-variant">Vendedor</th>
          <th class="h-11 px-4 text-xs font-medium uppercase tracking-wide text-on-surface-variant">Fecha</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-outline-variant" id="table-body">
        {sales && sales.map((sale: any) => {
          const ticket = sale.ticket || { ticket_code: "N/A", buyer_name: "Desconocido", buyer_phone: "", buyer_email: "" };
          const dateStr = new Date(sale.created_at).toISOString().split("T")[0];

          return (
            <tr
              class="sales-row transition-colors hover:bg-surface-container-low/70"
              data-buyer={ticket.buyer_name?.toLowerCase() || ""}
              data-seller={sale.seller_name.toLowerCase()}
              data-code={ticket.ticket_code.toLowerCase()}
              data-payment={sale.payment_method.toLowerCase()}
              data-date={dateStr}
            >
              <td class="px-4 py-3 font-mono text-sm font-semibold text-primary">
                {ticket.ticket_code}
              </td>
              <td class="px-4 py-3">
                <div class="flex flex-col">
                  <span class="text-sm font-semibold text-on-surface">{ticket.buyer_name}</span>
                  <span class="text-xs text-on-surface-variant">{ticket.buyer_phone || ticket.buyer_email}</span>
                </div>
              </td>
              <td class="px-4 py-3 text-sm font-semibold">
                {formatSiteCurrency(sale.amount)}
              </td>
              <td class="px-4 py-3 text-sm capitalize">
                {sale.payment_method}
              </td>
              <td class="px-4 py-3 text-sm">
                <div class="flex flex-col">
                  <span class="font-medium">{sale.seller_name}</span>
                  <span class="text-xs text-on-surface-variant">{sale.sales_point}</span>
                </div>
              </td>
              <td class="px-4 py-3 text-sm text-on-surface-variant">
                {formatDate(sale.created_at)}
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>
  
  <!-- Empty State -->
  <div id="empty-state" class="hidden py-10 text-center text-on-surface-variant">
    <span class="material-symbols-outlined mb-2 text-4xl">find_in_page</span>
    <p class="text-sm">No se encontraron ventas que coincidan con los filtros.</p>
  </div>

  <div class="flex items-center justify-between border-t border-outline-variant bg-surface-container-low p-4 md:p-6">
    <span class="text-sm text-on-surface-variant" id="results-count">
      Mostrando {sales?.length || 0} ventas
    </span>
  </div>
</div>

<script>
  const searchInput = document.getElementById("search-input") as HTMLInputElement | null;
  const paymentFilter = document.getElementById("payment-filter") as HTMLSelectElement | null;
  const dateFilter = document.getElementById("date-filter") as HTMLInputElement | null;
  const tableRows = document.querySelectorAll(".sales-row") as NodeListOf<HTMLTableRowElement>;
  const emptyState = document.getElementById("empty-state");
  const resultsCount = document.getElementById("results-count");

  const filterTable = () => {
    const searchVal = searchInput?.value.toLowerCase() || "";
    const paymentVal = paymentFilter?.value || "all";
    const dateVal = dateFilter?.value || "";

    let visibleCount = 0;

    tableRows.forEach(row => {
      const buyer = row.getAttribute("data-buyer") || "";
      const seller = row.getAttribute("data-seller") || "";
      const code = row.getAttribute("data-code") || "";
      const payment = row.getAttribute("data-payment") || "";
      const date = row.getAttribute("data-date") || "";

      const matchesSearch = buyer.includes(searchVal) || seller.includes(searchVal) || code.includes(searchVal);
      const matchesPayment = paymentVal === "all" || payment === paymentVal;
      const matchesDate = !dateVal || date === dateVal;

      if (matchesSearch && matchesPayment && matchesDate) {
        row.classList.remove("hidden");
        visibleCount++;
      } else {
        row.classList.add("hidden");
      }
    });

    if (resultsCount) {
      resultsCount.innerText = `Mostrando ${visibleCount} de ${tableRows.length} resultados`;
    }

    if (emptyState) {
      if (visibleCount === 0) {
        emptyState.classList.remove("hidden");
      } else {
        emptyState.classList.add("hidden");
      }
    }
  };

  searchInput?.addEventListener("input", filterTable);
  paymentFilter?.addEventListener("change", filterTable);
  dateFilter?.addEventListener("change", filterTable);
</script>
