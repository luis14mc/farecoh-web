---
import { supabase } from "@/lib/supabase";
import { formatSiteDate, formatSiteCurrency } from "@/lib/locale";

// Fetch sales with tickets joined
const { data: sales = [] } = await supabase
  .from("sales")
  .select("*, ticket:tickets(*)")
  .order("created_at", { ascending: false });

const formatDate = (isoString: string) =>
  formatSiteDate(isoString, {
    day: "2-digit",
    month: "short",
    year: "numeric",
    hour: "2-digit",
    minute: "2-digit"
  });
---

<div class="bg-surface-container-lowest border border-outline-variant rounded-lg overflow-hidden flex flex-col text-on-surface">
  <div class="p-6 border-b border-outline-variant flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
    <div>
      <h3 class="text-headline-md font-headline-md text-on-surface">Historial de Ventas</h3>
      <p class="text-caption font-caption text-on-surface-variant">Vea y filtre las transacciones registradas</p>
    </div>
  </div>

  <!-- Dynamic Filters Section -->
  <div class="p-6 bg-surface-container-low border-b border-outline-variant grid grid-cols-1 sm:grid-cols-3 gap-4">
    <!-- Name / Code Filter -->
    <div>
      <label class="text-caption font-caption text-on-surface-variant uppercase font-bold block mb-2">Buscar</label>
      <div class="relative">
        <input 
          id="search-input" 
          type="text" 
          placeholder="Comprador, vendedor o código..." 
          class="w-full pl-10 pr-4 py-2 border border-[rgba(69,65,66,0.2)] focus:border-primary focus:ring-0 outline-none bg-surface text-body-md text-on-surface"
        />
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline">search</span>
      </div>
    </div>

    <!-- Payment Method Filter -->
    <div>
      <label class="text-caption font-caption text-on-surface-variant uppercase font-bold block mb-2">Método de Pago</label>
      <select 
        id="payment-filter" 
        class="w-full px-3 py-2 border border-[rgba(69,65,66,0.2)] focus:border-primary focus:ring-0 outline-none bg-surface text-body-md text-on-surface"
      >
        <option value="all">Todos</option>
        <option value="cash">Efectivo</option>
        <option value="transfer">Transferencia</option>
        <option value="card">Tarjeta</option>
      </select>
    </div>

    <!-- Date Filter -->
    <div>
      <label class="text-caption font-caption text-on-surface-variant uppercase font-bold block mb-2">Fecha</label>
      <div class="relative">
        <input 
          id="date-filter" 
          type="date" 
          class="w-full pl-10 pr-4 py-2 border border-[rgba(69,65,66,0.2)] focus:border-primary focus:ring-0 outline-none bg-surface text-body-md text-on-surface"
        />
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline">calendar_today</span>
      </div>
    </div>
  </div>

  <!-- Table Section -->
  <div class="overflow-x-auto">
    <table class="w-full text-left border-collapse" id="sales-table">
      <thead class="bg-surface-container-low">
        <tr>
          <th class="px-6 py-4 text-label-md font-label-md text-on-surface-variant uppercase font-semibold">Boleto</th>
          <th class="px-6 py-4 text-label-md font-label-md text-on-surface-variant uppercase font-semibold">Comprador</th>
          <th class="px-6 py-4 text-label-md font-label-md text-on-surface-variant uppercase font-semibold">Monto</th>
          <th class="px-6 py-4 text-label-md font-label-md text-on-surface-variant uppercase font-semibold">Método Pago</th>
          <th class="px-6 py-4 text-label-md font-label-md text-on-surface-variant uppercase font-semibold">Vendedor</th>
          <th class="px-6 py-4 text-label-md font-label-md text-on-surface-variant uppercase font-semibold">Fecha</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-outline-variant" id="table-body">
        {sales && sales.map((sale: any) => {
          const ticket = sale.ticket || { ticket_code: "N/A", buyer_name: "Desconocido", buyer_phone: "", buyer_email: "" };
          const dateStr = new Date(sale.created_at).toISOString().split("T")[0];

          return (
            <tr 
              class="hover:bg-surface-container-low transition-colors group sales-row" 
              data-buyer={ticket.buyer_name?.toLowerCase() || ""} 
              data-seller={sale.seller_name.toLowerCase()} 
              data-code={ticket.ticket_code.toLowerCase()} 
              data-payment={sale.payment_method.toLowerCase()}
              data-date={dateStr}
            >
              <td class="px-6 py-4 text-body-md font-body-md font-semibold text-primary font-mono">
                {ticket.ticket_code}
              </td>
              <td class="px-6 py-4">
                <div class="flex flex-col">
                  <span class="text-body-md font-body-md text-on-surface font-bold">{ticket.buyer_name}</span>
                  <span class="text-caption font-caption text-on-surface-variant">{ticket.buyer_phone || ticket.buyer_email}</span>
                </div>
              </td>
              <td class="px-6 py-4 text-body-md font-body-md font-bold">
                {formatSiteCurrency(sale.amount)}
              </td>
              <td class="px-6 py-4 text-body-md font-body-md capitalize">
                {sale.payment_method}
              </td>
              <td class="px-6 py-4 text-body-md font-body-md">
                <div class="flex flex-col">
                  <span class="font-semibold">{sale.seller_name}</span>
                  <span class="text-caption font-caption text-on-surface-variant">{sale.sales_point}</span>
                </div>
              </td>
              <td class="px-6 py-4 text-body-md font-body-md text-on-surface-variant">
                {formatDate(sale.created_at)}
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>
  
  <!-- Empty State -->
  <div id="empty-state" class="hidden py-10 text-center text-on-surface-variant">
    <span class="material-symbols-outlined text-4xl mb-2">find_in_page</span>
    <p class="text-body-lg font-body-lg">No se encontraron ventas que coincidan con los filtros.</p>
  </div>

  <div class="p-6 bg-surface-container-low border-t border-outline-variant flex items-center justify-between">
    <span class="text-caption font-caption text-on-surface-variant" id="results-count">
      Mostrando {sales?.length || 0} ventas
    </span>
  </div>
</div>

<script>
  const searchInput = document.getElementById("search-input") as HTMLInputElement | null;
  const paymentFilter = document.getElementById("payment-filter") as HTMLSelectElement | null;
  const dateFilter = document.getElementById("date-filter") as HTMLInputElement | null;
  const tableRows = document.querySelectorAll(".sales-row") as NodeListOf<HTMLTableRowElement>;
  const emptyState = document.getElementById("empty-state");
  const resultsCount = document.getElementById("results-count");

  const filterTable = () => {
    const searchVal = searchInput?.value.toLowerCase() || "";
    const paymentVal = paymentFilter?.value || "all";
    const dateVal = dateFilter?.value || "";

    let visibleCount = 0;

    tableRows.forEach(row => {
      const buyer = row.getAttribute("data-buyer") || "";
      const seller = row.getAttribute("data-seller") || "";
      const code = row.getAttribute("data-code") || "";
      const payment = row.getAttribute("data-payment") || "";
      const date = row.getAttribute("data-date") || "";

      const matchesSearch = buyer.includes(searchVal) || seller.includes(searchVal) || code.includes(searchVal);
      const matchesPayment = paymentVal === "all" || payment === paymentVal;
      const matchesDate = !dateVal || date === dateVal;

      if (matchesSearch && matchesPayment && matchesDate) {
        row.classList.remove("hidden");
        visibleCount++;
      } else {
        row.classList.add("hidden");
      }
    });

    if (resultsCount) {
      resultsCount.innerText = `Mostrando ${visibleCount} de ${tableRows.length} resultados`;
    }

    if (emptyState) {
      if (visibleCount === 0) {
        emptyState.classList.remove("hidden");
      } else {
        emptyState.classList.add("hidden");
      }
    }
  };

  searchInput?.addEventListener("input", filterTable);
  paymentFilter?.addEventListener("change", filterTable);
  dateFilter?.addEventListener("change", filterTable);
</script>
