---
import { supabase } from "@/lib/supabase";
import { formatSiteCurrency, formatSiteNumber } from "@/lib/locale";
import { getPinkFloydEventFallback } from "@/lib/events";
import StatCard from "@/components/admin/ui/StatCard.astro";

const CAPACITY = getPinkFloydEventFallback().total_tickets;

const { data: tickets = [] } = await supabase
  .from("tickets")
  .select("status");

const countByStatus = (status: string) =>
  tickets.filter((t: { status: string }) => t.status === status).length;

const { data: sales = [] } = await supabase
  .from("sales")
  .select("amount");

const totalRevenue = sales.reduce((sum: number, s: { amount: number | string }) => sum + Number(s.amount), 0);

const kpis = [
  { label: "Capacidad", value: formatSiteNumber(CAPACITY), icon: "stadium", tone: "slate" as const },
  { label: "Disponibles", value: formatSiteNumber(countByStatus("available")), icon: "event_seat", tone: "slate" as const },
  { label: "Asignados", value: formatSiteNumber(countByStatus("assigned")), icon: "local_shipping", tone: "blue" as const },
  { label: "Reservados", value: formatSiteNumber(countByStatus("reserved")), icon: "schedule", tone: "amber" as const },
  { label: "Vendidos", value: formatSiteNumber(countByStatus("sold")), icon: "check_circle", tone: "green" as const },
  { label: "Validados", value: formatSiteNumber(countByStatus("validated")), icon: "qr_code_scanner", tone: "purple" as const },
  { label: "Anulados", value: formatSiteNumber(countByStatus("cancelled")), icon: "block", tone: "red" as const },
];
---

<section class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
  {kpis.map((kpi) => (
    <StatCard label={kpi.label} value={kpi.value} icon={kpi.icon} tone={kpi.tone} />
  ))}
  <StatCard label="Recaudación" value={formatSiteCurrency(totalRevenue)} icon="payments" tone="primary" class="sm:col-span-2 xl:col-span-1" />
</section>
