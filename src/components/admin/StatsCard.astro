---
import { supabase } from "@/lib/supabase";
import { formatSiteCurrency, formatSiteNumber } from "@/lib/locale";

// Query all tickets for live aggregation
const { data: tickets = [] } = await supabase
  .from("tickets")
  .select("status");

const availableTickets = tickets.filter((t: any) => t.status === "available").length;
const soldTickets = tickets.filter((t: any) => t.status === "sold").length;
const validatedTickets = tickets.filter((t: any) => t.status === "validated").length;
const pendingTickets = tickets.filter((t: any) => t.status === "assigned").length;

// Query total revenue from sales table
const { data: sales = [] } = await supabase
  .from("sales")
  .select("amount");

const totalRevenue = sales.reduce((sum: number, s: any) => sum + Number(s.amount), 0);
---

<section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-gutter text-on-surface">
  <!-- Available Tickets -->
  <div class="bg-surface-container-lowest border border-outline-variant p-6 rounded-lg hover:shadow-lg transition-shadow duration-300">
    <div class="flex justify-between items-start mb-4">
      <div class="p-2 bg-blue-100 rounded-lg">
        <span class="material-symbols-outlined text-blue-600">event_seat</span>
      </div>
    </div>
    <p class="text-label-md font-label-md text-on-surface-variant uppercase font-semibold">Disponibles</p>
    <p class="text-headline-lg font-headline-lg text-on-surface mt-1">{formatSiteNumber(availableTickets)}</p>
  </div>

  <!-- Sold Tickets -->
  <div class="bg-surface-container-lowest border border-outline-variant p-6 rounded-lg hover:shadow-lg transition-shadow duration-300">
    <div class="flex justify-between items-start mb-4">
      <div class="p-2 bg-green-100 rounded-lg">
        <span class="material-symbols-outlined text-green-600">check_circle</span>
      </div>
    </div>
    <p class="text-label-md font-label-md text-on-surface-variant uppercase font-semibold">Vendidos</p>
    <p class="text-headline-lg font-headline-lg text-on-surface mt-1">{formatSiteNumber(soldTickets)}</p>
  </div>

  <!-- Validated Tickets -->
  <div class="bg-surface-container-lowest border border-outline-variant p-6 rounded-lg hover:shadow-lg transition-shadow duration-300">
    <div class="flex justify-between items-start mb-4">
      <div class="p-2 bg-purple-100 rounded-lg">
        <span class="material-symbols-outlined text-purple-600">qr_code_scanner</span>
      </div>
    </div>
    <p class="text-label-md font-label-md text-on-surface-variant uppercase font-semibold">Validados</p>
    <p class="text-headline-lg font-headline-lg text-on-surface mt-1">{formatSiteNumber(validatedTickets)}</p>
  </div>

  <!-- Pending (Assigned) Tickets -->
  <div class="bg-surface-container-lowest border border-outline-variant p-6 rounded-lg hover:shadow-lg transition-shadow duration-300">
    <div class="flex justify-between items-start mb-4">
      <div class="p-2 bg-yellow-100 rounded-lg">
        <span class="material-symbols-outlined text-yellow-600">local_shipping</span>
      </div>
    </div>
    <p class="text-label-md font-label-md text-on-surface-variant uppercase font-semibold">Asignados (Pendientes)</p>
    <p class="text-headline-lg font-headline-lg text-on-surface mt-1">{formatSiteNumber(pendingTickets)}</p>
  </div>

  <!-- Revenue -->
  <div class="bg-primary text-white p-6 rounded-lg hover:shadow-lg transition-shadow duration-300">
    <div class="flex justify-between items-start mb-4">
      <div class="p-2 bg-white/20 rounded-lg text-white">
        <span class="material-symbols-outlined text-white">payments</span>
      </div>
    </div>
    <p class="text-label-md font-label-md text-white/80 uppercase font-semibold">Recaudación</p>
    <p class="text-headline-lg font-headline-lg text-white mt-1">{formatSiteCurrency(totalRevenue)}</p>
  </div>
</section>
