---
import type { StaffProfile } from "@/lib/auth";
import { canAccessRoute } from "@/lib/rbac";

interface Props {
  active?: string;
}

const { active = "dashboard" } = Astro.props;
const staffProfile = Astro.locals.staffProfile as StaffProfile | undefined;

const navItems = [
  { label: "Dash", href: "/admin", icon: "dashboard", key: "dashboard" },
  { label: "Ventas", href: "/admin/ventas", icon: "payments", key: "ventas" },
  { label: "Boletos", href: "/admin/boletos", icon: "confirmation_number", key: "boletos" },
  { label: "Check-in", href: "/admin/checkin", icon: "qr_code_scanner", key: "checkin" },
  { label: "Lotes", href: "/admin/lotes", icon: "inventory_2", key: "lotes" },
].filter((item) => staffProfile && canAccessRoute(staffProfile.role, item.href));
---

<div class="md:hidden fixed bottom-0 left-0 right-0 bg-surface border-t border-outline-variant flex justify-around p-3 z-50 text-on-surface">
  {navItems.map((item) => {
    const isActive = active === item.key;
    const textClass = isActive ? "text-primary font-bold" : "text-on-surface-variant";
    return (
      <a class={`flex flex-col items-center ${textClass}`} href={item.href}>
        <span class="material-symbols-outlined" style={isActive ? "font-variation-settings: 'FILL' 1;" : ""}>
          {item.icon}
        </span>
        <span class="text-[10px]">{item.label}</span>
      </a>
    );
  })}
</div>