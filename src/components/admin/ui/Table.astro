---
interface Props {
  class?: string;
  minWidth?: string;
}

const { class: className = "", minWidth = "640px" } = Astro.props;
---

<div class={`relative w-full overflow-x-auto rounded-lg border border-outline-variant bg-white ${className}`}>
  <table class="w-full caption-bottom text-sm" style={`min-width: ${minWidth}`}>
    <slot />
  </table>
</div>
