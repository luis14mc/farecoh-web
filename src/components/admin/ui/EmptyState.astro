---
interface Props {
  icon?: string;
  title: string;
  description?: string;
  class?: string;
}

const { icon = "inbox", title, description, class: className = "" } = Astro.props;
---

<div class={`flex flex-col items-center justify-center px-6 py-12 text-center ${className}`}>
  <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-surface-container-low text-on-surface-variant">
    <span class="material-symbols-outlined text-[28px]">{icon}</span>
  </div>
  <h3 class="text-base font-semibold text-on-surface">{title}</h3>
  {description && <p class="mt-2 max-w-sm text-sm text-on-surface-variant">{description}</p>}
  {Astro.slots.has("default") && <div class="mt-4"><slot /></div>}
</div>
