---
import type { PhysicalTicketStatus } from "@/types/ticketing";
import { getTicketStatusLabel, TICKET_STATUS_CLASSES } from "@/lib/ticket-status";

interface Props {
  variant?: "default" | "secondary" | "outline" | PhysicalTicketStatus;
  class?: string;
  status?: string;
}

const { variant = "default", class: className = "", status } = Astro.props;

const base = "inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold transition-colors";

const variants: Record<string, string> = {
  default: "bg-primary/10 text-primary border border-primary/20",
  secondary: "bg-surface-container-high text-on-surface-variant",
  outline: "border border-outline-variant text-on-surface-variant bg-white",
  available: TICKET_STATUS_CLASSES.available,
  assigned: TICKET_STATUS_CLASSES.assigned,
  reserved: TICKET_STATUS_CLASSES.reserved,
  sold: TICKET_STATUS_CLASSES.sold,
  validated: TICKET_STATUS_CLASSES.validated,
  cancelled: TICKET_STATUS_CLASSES.cancelled,
};

const resolvedVariant = status && variants[status] ? status : variant;
const label = status ? getTicketStatusLabel(status) : undefined;
const classes = [base, variants[resolvedVariant] ?? variants.default, className].join(" ");
---

<span class={classes}>
  {label ?? <slot />}
</span>
