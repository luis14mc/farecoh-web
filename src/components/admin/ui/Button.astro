---
interface Props {
  variant?: "default" | "secondary" | "outline" | "ghost" | "destructive";
  size?: "default" | "sm" | "lg" | "icon";
  type?: "button" | "submit" | "reset";
  href?: string;
  id?: string;
  disabled?: boolean;
  class?: string;
  fullWidthMobile?: boolean;
  adminLogout?: boolean;
}

const {
  variant = "default",
  size = "default",
  type = "button",
  href,
  id,
  disabled = false,
  class: className = "",
  fullWidthMobile = false,
  adminLogout = false,
} = Astro.props;

const base =
  "inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/40 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50";

const variants: Record<NonNullable<Props["variant"]>, string> = {
  default: "bg-primary text-on-primary shadow-sm hover:bg-secondary",
  secondary: "bg-secondary text-on-secondary shadow-sm hover:opacity-90",
  outline: "border border-outline-variant bg-white text-on-surface shadow-sm hover:bg-surface-container-low",
  ghost: "text-on-surface hover:bg-surface-container-low",
  destructive: "bg-error text-on-error shadow-sm hover:opacity-90",
};

const sizes: Record<NonNullable<Props["size"]>, string> = {
  default: "h-11 px-4 py-2",
  sm: "h-9 rounded-md px-3 text-xs",
  lg: "h-12 rounded-md px-6 text-base",
  icon: "h-10 w-10",
};

const widthClass = fullWidthMobile ? "w-full sm:w-auto" : "";
const classes = [base, variants[variant], sizes[size], widthClass, className].filter(Boolean).join(" ");
---

{href ? (
  <a href={href} class={classes} id={id}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} id={id} disabled={disabled} data-admin-logout={adminLogout || undefined}>
    <slot />
  </button>
)}
