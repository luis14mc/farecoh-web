---
import Card from "@/components/admin/ui/Card.astro";
import { supabase } from "@/lib/supabase";
import { formatSiteCurrency } from "@/lib/locale";

const { data: sales = [] } = await supabase
  .from("sales")
  .select("sales_point, amount");

const salesByPointMap: Record<string, number> = {};
sales?.forEach((sale: { sales_point: string | null; amount: number | string }) => {
  const point = sale.sales_point || "Sin punto";
  salesByPointMap[point] = (salesByPointMap[point] || 0) + Number(sale.amount);
});

const salesByPoint = Object.entries(salesByPointMap)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 5);
const maxPointSales = Math.max(...salesByPoint.map(([, amt]) => amt), 1);
---

<Card>
  <h3 class="text-sm font-semibold text-on-surface">Ventas por punto</h3>
  <p class="mt-1 text-xs text-on-surface-variant">Recaudación por punto de venta</p>

  {salesByPoint.length > 0 ? (
    <div class="mt-5 space-y-4">
      {salesByPoint.map(([point, amount]) => {
        const pct = (amount / maxPointSales) * 100;
        return (
          <div class="space-y-1.5">
            <div class="flex justify-between gap-3 text-sm">
              <span class="truncate font-medium">{point}</span>
              <span class="shrink-0 font-semibold text-secondary">{formatSiteCurrency(amount)}</span>
            </div>
            <div class="h-2 w-full overflow-hidden rounded-full bg-surface-container-low">
              <div class="h-full rounded-full bg-secondary-container transition-all" style={`width: ${pct}%`}></div>
            </div>
          </div>
        );
      })}
    </div>
  ) : (
    <p class="py-8 text-sm text-on-surface-variant">No hay registros por punto de venta.</p>
  )}
</Card>
