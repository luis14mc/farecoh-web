---
import Card from "@/components/admin/ui/Card.astro";
import FormField from "@/components/admin/ui/FormField.astro";
import Input from "@/components/admin/ui/Input.astro";
import Button from "@/components/admin/ui/Button.astro";
import { SITE_LOCALE } from "@/lib/locale";
---

<Card class="h-full">
  <h3 class="mb-4 flex items-center gap-2 text-base font-semibold text-on-surface">
    <span class="material-symbols-outlined text-primary">qr_code_scanner</span>
    Control de acceso rápido
  </h3>

  <div class="space-y-4">
    <FormField label="Buscar por código" htmlFor="checkin-search">
      <div class="flex flex-col gap-3 sm:flex-row">
        <Input id="checkin-search" placeholder="PF-000001" mono class="min-w-0 flex-1" />
        <Button id="search-btn" type="button" fullWidthMobile class="sm:shrink-0">
          <span class="material-symbols-outlined text-base">search</span>
          Buscar
        </Button>
      </div>
    </FormField>

    <div id="checkin-status-msg" class="hidden rounded-lg border px-4 py-3 text-sm" role="alert"></div>

    <div id="result-card" class="hidden rounded-lg border border-dashed border-primary/30 bg-primary/5 p-4">
      <div class="mb-4 flex items-start justify-between gap-4">
        <div>
          <p class="text-xs font-medium uppercase tracking-wide text-primary">Boleto encontrado</p>
          <h4 class="font-mono text-lg font-semibold text-on-surface" id="res-code">PF-000001</h4>
        </div>
        <span id="res-badge" class="inline-flex rounded-full px-2.5 py-0.5 text-xs font-semibold"></span>
      </div>

      <dl class="mb-4 space-y-2 text-sm">
        <div class="flex justify-between gap-4 border-b border-outline-variant/30 pb-2">
          <dt class="text-on-surface-variant">Comprador</dt>
          <dd class="font-medium text-right" id="res-name">-</dd>
        </div>
        <div class="flex justify-between gap-4 border-b border-outline-variant/30 pb-2">
          <dt class="text-on-surface-variant">Teléfono</dt>
          <dd class="font-medium text-right" id="res-phone">-</dd>
        </div>
        <div class="flex justify-between gap-4 border-b border-outline-variant/30 pb-2">
          <dt class="text-on-surface-variant">Estado</dt>
          <dd class="font-medium text-right" id="res-status">-</dd>
        </div>
        <div id="checked-in-time-row" class="hidden flex justify-between gap-4">
          <dt class="text-on-surface-variant">Ingreso</dt>
          <dd class="font-medium text-right text-green-700" id="res-time">-</dd>
        </div>
      </dl>

      <Button id="validate-btn" type="button" variant="secondary" fullWidthMobile class="w-full">
        <span class="material-symbols-outlined text-base">how_to_reg</span>
        Validar ingreso
      </Button>
    </div>
  </div>
</Card>

<script define:vars={{ siteLocale: SITE_LOCALE }}>
  import { supabase } from "@/lib/supabase";
  import { TICKET_STATUS_LABELS, TICKET_STATUS_CLASSES } from "@/lib/ticket-status";

  const searchInput = document.getElementById("checkin-search");
  const searchBtn = document.getElementById("search-btn");
  const msgBox = document.getElementById("checkin-status-msg");
  const resultCard = document.getElementById("result-card");
  const validateBtn = document.getElementById("validate-btn") as HTMLButtonElement | null;

  const resCode = document.getElementById("res-code");
  const resBadge = document.getElementById("res-badge");
  const resName = document.getElementById("res-name");
  const resPhone = document.getElementById("res-phone");
  const resStatus = document.getElementById("res-status");
  const checkedInTimeRow = document.getElementById("checked-in-time-row");
  const resTime = document.getElementById("res-time");

  let activeTicket: any = null;

  const msgClasses = {
    error: "border-red-200 bg-red-50 text-red-800",
    success: "border-green-200 bg-green-50 text-green-800",
    info: "border-blue-200 bg-blue-50 text-blue-800",
  };

  const showMsg = (text: string, type: "error" | "info" | "success") => {
    if (!msgBox) return;
    msgBox.textContent = text;
    msgBox.className = `rounded-lg border px-4 py-3 text-sm ${msgClasses[type]}`;
    msgBox.classList.remove("hidden");
  };

  const setValidateBtnState = (mode: "ready" | "disabled" | "loading" | "success", label?: string) => {
    if (!validateBtn) return;
    validateBtn.className =
      "inline-flex h-11 w-full items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium transition-colors sm:w-auto";

    if (mode === "loading") {
      validateBtn.disabled = true;
      validateBtn.classList.add("bg-secondary", "text-on-secondary", "opacity-80", "cursor-wait");
      validateBtn.innerHTML = `<span class="material-symbols-outlined animate-spin text-base">sync</span> Validando...`;
      return;
    }

    if (mode === "success") {
      validateBtn.disabled = true;
      validateBtn.classList.add("bg-green-600", "text-white");
      validateBtn.innerHTML = `<span class="material-symbols-outlined text-base">check_circle</span> Acceso concedido`;
      return;
    }

    if (mode === "disabled") {
      validateBtn.disabled = true;
      validateBtn.classList.add("bg-zinc-300", "text-white", "cursor-not-allowed");
      validateBtn.textContent = label || "No disponible";
      return;
    }

    validateBtn.disabled = false;
    validateBtn.classList.add("bg-secondary", "text-on-secondary", "hover:opacity-90");
    validateBtn.innerHTML = `<span class="material-symbols-outlined text-base">how_to_reg</span> ${label || "Validar ingreso"}`;
  };

  const handleSearch = async () => {
    if (!searchInput || !resultCard) return;
    const query = (searchInput as HTMLInputElement).value.trim().toUpperCase();

    if (!query) {
      showMsg("Por favor ingrese un código de boleto.", "error");
      resultCard.classList.add("hidden");
      return;
    }

    showMsg("Buscando boleto...", "info");
    resultCard.classList.add("hidden");
    activeTicket = null;

    const { data, error } = await supabase.from("tickets").select("*").eq("ticket_code", query).single();

    if (error || !data) {
      showMsg("Boleto no encontrado. Verifique el código.", "error");
      return;
    }

    activeTicket = data;
    showMsg("Boleto encontrado.", "success");

    if (resCode) resCode.textContent = data.ticket_code;
    if (resName) resName.textContent = data.buyer_name || "Invitado";
    if (resPhone) resPhone.textContent = data.buyer_phone || "Sin teléfono";
    if (resStatus) resStatus.textContent = TICKET_STATUS_LABELS[data.status as keyof typeof TICKET_STATUS_LABELS] || data.status;

    if (resBadge) {
      const badgeClass = TICKET_STATUS_CLASSES[data.status as keyof typeof TICKET_STATUS_CLASSES] || TICKET_STATUS_CLASSES.available;
      resBadge.className = `inline-flex rounded-full px-2.5 py-0.5 text-xs font-semibold ${badgeClass}`;
      resBadge.textContent = TICKET_STATUS_LABELS[data.status as keyof typeof TICKET_STATUS_LABELS] || data.status;
    }

    if (data.status === "validated" && data.validated_at) {
      checkedInTimeRow?.classList.remove("hidden");
      if (resTime) {
        const time = new Date(data.validated_at).toLocaleTimeString(siteLocale, { hour: "numeric", minute: "2-digit" });
        resTime.textContent = `Ingresó a las ${time}`;
      }
    } else {
      checkedInTimeRow?.classList.add("hidden");
    }

    if (data.status === "validated") setValidateBtnState("disabled", "Ingreso ya validado");
    else if (data.status === "cancelled") setValidateBtnState("disabled", "Boleto anulado");
    else if (data.status !== "sold") setValidateBtnState("disabled", "Boleto no vendido");
    else setValidateBtnState("ready");

    resultCard.classList.remove("hidden");
  };

  searchBtn?.addEventListener("click", handleSearch);
  searchInput?.addEventListener("keydown", (e) => {
    if (e.key === "Enter") handleSearch();
  });

  validateBtn?.addEventListener("click", async () => {
    if (!activeTicket || !validateBtn) return;
    setValidateBtnState("loading");

    try {
      const { data, error } = await supabase.rpc("validate_ticket", {
        p_ticket_code: activeTicket.ticket_code,
        p_validated_by: "admin-dashboard",
      });

      if (error) throw error;
      const result = data?.[0];
      if (!result?.ok) throw new Error(result?.message || "No se pudo validar el boleto.");

      const now = result.validated_at || new Date().toISOString();
      setValidateBtnState("success");

      if (resBadge) {
        resBadge.className = `inline-flex rounded-full px-2.5 py-0.5 text-xs font-semibold ${TICKET_STATUS_CLASSES.validated}`;
        resBadge.textContent = TICKET_STATUS_LABELS.validated;
      }
      checkedInTimeRow?.classList.remove("hidden");
      if (resTime) {
        const time = new Date(now).toLocaleTimeString(siteLocale, { hour: "numeric", minute: "2-digit" });
        resTime.textContent = `Ingresó a las ${time}`;
      }

      showMsg("Entrada validada correctamente.", "success");
    } catch {
      setValidateBtnState("ready");
      showMsg("Error al validar el ingreso. Intente de nuevo.", "error");
    }
  });
</script>
