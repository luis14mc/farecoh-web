---
import Card from "@/components/admin/ui/Card.astro";
import Table from "@/components/admin/ui/Table.astro";
import { supabase } from "@/lib/supabase";
import { getTicketStatusLabel } from "@/lib/ticket-status";

const { data: reservations = [] } = await supabase
  .from("tickets")
  .select("ticket_code, buyer_name, buyer_phone, created_at")
  .eq("status", "reserved")
  .order("ticket_code", { ascending: false })
  .limit(8);
---

<Card padding={false}>
  <div class="border-b border-outline-variant px-6 py-4">
    <h3 class="text-base font-semibold text-on-surface">Reservas recientes</h3>
    <p class="mt-1 text-sm text-on-surface-variant">Boletos reservados desde el formulario público</p>
  </div>
  <Table minWidth="640px" class="border-0 rounded-none">
    <thead class="border-b border-outline-variant bg-surface-container-low">
      <tr>
        <th class="h-11 px-4 text-left text-xs font-medium uppercase tracking-wide text-on-surface-variant">Código</th>
        <th class="h-11 px-4 text-left text-xs font-medium uppercase tracking-wide text-on-surface-variant">Comprador</th>
        <th class="h-11 px-4 text-left text-xs font-medium uppercase tracking-wide text-on-surface-variant">Teléfono</th>
        <th class="h-11 px-4 text-left text-xs font-medium uppercase tracking-wide text-on-surface-variant">Estado</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-outline-variant">
      {reservations.length ? reservations.map((ticket) => (
        <tr class="hover:bg-surface-container-low/70">
          <td class="px-4 py-3 font-mono text-sm font-semibold text-primary">{ticket.ticket_code}</td>
          <td class="px-4 py-3 text-sm">{ticket.buyer_name || "-"}</td>
          <td class="px-4 py-3 text-sm text-on-surface-variant">{ticket.buyer_phone || "-"}</td>
          <td class="px-4 py-3 text-sm">{getTicketStatusLabel("reserved")}</td>
        </tr>
      )) : (
        <tr>
          <td colspan="4" class="px-4 py-10 text-center text-sm text-on-surface-variant">No hay reservas recientes.</td>
        </tr>
      )}
    </tbody>
  </Table>
</Card>
