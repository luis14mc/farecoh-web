---
import FarecohLogo from "@/components/layout/FarecohLogo.astro";
import { getPublicSupabaseConfig, isAuthConfigured, STAFF_ROLE_LABELS, type StaffProfile } from "@/lib/auth";
import { canAccessRoute } from "@/lib/rbac";

interface Props {
  active?: string;
}

const { active = "dashboard" } = Astro.props;
const staffProfile = Astro.locals.staffProfile as StaffProfile | undefined;
const { supabaseUrl, supabaseAnonKey } = getPublicSupabaseConfig();
const authConfigured = isAuthConfigured({ supabaseUrl, supabaseAnonKey });

const navItems = [
  { label: "Panel", href: "/admin", icon: "dashboard", key: "dashboard" },
  { label: "Usuarios", href: "/admin/usuarios", icon: "admin_panel_settings", key: "usuarios" },
  { label: "Ventas", href: "/admin/ventas", icon: "payments", key: "ventas" },
  { label: "Boletos", href: "/admin/boletos", icon: "confirmation_number", key: "boletos" },
  { label: "Lotes", href: "/admin/lotes", icon: "inventory_2", key: "lotes" },
  { label: "Acceso", href: "/admin/checkin", icon: "qr_code_scanner", key: "checkin" },
  { label: "Vendedores", href: "/admin/vendedores", icon: "group", key: "vendedores" },
  { label: "Reportes", href: "/admin/reportes", icon: "monitoring", key: "reportes" },
].filter((item) => staffProfile && canAccessRoute(staffProfile.role, item.href));

const linkClass = (key: string) => {
  const base = "flex items-center gap-3 px-4 py-3 rounded-lg text-label-md font-label-md transition-all";
  if (active === key) return `${base} bg-secondary-container text-on-secondary-container font-bold translate-x-1`;
  return `${base} text-on-surface-variant hover:bg-surface-container-highest`;
};
---

<aside class="hidden md:flex flex-col h-screen p-4 space-y-stack-md bg-surface-container-low border-r border-outline-variant w-64 shrink-0 overflow-y-auto custom-scrollbar text-on-surface">
  <div class="mb-8 px-2">
    <a href="/" aria-label="FARECOH inicio">
      <FarecohLogo variant="stacked" theme="color" size="admin" />
    </a>
    <p class="mt-2 text-label-md font-label-md text-on-surface-variant opacity-70">Portal administrativo</p>
  </div>
  
  <div class="flex items-center gap-3 p-3 mb-6 bg-surface-container rounded-lg">
    <div class="w-10 h-10 rounded-full bg-primary-container flex items-center justify-center text-on-primary">
      <span class="material-symbols-outlined">person</span>
    </div>
    <div class="min-w-0">
      <p class="truncate text-label-md font-label-md text-on-surface font-bold">{staffProfile?.full_name ?? "Administrador"}</p>
      <p class="truncate text-caption font-caption text-on-surface-variant">{staffProfile ? STAFF_ROLE_LABELS[staffProfile.role] : "staff"}</p>
    </div>
  </div>
  
  <nav class="flex-1 space-y-2">
    {navItems.map((item) => (
      <a class={linkClass(item.key)} href={item.href}>
        <span class="material-symbols-outlined">{item.icon}</span>
        <span>{item.label}</span>
      </a>
    ))}
  </nav>

  <button id="admin-logout" class="w-full mt-auto py-3 border border-outline-variant text-on-surface font-bold rounded-lg hover:bg-surface-container-high transition-colors flex items-center justify-center gap-2 text-center text-label-md font-label-md cursor-pointer" type="button">
    <span class="material-symbols-outlined">logout</span>
    Cerrar sesión
  </button>
</aside>

<script define:vars={{ supabaseUrl, supabaseAnonKey, authConfigured }}>
  import { createBrowserClient } from "@supabase/ssr";

  const supabase = authConfigured ? createBrowserClient(supabaseUrl, supabaseAnonKey) : null;
  document.getElementById("admin-logout")?.addEventListener("click", async () => {
    if (supabase) await supabase.auth.signOut();
    window.location.href = "/admin/login";
  });
</script>