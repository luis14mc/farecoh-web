---
import FarecohLogo from "@/components/layout/FarecohLogo.astro";

interface Props {
  active?: "home" | "events" | "tickets";
  variant?: "light" | "dark" | "concert";
}

const { active, variant = "light" } = Astro.props;

const navItems = [
  { label: "Inicio", href: "/", key: "home" },
  { label: "Evento", href: "/eventos/pink-floyd", key: "events" },
  { label: "Boletos", href: "/eventos/pink-floyd/boletos", key: "tickets" },
];

const ticketsHref = "/eventos/pink-floyd/boletos";

const headerClass =
  variant === "concert"
    ? "fixed top-0 left-0 z-50 w-full border-b border-concert-orange/20 bg-concert-deep/90 py-4 backdrop-blur-md transition-all duration-300"
    : variant === "dark"
      ? "fixed top-0 left-0 z-50 w-full border-b border-outline/10 bg-on-background/90 py-4 backdrop-blur-md transition-all duration-300"
      : "fixed top-0 left-0 z-50 w-full border-b border-outline-variant bg-surface/90 py-4 backdrop-blur-md transition-all duration-300";

const inactiveClass =
  variant === "concert"
    ? "text-white/65 hover:text-concert-amber"
    : variant === "dark"
      ? "text-surface-bright/70 hover:text-primary-container"
      : "text-on-surface-variant hover:text-primary";

const activeClass =
  variant === "concert"
    ? "border-b-2 border-concert-orange pb-1 font-bold text-concert-amber"
    : variant === "dark"
      ? "border-b-2 border-primary-container pb-1 font-bold text-primary-container"
      : "border-b-2 border-primary pb-1 font-bold text-primary";

const logoTheme = variant === "light" ? "color" : "white";

const ctaClass =
  variant === "concert"
    ? "bg-gradient-to-r from-concert-orange to-concert-orange-mid px-6 py-2 text-label-md font-label-md text-white transition-all hover:from-concert-orange-mid hover:to-concert-amber hover:text-concert-deep active:scale-95 whitespace-nowrap shadow-[0_0_20px_rgba(255,77,0,0.35)]"
    : "bg-primary-container px-6 py-2 text-label-md font-label-md text-on-primary-container transition-all hover:bg-primary active:scale-95 whitespace-nowrap";

const mobileMenuClass =
  variant === "concert"
    ? "border-concert-orange/25 bg-concert-elevated"
    : variant === "dark"
      ? "border-outline/20 bg-on-background"
      : "border-outline-variant bg-surface";

const mobileActiveClass =
  variant === "concert" ? "font-bold text-concert-amber" : "font-bold text-primary-container";

const menuIconClass =
  variant === "concert" ? "text-white" : variant === "dark" ? "text-surface-bright" : "text-on-surface";
---

<header class={headerClass} id="main-header">
  <div class="mx-auto flex w-full max-w-container-max items-center justify-between px-margin">
    <a href="/" class="transition-opacity hover:opacity-90" aria-label="FARECOH inicio">
      <FarecohLogo variant="horizontal" theme={logoTheme} size="nav" loading="eager" />
    </a>

    <nav class="hidden items-center space-x-stack-lg md:flex" aria-label="Navegación principal">
      {navItems.map((item) => (
        <a class={`text-label-md font-label-md transition-colors ${active === item.key ? activeClass : inactiveClass}`} href={item.href}>
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-4">
      <a href={ticketsHref} class={ctaClass}>
        Reservar boletos
      </a>

      <details class="group relative md:hidden">
        <summary class={`list-none cursor-pointer focus:outline-none ${menuIconClass}`} aria-label="Abrir menú">
          <span class="material-symbols-outlined align-middle text-[28px]">menu</span>
        </summary>
        <div class={`absolute right-0 top-full z-[60] mt-4 min-w-[240px] border p-6 shadow-2xl ${mobileMenuClass}`}>
          <nav class="flex flex-col gap-4" aria-label="Navegación móvil">
            {navItems.map((item) => (
              <a class={`text-label-md font-label-md ${active === item.key ? mobileActiveClass : "opacity-80"}`} href={item.href}>
                {item.label}
              </a>
            ))}
            <a class={`mt-2 px-4 py-3 text-center text-label-md font-label-md ${variant === "concert" ? "bg-gradient-to-r from-concert-orange to-concert-orange-mid text-white" : "bg-primary-container text-on-primary-container"}`} href={ticketsHref}>
              Reservar boletos
            </a>
          </nav>
        </div>
      </details>
    </div>
  </div>
</header>

<script is:inline>
  window.addEventListener("scroll", () => {
    const nav = document.getElementById("main-header");
    if (!nav) return;
    nav.classList.toggle("shadow-lg", window.scrollY > 50);
    nav.classList.toggle("py-2", window.scrollY > 50);
    nav.classList.toggle("py-4", window.scrollY <= 50);
  });
</script>
