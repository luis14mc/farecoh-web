---
import ArrowRight from "@lucide/astro/icons/arrow-right";
import { homeFeaturedEvent } from "@/data/home";
import { eventPage } from "@/data/event-page";
import { formatEventCompactDate, getPinkFloydEvent } from "@/lib/events";
import { formatSiteCurrency } from "@/lib/locale";

const event = await getPinkFloydEvent();

const compactDate = formatEventCompactDate(event.date);
const formattedPrice = formatSiteCurrency(event.ticket_price);
const venueBadge = event.venue.split(",")[0]?.trim() || event.venue;

const titleMatch = event.name.match(/^(Tributo a)\s+(.+)$/i);
const titleLead = titleMatch?.[1] ?? event.name;
const titleAccent = titleMatch?.[2] ?? "";
---

<section
  class="reveal-section event-v2-featured-home relative overflow-hidden bg-black"
  aria-labelledby="featured-event-title"
>
  <div class="absolute inset-0 z-0">
    <div class="parallax-layer h-full w-full" data-parallax data-parallax-speed="0.28" data-parallax-scale="1.08">
      <img
        class="event-v2-bw h-full w-full object-cover"
        src={eventPage.hero.image}
        alt={eventPage.hero.imageAlt}
        loading="lazy"
        width="1600"
        height="1067"
      />
    </div>
    <div class="event-v2-hero-gradient absolute inset-0" aria-hidden="true"></div>
    <div class="event-v2-hero-scrim absolute inset-0 bg-black/45" aria-hidden="true"></div>
  </div>

  <div class="landing-shell event-v2-hero-content relative z-10 py-16 md:py-24">
    <div class="grid grid-cols-1 items-end gap-12 lg:grid-cols-12 lg:gap-16">
      <div class="space-y-5 lg:col-span-7">
        <span class="event-v2-badge">{venueBadge}</span>

        <h2 id="featured-event-title" class="event-v2-display uppercase italic text-white">
          {titleAccent ? (
            <>
              {titleLead}{" "}
              <span class="text-concert-orange">{titleAccent}</span>
            </>
          ) : (
            event.name
          )}
        </h2>

        <p class="body-lg max-w-2xl font-light text-white/90">{eventPage.hero.tagline}</p>

        <ul class="flex flex-wrap gap-x-8 gap-y-3 pt-1" role="list">
          <li class="flex items-center gap-3 text-white">
            <span class="material-symbols-outlined text-concert-orange" aria-hidden="true">calendar_month</span>
            <span class="label-caps">{compactDate}</span>
          </li>
          <li class="flex items-center gap-3 text-white">
            <span class="material-symbols-outlined text-concert-orange" aria-hidden="true">schedule</span>
            <span class="label-caps">{event.time}</span>
          </li>
          <li class="flex items-center gap-3 text-white">
            <span class="material-symbols-outlined text-concert-orange" aria-hidden="true">payments</span>
            <span class="label-caps">{formattedPrice}</span>
          </li>
        </ul>

        <div class="flex flex-col gap-4 pt-4 sm:flex-row sm:flex-wrap">
          <a href="/eventos/pink-floyd/boletos" class="event-rock-button group inline-flex items-center justify-center gap-4 px-8 py-4 sm:px-10 sm:py-5">
            <span class="label-caps tracking-widest">{homeFeaturedEvent.ctaTickets}</span>
            <ArrowRight size={20} stroke-width={2} class="transition-transform group-hover:translate-x-1" aria-hidden="true" />
          </a>
          <a
            href="/eventos/pink-floyd"
            class="inline-flex items-center justify-center border border-white/25 px-8 py-4 text-center label-caps tracking-widest text-white transition hover:border-concert-orange hover:text-concert-orange sm:px-10 sm:py-5"
          >
            {homeFeaturedEvent.ctaEvent}
          </a>
        </div>
      </div>

      <div class="lg:col-span-5">
        <div class="overflow-hidden border border-white/10 bg-black/20">
          <div class="relative aspect-[4/3]">
            <img
              class="h-full w-full object-cover"
              src={eventPage.experience.image}
              alt={eventPage.experience.imageAlt}
              loading="lazy"
              width="1200"
              height="675"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent" aria-hidden="true"></div>
            <div class="absolute bottom-0 left-0 p-5 md:p-6">
              <p class="label-caps text-concert-orange">{eventPage.experience.titleLead}</p>
              <p class="headline-md uppercase italic text-white">
                {eventPage.experience.titleAccent}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="event-prism-accent relative z-10" aria-hidden="true"></div>
</section>
