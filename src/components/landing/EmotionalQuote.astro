---
import { homeQuote } from "@/data/home";
---

<section class="reveal-section landing-section bg-surface-container-low">
  <div class="landing-shell">
    <blockquote class="landing-quote mx-auto max-w-4xl text-center">
      <p class="landing-quote-text">{homeQuote.text}</p>
      <footer class="mt-stack-lg">
        <cite class="landing-eyebrow not-italic text-brand-700">{homeQuote.signature}</cite>
      </footer>
    </blockquote>
  </div>
</section>
