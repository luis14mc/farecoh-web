---
import { homeTestimonial } from "@/data/home";
---

<section class="reveal-section landing-section bg-surface">
  <div class="landing-shell grid grid-cols-1 items-center gap-gutter lg:grid-cols-12">
    <figure class="editorial-image aspect-[4/3] lg:col-span-5">
      <img src={homeTestimonial.image} alt="Participante joven de FARECOH en una presentación artística" loading="lazy" />
    </figure>
    <blockquote class="lg:col-span-7 lg:pl-stack-lg">
      <p class="text-[clamp(2rem,4vw,4rem)] font-black leading-[1.05] tracking-[-0.03em] text-on-surface">“{homeTestimonial.quote}”</p>
      <footer class="mt-stack-md">
        <cite class="landing-eyebrow not-italic text-brand-700">{homeTestimonial.name}</cite>
      </footer>
    </blockquote>
  </div>
</section>
