---
import type { Lang } from "@/i18n/types";
import { getAlternateLang, getAlternateLangPath } from "@/i18n/routes";
import { getDictionary } from "@/i18n";

interface Props {
  lang: Lang;
  currentPath: string;
  class?: string;
}

const { lang, currentPath, class: className = "" } = Astro.props;
const alternateLang = getAlternateLang(lang);
const alternateHref = getAlternateLangPath(currentPath);
const label = getDictionary(lang).footer.languageSwitch;
---

<a
  class={`label-caps text-[var(--prism-text-secondary)] transition-colors hover:text-[var(--prism-gold)] ${className}`}
  href={alternateHref}
  hreflang={alternateLang}
  lang={alternateLang}
>
  {label}
</a>
