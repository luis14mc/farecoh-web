---
interface Props {
  eventHref: string;
}

const { eventHref } = Astro.props;
---

<section class="relative isolate min-h-screen overflow-hidden px-4 py-6 sm:px-6 lg:px-8">
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_50%_30%,rgba(255,255,255,0.09),transparent_26rem)]"></div>
  <div class="mx-auto flex min-h-[calc(100vh-3rem)] w-full max-w-7xl flex-col">
    <header class="flex items-center justify-between py-2" aria-label="Navegación principal">
      <a href="/" class="text-sm font-black tracking-[0.32em] text-white uppercase">FARECOH</a>
      <nav class="hidden items-center gap-8 text-sm font-medium text-white/76 sm:flex">
        <a class="transition hover:text-white" href="#programas">Programas</a>
        <a class="transition hover:text-white" href="#impacto">Impacto</a>
        <a class="transition hover:text-white" href={eventHref}>Evento</a>
      </nav>
      <a class="btn btn-sm border-white/20 bg-white text-black hover:bg-farecoh-silver" href={eventHref}>Ver evento</a>
    </header>

    <div class="grid flex-1 items-center gap-12 py-16 lg:grid-cols-[1.05fr_0.95fr]">
      <div class="max-w-3xl">
        <p class="mb-5 text-sm font-semibold tracking-[0.28em] text-prism-gold uppercase">Plataforma de eventos solidarios</p>
        <h1 class="text-5xl font-black leading-[0.95] text-white sm:text-6xl lg:text-8xl">
          FARECOH <span class="prism-text block">Events</span>
        </h1>
        <p class="mt-7 max-w-2xl text-lg leading-8 text-farecoh-muted sm:text-xl">
          Experiencias culturales premium con venta de boletos, acceso por QR y administración preparada para múltiples eventos.
        </p>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <a class="btn btn-lg border-0 bg-prism-gold text-black hover:bg-[#ffe08d]" href={eventHref}>Explorar evento</a>
          <a class="btn btn-lg border-white/20 bg-white/8 text-white hover:bg-white/14" href="#impacto">Conocer FARECOH</a>
        </div>
      </div>

      <div class="relative min-h-[420px] overflow-hidden rounded-lg border border-white/12 bg-black/30 shadow-2xl">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(255,255,255,0.12),transparent_15rem)]"></div>
        <div class="absolute left-[18%] top-1/2 h-1 w-[72%] -translate-y-1/2 bg-white/70 shadow-[0_0_34px_rgba(255,255,255,0.7)]"></div>
        <div class="absolute left-[42%] top-1/2 h-44 w-44 -translate-y-1/2 rotate-45 border border-white/50 bg-white/5 backdrop-blur-sm"></div>
        <div class="absolute left-[54%] top-[44%] h-1 w-[34%] rotate-[-14deg] bg-prism-red shadow-[0_0_22px_rgba(255,59,95,0.8)]"></div>
        <div class="absolute left-[54%] top-[49%] h-1 w-[38%] bg-prism-gold shadow-[0_0_22px_rgba(255,209,102,0.7)]"></div>
        <div class="absolute left-[54%] top-[54%] h-1 w-[36%] rotate-[14deg] bg-prism-green shadow-[0_0_22px_rgba(66,211,146,0.7)]"></div>
        <div class="absolute left-[54%] top-[59%] h-1 w-[32%] rotate-[27deg] bg-prism-cyan shadow-[0_0_22px_rgba(53,199,255,0.7)]"></div>
        <div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-black via-black/70 to-transparent"></div>
        <div class="absolute bottom-6 left-6 right-6">
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-white/58">Prisma, humo y comunidad</p>
          <p class="mt-2 text-2xl font-bold text-white">Producción visual diseñada para noches memorables.</p>
        </div>
      </div>
    </div>
  </div>
</section>
