---
import type { Lang } from "@/i18n/types";
import { getDictionary } from "@/i18n";
import { strategicPartners } from "@/data/site";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const p = getDictionary(lang).home.partners;
const s = getDictionary(lang).home.sponsors;
---

<section class="prism-section border-t border-[var(--prism-divider)]">
  <div class="prism-container">
    <p class="subheader text-[var(--prism-outline)]">{p.title}</p>
    <ul class="mt-12 grid gap-px bg-[var(--prism-divider)] sm:grid-cols-2 lg:grid-cols-3">
      {
        strategicPartners.map((partner) => (
          <li class="bg-[var(--prism-bg)] px-6 py-8">
            <p class="label-caps text-[var(--prism-text-secondary)]">{partner}</p>
          </li>
        ))
      }
    </ul>

    <div class="mt-20 border border-[var(--prism-outline-variant)] p-8 md:p-12">
      <p class="subheader text-[var(--prism-outline)]">{s.title}</p>
      <p class="body-md mt-6 max-w-2xl text-[var(--prism-text-secondary)]">{s.placeholder}</p>
      <div class="mt-10 grid gap-px bg-[var(--prism-divider)] sm:grid-cols-2 lg:grid-cols-4">
        {[1, 2, 3, 4].map((n) => (
          <div class="flex min-h-[80px] items-center justify-center bg-[var(--prism-surface-lowest)] px-4">
            <span class="label-caps text-[var(--prism-outline)]">—</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
