---
import type { Lang, RouteKey } from "@/i18n/types";
import { getDictionary } from "@/i18n";
import { getLocalizedPath } from "@/i18n/routes";
import LanguageSwitcher from "./LanguageSwitcher.astro";

interface Props {
  lang: Lang;
  active?: RouteKey;
  variant?: "default" | "event";
}

const { lang, active, variant = "default" } = Astro.props;
const t = getDictionary(lang).nav;
const currentPath = Astro.url.pathname;

const homeHref = getLocalizedPath(lang, "home");
const navItems: { key: RouteKey; href: string; label: string }[] = [
  { key: "about", href: getLocalizedPath(lang, "about"), label: t.about },
  { key: "programs", href: getLocalizedPath(lang, "programs"), label: t.programs },
  { key: "events", href: getLocalizedPath(lang, "events"), label: t.events },
];
const donateHref = getLocalizedPath(lang, "donate");

const linkClass = (key: RouteKey) =>
  active === key
    ? "body-md text-[var(--prism-gold)]"
    : "body-md text-[var(--prism-text-secondary)] transition-colors hover:text-[var(--prism-gold)]";

const headerClass =
  variant === "event"
    ? "border-b border-[var(--prism-divider)] bg-[var(--prism-surface-lowest)]"
    : "border-b border-[var(--prism-divider)] bg-[var(--prism-bg)]";
---

<header class={`sticky top-0 z-50 ${headerClass}`}>
  <div class="prism-container flex min-h-[72px] items-center justify-between gap-6 md:min-h-20">
    <a href={homeHref} class="flex items-center gap-3" aria-label="FARECOH">
      <img class="h-10 w-auto md:h-12" src="/images/Logo Farecoh VARIANTE.png" alt="" width="96" height="96" />
      <span class="label-caps hidden text-[var(--prism-text)] sm:inline">FARECOH</span>
    </a>

    <nav class="hidden items-center gap-10 md:flex" aria-label={t.mainNav}>
      <a class={linkClass("home")} href={homeHref}>{t.home}</a>
      {navItems.map((item) => (
        <a class={linkClass(item.key)} href={item.href}>{item.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-4 md:gap-6">
      <LanguageSwitcher lang={lang} currentPath={currentPath} class="hidden sm:inline-flex" />
      <a class="btn-prism-primary hidden min-h-0 px-4 py-2 text-xs sm:inline-flex" href={donateHref}>{t.donate}</a>

      <details class="relative md:hidden">
        <summary class="label-caps cursor-pointer list-none text-[var(--prism-text)] [&::-webkit-details-marker]:hidden" aria-label={t.openMenu}>
          Menu
        </summary>
        <div class="absolute right-0 top-full z-[60] mt-2 min-w-[200px] border border-[var(--prism-outline-variant)] bg-[var(--prism-surface-low)] p-4">
          <nav class="flex flex-col gap-4" aria-label={t.mainNav}>
            <a class="body-md text-[var(--prism-text)]" href={homeHref}>{t.home}</a>
            {navItems.map((item) => (
              <a class="body-md text-[var(--prism-text-secondary)]" href={item.href}>{item.label}</a>
            ))}
            <hr class="prism-divider" />
            <LanguageSwitcher lang={lang} currentPath={currentPath} />
            <a class="btn-prism-primary w-full text-center text-xs" href={donateHref}>{t.donate}</a>
          </nav>
        </div>
      </details>
    </div>
  </div>
</header>
