---
import type { Lang } from "@/i18n/types";
import { getDictionary } from "@/i18n";
import { events } from "@/data/events";
import PageHero from "./PageHero.astro";
import EventCard from "./EventCard.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const e = getDictionary(lang).eventsPage;
---

<PageHero label={e.label} title={e.title} intro={e.intro} />

<section class="prism-section">
  <div class="prism-container">
    <p class="subheader text-[var(--prism-outline)]">{e.upcoming}</p>
    <hr class="prism-divider mt-6" />
    <ul class="mt-12 grid gap-px bg-[var(--prism-divider)]">
      {events.map((event) => (
        <li>
          <EventCard lang={lang} event={event} />
        </li>
      ))}
    </ul>
  </div>
</section>
