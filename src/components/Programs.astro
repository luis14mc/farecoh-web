---
import type { ProgramItem } from "@/data/events";

interface Props {
  items: ProgramItem[];
}

const { items } = Astro.props;
---

<section id="programas" class="py-20 sm:py-28">
  <div class="mx-auto w-[min(1120px,calc(100%-32px))] md:w-[min(1120px,calc(100%-64px))]">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-[#ffd166]">Programa</p>
      <h2 class="mt-4 text-3xl font-black text-white sm:text-5xl">Una noche construida por capas.</h2>
    </div>
    <div class="mt-10 grid gap-4">
      {
        items.map((item) => (
          <article class="grid gap-4 rounded-lg border border-white/12 bg-white/7 p-5 shadow-2xl backdrop-blur-xl sm:grid-cols-[140px_1fr] sm:p-6">
            <div class="text-lg font-black text-[#ffd166]">{item.time}</div>
            <div>
              <h3 class="text-xl font-bold text-white">{item.title}</h3>
              <p class="mt-2 leading-7 text-[#a8a4b2]">{item.description}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
