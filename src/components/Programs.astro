---
import type { ProgramItem } from "@/data/events";

interface Props {
  items: ProgramItem[];
}

const { items } = Astro.props;
---

<section id="programas" class="py-20 sm:py-28">
  <div class="section-shell">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-prism-gold">Programa</p>
      <h2 class="mt-4 text-3xl font-black text-white sm:text-5xl">Una noche construida por capas.</h2>
    </div>
    <div class="mt-10 grid gap-4">
      {
        items.map((item) => (
          <article class="glass-panel grid gap-4 rounded-lg p-5 sm:grid-cols-[140px_1fr] sm:p-6">
            <div class="text-lg font-black text-prism-gold">{item.time}</div>
            <div>
              <h3 class="text-xl font-bold text-white">{item.title}</h3>
              <p class="mt-2 leading-7 text-farecoh-muted">{item.description}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
