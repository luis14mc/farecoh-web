---
import type { Lang } from "@/i18n/types";
import { getDictionary } from "@/i18n";
import { getLocalizedPath } from "@/i18n/routes";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const h = getDictionary(lang).home;
---

<section class="prism-section pt-12 md:pt-16">
  <div class="prism-container grid items-end gap-12 lg:grid-cols-[1fr_1.05fr] lg:gap-16">
    <div>
      <p class="subheader text-[var(--prism-outline)]">{h.eyebrow}</p>
      <h1 class="display mt-8 text-[var(--prism-text)]">{h.title}</h1>
      <p class="bilingual-subtext mt-4">{h.bilingualSubtext}</p>
      <p class="body-lg mt-8 max-w-xl text-[var(--prism-text-secondary)]">{h.intro}</p>
      <div class="mt-10 flex flex-col gap-4 sm:flex-row">
        <a class="btn-prism-primary" href={getLocalizedPath(lang, "programs")}>{h.ctaPrograms}</a>
        <a class="btn-prism-secondary" href={getLocalizedPath(lang, "donate")}>{h.ctaDonate}</a>
      </div>
    </div>
    <figure class="editorial-image">
      <img src="/images/farecoh-welcome.webp" alt={h.heroImageAlt} width="1920" height="1080" loading="eager" />
      <figcaption class="body-md mt-4 text-[var(--prism-outline)]">{h.heroCaption}</figcaption>
    </figure>
  </div>
</section>
