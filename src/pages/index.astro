---
import PublicLayout from "@/layouts/PublicLayout.astro";
import Hero from "@/components/Hero.astro";
import About from "@/components/About.astro";
import Programs from "@/components/Programs.astro";
import DonationCTA from "@/components/DonationCTA.astro";
import Footer from "@/components/Footer.astro";
import { events } from "@/data/events";

const featuredEvent = events[0];
const featuredEventHref = `/eventos/${featuredEvent.slug}`;
---

<PublicLayout
  title="FARECOH Events Platform"
  description="Plataforma pública de eventos FARECOH con experiencias culturales premium, boletos y acceso por QR."
>
  <Hero eventHref={featuredEventHref} />
  <About />
  <Programs items={featuredEvent.programs} />
  <DonationCTA text={featuredEvent.donationGoal} href={featuredEventHref} />
  <Footer eventHref={featuredEventHref} />
</PublicLayout>
