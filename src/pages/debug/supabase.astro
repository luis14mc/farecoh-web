---
import "../../styles/global.css";
import { SITE_LANG } from "@/lib/locale";

const serverUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const serverAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

function maskKey(key: string | undefined): string {
  if (!key) return "no detectada";
  if (key.length <= 12) return key;
  return `${key.substring(0, 8)}...${key.substring(key.length - 4)}`;
}

const maskedUrl = maskKey(serverUrl);
const maskedAnonKey = maskKey(serverAnonKey);
const hasKeys = !!serverUrl && !!serverAnonKey;
---

<!doctype html>
<html lang={SITE_LANG} class="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>Debug Supabase Connection | FARECOH</title>
  </head>
  <body class="min-h-screen bg-surface text-on-surface font-body-md text-body-md p-6">
    <main class="max-w-2xl mx-auto mt-10">
      <div class="rounded-lg border border-outline-variant bg-surface-container-lowest p-6 shadow-sm">
        <h1 class="text-headline-md font-headline-md text-on-surface">Supabase Debug Panel (Client-Side)</h1>
        <p class="mt-2 text-body-md text-on-surface-variant">Pruebas de conectividad y variables de entorno de Supabase desde el navegador.</p>
        
        {!hasKeys && (
          <div class="mt-4 rounded bg-red-100 p-4 text-red-800">
            <h3 class="font-bold">Error de Configuración (Servidor)</h3>
            <p class="text-body-md mt-1">Las variables de entorno PUBLIC_SUPABASE_URL o PUBLIC_SUPABASE_ANON_KEY no están definidas en el servidor.</p>
          </div>
        )}

        <div class="mt-6 space-y-4">
          <div class="p-4 rounded border border-outline-variant bg-surface">
            <h2 class="font-bold text-title-md">1. Variables en Servidor (Render-Time)</h2>
            <ul class="mt-2 space-y-1">
              <li><strong>PUBLIC_SUPABASE_URL:</strong> <span class={serverUrl ? "text-green-700 font-mono" : "text-red-700 font-bold"}>{maskedUrl}</span></li>
              <li><strong>PUBLIC_SUPABASE_ANON_KEY:</strong> <span class={serverAnonKey ? "text-green-700 font-mono" : "text-red-700 font-bold"}>{maskedAnonKey}</span></li>
            </ul>
          </div>

          <div class="p-4 rounded border border-outline-variant bg-surface">
            <h2 class="font-bold text-title-md">2. Conexión Frontend (Client-Side)</h2>
            <ul class="mt-2 space-y-2">
              <li class="flex items-center justify-between">
                <span>PUBLIC_SUPABASE_URL detectada:</span>
                <span id="client-url-status" class="px-2 py-1 rounded text-caption font-bold bg-outline-variant text-on-surface">Cargando...</span>
              </li>
              <li class="flex items-center justify-between">
                <span>PUBLIC_SUPABASE_ANON_KEY detectada:</span>
                <span id="client-key-status" class="px-2 py-1 rounded text-caption font-bold bg-outline-variant text-on-surface">Cargando...</span>
              </li>
              <li class="flex items-center justify-between">
                <span>Supabase client inicializado:</span>
                <span id="client-init-status" class="px-2 py-1 rounded text-caption font-bold bg-outline-variant text-on-surface">Cargando...</span>
              </li>
              <li class="flex items-center justify-between">
                <span>Auth session existente:</span>
                <span id="client-session-status" class="px-2 py-1 rounded text-caption font-bold bg-outline-variant text-on-surface">Cargando...</span>
              </li>
              <li class="border-t border-outline-variant pt-2">
                <span class="block font-bold mb-1">Consulta de prueba a `staff_profiles`:</span>
                <div id="client-query-status" class="p-3 rounded bg-surface-container-high font-mono text-caption overflow-x-auto whitespace-pre">Cargando consulta...</div>
              </li>
            </ul>
          </div>
        </div>

        <div class="mt-6 flex gap-4">
          <a href="/admin/login" class="rounded bg-primary px-4 py-2 text-label-md font-bold text-on-primary hover:bg-secondary">Ir a Login Administrativo</a>
          <button id="retry-btn" class="rounded border border-outline-variant px-4 py-2 text-label-md font-bold text-on-surface hover:bg-surface-container-high">Reintentar</button>
        </div>
      </div>
    </main>

    <script>
      import { supabase } from "@/lib/supabase";

      async function testSupabase() {
        const urlStatusEl = document.getElementById("client-url-status");
        const keyStatusEl = document.getElementById("client-key-status");
        const initStatusEl = document.getElementById("client-init-status");
        const sessionStatusEl = document.getElementById("client-session-status");
        const queryStatusEl = document.getElementById("client-query-status");

        // Helper to set element status class
        function setStatus(el, success, text) {
          if (!el) return;
          el.textContent = text;
          el.className = `px-2 py-1 rounded text-caption font-bold ${success ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800"}`;
        }

        // Mask function inside script
        function mask(key) {
          if (!key) return "no";
          if (key.length <= 12) return key;
          return `${key.substring(0, 8)}...${key.substring(key.length - 4)}`;
        }

        // 1. Detect client variables
        const clientUrl = import.meta.env.PUBLIC_SUPABASE_URL;
        const clientKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

        setStatus(urlStatusEl, !!clientUrl, clientUrl ? `SÍ (${mask(clientUrl)})` : "NO");
        setStatus(keyStatusEl, !!clientKey, clientKey ? `SÍ (${mask(clientKey)})` : "NO");

        if (!clientUrl || !clientKey) {
          setStatus(initStatusEl, false, "NO (Faltan variables)");
          setStatus(sessionStatusEl, false, "NO");
          queryStatusEl.textContent = "Error: Faltan PUBLIC_SUPABASE_URL o PUBLIC_SUPABASE_ANON_KEY para inicializar el cliente.";
          queryStatusEl.className = "p-3 rounded bg-red-100 text-red-800 font-mono text-caption";
          return;
        }

        try {
          if (supabase) {
            setStatus(initStatusEl, true, "SÍ");
          } else {
            setStatus(initStatusEl, false, "NO (No inicializado)");
            return;
          }

          // 4. Session check
          const { data: { session }, error: sessionError } = await supabase.auth.getSession();
          if (sessionError) {
            setStatus(sessionStatusEl, false, `ERROR: ${sessionError.message}`);
          } else {
            setStatus(sessionStatusEl, true, session ? "SÍ (Conectado)" : "NO (Sesión vacía)");
          }

          // 5. Test query to staff_profiles
          const { data, error } = await supabase
            .from("staff_profiles")
            .select("id, role")
            .limit(1);

          if (error) {
            queryStatusEl.textContent = `Error en consulta:\nCode: ${error.code}\nMessage: ${error.message}\nDetails: ${error.details || 'ninguno'}`;
            queryStatusEl.className = "p-3 rounded bg-red-100 text-red-800 font-mono text-caption";
          } else {
            queryStatusEl.textContent = `ÉXITO (success):\n${JSON.stringify(data, null, 2)}`;
            queryStatusEl.className = "p-3 rounded bg-green-100 text-green-800 font-mono text-caption";
          }

        } catch (err) {
          setStatus(initStatusEl, false, "ERROR");
          setStatus(sessionStatusEl, false, "ERROR");
          queryStatusEl.textContent = `Error crítico en ejecución:\n${err.message || err}`;
          queryStatusEl.className = "p-3 rounded bg-red-100 text-red-800 font-mono text-caption";
        }
      }

      // Initial run
      testSupabase();

      // Retry btn
      document.getElementById("retry-btn")?.addEventListener("click", () => {
        const queryStatusEl = document.getElementById("client-query-status");
        if (queryStatusEl) queryStatusEl.textContent = "Reintentando...";
        testSupabase();
      });
    </script>
  </body>
</html>
