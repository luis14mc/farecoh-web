---
import Layout from "@/layouts/Layout.astro";
import { getPinkFloydEventFallback } from "@/lib/events";
import {
  getPublicTicketStatusBadgeClass,
  getPublicTicketStatusLabel,
  getPublicTicketStatusMessage,
} from "@/lib/public-ticket-status";
import { seoPages } from "@/data/seo";
import { site } from "@/data/site";
import { supabase } from "@/lib/supabase";

const token = (Astro.params.token ?? "").trim();
const pinkFloyd = getPinkFloydEventFallback();
const eventPath = "/eventos/pink-floyd";

const { data, error } = await supabase.rpc("get_public_ticket_status", { p_qr_token: token });
const ticket = !error && Array.isArray(data) ? data[0] : null;

const notFound = !ticket;
const eventName = ticket?.event_slug === "pink-floyd" ? pinkFloyd.name : pinkFloyd.name;
const status = ticket?.status ?? "";
const statusLabel = ticket ? getPublicTicketStatusLabel(status) : "";
const statusMessage = ticket ? getPublicTicketStatusMessage(status) : "Boleto no encontrado.";
const badgeClass = ticket ? getPublicTicketStatusBadgeClass(status) : "border-red-400/40 bg-red-500/15 text-red-100";
---

<Layout
  title={seoPages.ticketLookup.title}
  description={seoPages.ticketLookup.description}
  noindex={true}
  variant="concert"
>
  <main class="min-h-[calc(100dvh-5rem)] px-margin py-10 md:py-16">
    <section class="mx-auto max-w-lg">
      <div class="mb-8 text-center">
        <p class="text-label-md font-label-md font-bold uppercase tracking-[0.2em] text-concert-amber">FARECOH Ticketing</p>
        <h1 class="mt-2 text-headline-md font-headline-md text-white">{site.name}</h1>
        <p class="mt-1 text-body-sm text-white/70">Consulta de boleto</p>
      </div>

      <div class="overflow-hidden rounded-xl border border-concert-orange/25 bg-concert-elevated/90 shadow-[0_0_40px_rgba(255,77,0,0.12)]">
        <div class="border-b border-concert-orange/20 bg-gradient-to-r from-concert-orange/20 to-concert-amber/10 px-5 py-4">
          <p class="text-label-sm font-label-sm uppercase tracking-wider text-concert-amber/90">Evento</p>
          <h2 class="mt-1 text-title-lg font-title-lg text-white">{notFound ? "—" : eventName}</h2>
        </div>

        <div class="space-y-5 p-5">
          {
            notFound ? (
              <div class={`rounded-lg border px-4 py-5 text-center ${badgeClass}`}>
                <p class="text-title-md font-title-md font-semibold">No encontrado</p>
                <p class="mt-2 text-body-md">{statusMessage}</p>
              </div>
            ) : (
              <>
                <div class="text-center">
                  <p class="text-label-sm font-label-sm uppercase tracking-wider text-white/60">Código del boleto</p>
                  <p class="mt-1 font-mono text-2xl font-bold tracking-wide text-concert-amber">{ticket.ticket_code}</p>
                </div>

                <div class={`rounded-lg border px-4 py-5 text-center ${badgeClass}`}>
                  <p class="text-label-md font-label-md font-bold uppercase tracking-wider">{statusLabel}</p>
                  <p class="mt-2 text-body-md">{statusMessage}</p>
                </div>

                <p class="text-center text-body-sm text-white/60">
                  Esta consulta no valida el ingreso. La validación se realiza en el control de acceso del evento.
                </p>
              </>
            )
          }

          <a
            href={eventPath}
            class="inline-flex w-full items-center justify-center rounded-lg bg-gradient-to-r from-concert-orange to-concert-orange-mid px-4 py-3 text-label-md font-label-md font-bold text-white transition hover:from-concert-orange-mid hover:to-concert-amber"
          >
            Volver al evento
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
