---
import Layout from "../../layouts/Layout.astro";
import EventHero from "@/components/event/EventHero.astro";
import EventInfo from "@/components/event/EventInfo.astro";
import ArtistLineup from "@/components/event/ArtistLineup.astro";
import EventCTA from "@/components/event/EventCTA.astro";
import { getEvent } from "../../lib/supabase";
import { eventPage } from "@/data/event-page";

const event = await getEvent();
---

<Layout
  title={`${event.name} | FARECOH`}
  description={eventPage.hero.body}
  active="events"
  variant="concert"
>
  <EventHero
    name={event.name}
    tagline={eventPage.hero.tagline}
    venue={event.venue}
    city={event.city}
    date="29 de agosto de 2026"
    time={event.time}
    price={event.ticket_price}
  />

  <EventInfo />
  <ArtistLineup />
  <EventCTA price={event.ticket_price} />
</Layout>

<script>
  import { initParallax } from "@/scripts/parallax";

  initParallax();
</script>

<script is:inline>
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!prefersReducedMotion) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        });
      },
      { threshold: 0.08, rootMargin: "0px 0px -40px 0px" }
    );

    document.querySelectorAll(".reveal-section").forEach((section, index) => {
      section.style.setProperty("--reveal-delay", `${Math.min(index * 80, 320)}ms`);
      observer.observe(section);
    });
  } else {
    document.querySelectorAll(".reveal-section").forEach((section) => {
      section.classList.add("is-visible");
    });
  }
</script>
