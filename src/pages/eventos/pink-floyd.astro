---
import Layout from "../../layouts/Layout.astro";
import EventHero from "@/components/event/EventHero.astro";
import EventInfo from "@/components/event/EventInfo.astro";
import ArtistLineup from "@/components/event/ArtistLineup.astro";
import EventCTA from "@/components/event/EventCTA.astro";
import { getPinkFloydEvent, formatEventCompactDate } from "@/lib/events";
import { seoPages, musicEventJsonLd, breadcrumbJsonLd } from "@/data/seo";
import { formatSiteCurrency } from "@/lib/locale";

const event = await getPinkFloydEvent();

const compactDate = formatEventCompactDate(event.date);
const formattedPrice = formatSiteCurrency(event.ticket_price);
---

<Layout
  title={seoPages.event.title}
  description={seoPages.event.description}
  image={seoPages.event.image}
  canonicalPath={seoPages.event.path}
  ogType="website"
  active="events"
  variant="concert"
  jsonLd={[
    musicEventJsonLd(event),
    breadcrumbJsonLd([
      { name: "Inicio", path: "/" },
      { name: event.name, path: seoPages.event.path },
    ]),
  ]}
>
  <EventHero
    name={event.name}
    venue={event.venue}
    date={compactDate}
    time={event.time}
    price={formattedPrice}
  />

  <EventInfo />
  <ArtistLineup />
  <EventCTA price={formattedPrice} />
</Layout>

<script>
  import { initParallax } from "@/scripts/parallax";

  initParallax();
</script>

<script is:inline>
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!prefersReducedMotion) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        });
      },
      { threshold: 0.08, rootMargin: "0px 0px -40px 0px" },
    );

    document.querySelectorAll(".reveal-section").forEach((section, index) => {
      section.style.setProperty("--reveal-delay", `${Math.min(index * 80, 320)}ms`);
      observer.observe(section);
    });
  } else {
    document.querySelectorAll(".reveal-section").forEach((section) => {
      section.classList.add("is-visible");
    });
  }
</script>
