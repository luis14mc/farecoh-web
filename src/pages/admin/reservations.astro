---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AdminPage from "@/components/admin/ui/AdminPage.astro";
import { AdminPageHeader } from "@/components/admin/react/AdminPageHeader";
import { ReservationsPanel } from "@/components/admin/react/ReservationsPanel";
import { createSupabaseServerClient, getPublicSupabaseConfig, isAuthConfigured, type UserProfile } from "@/lib/auth";
import { formatSiteDate } from "@/lib/locale";
import { confirmTicketPayment } from "@/services/ticket-payment";
import { cancelTicketReservation } from "@/services/ticket-reservation";
import { getSiteStartOfTodayIso } from "@/services/reservation-stats";
import { loadConvertedReservationsToday, loadReservedTickets } from "@/services/reservation-queries";

const supabase = createSupabaseServerClient(Astro);
const staffProfile = Astro.locals.staffProfile as UserProfile | undefined;
const authConfigured = isAuthConfigured(getPublicSupabaseConfig());
const currentDate = formatSiteDate(new Date(), { month: "short", day: "numeric", year: "numeric" });

let formMessage = "";
let formError = false;
let cancelMessage = "";
let cancelError = false;
let pageError = "";
let migrationWarning = "";

function normalizeTicketCode(ticketCode: string): string {
  return ticketCode.trim().toUpperCase();
}

if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const action = String(data.get("action") || "");

  if (action === "confirm_payment") {
    try {
      const ticketCode = normalizeTicketCode(String(data.get("code") || ""));
      const buyerName = String(data.get("buyer_name") || "").trim();
      const buyerPhone = String(data.get("buyer_phone") || "").trim();
      const buyerEmail = String(data.get("buyer_email") || "").trim().toLowerCase() || "";
      const sellerId = String(data.get("seller_id") || "");
      const saleLocation = String(data.get("sale_location") || "").trim();
      const paymentMethod = String(data.get("payment_method") || "");
      const paymentReference = String(data.get("payment_reference") || "").trim() || undefined;

      if (!ticketCode || !sellerId || !saleLocation || !paymentMethod) {
        throw new Error("Complete todos los campos obligatorios.");
      }

      const result = await confirmTicketPayment(supabase, {
        ticket_code: ticketCode,
        buyer_name: buyerName,
        buyer_phone: buyerPhone,
        buyer_email: buyerEmail,
        seller_id: sellerId,
        sale_location: saleLocation,
        payment_method: paymentMethod,
        payment_reference: paymentReference,
        confirmed_by: staffProfile?.email ?? staffProfile?.full_name ?? "admin-reservations",
      });

      if (!result.ok || !result.ticket) {
        throw new Error(result.message);
      }

      formMessage = result.message;
    } catch (err: unknown) {
      formError = true;
      formMessage = err instanceof Error ? err.message : "Error al confirmar el pago.";
    }
  }

  if (action === "cancel_reservation") {
    try {
      const ticketCode = normalizeTicketCode(String(data.get("ticket_code") || ""));
      const reason = String(data.get("reason") || "").trim();

      if (!ticketCode || !reason) {
        throw new Error("Indique el boleto y el motivo de cancelación.");
      }

      const result = await cancelTicketReservation(supabase, {
        ticket_code: ticketCode,
        cancelled_by: staffProfile?.email ?? staffProfile?.full_name ?? "admin-reservations",
        reason,
      });

      if (!result.ok) {
        throw new Error(result.message);
      }

      cancelMessage = `Reserva ${result.ticket_code} cancelada. El boleto volvió a disponible.`;
    } catch (err: unknown) {
      cancelError = true;
      cancelMessage = err instanceof Error ? err.message : "Error al cancelar la reserva.";
    }
  }
}

let reservations: Awaited<ReturnType<typeof loadReservedTickets>>["rows"] = [];
let sellers: { id: string; name: string; type: string }[] = [];
let convertedToSoldToday = 0;

try {
  const loaded = await loadReservedTickets(supabase);
  reservations = loaded.rows;
  migrationWarning = loaded.warning ?? "";

  const sellersResult = await supabase
    .from("sellers")
    .select("id, name, type")
    .eq("active", true)
    .order("name", { ascending: true });

  if (sellersResult.error) {
    throw new Error(sellersResult.error.message);
  }

  sellers = sellersResult.data ?? [];
  convertedToSoldToday = await loadConvertedReservationsToday(supabase, getSiteStartOfTodayIso());
} catch (err: unknown) {
  pageError = err instanceof Error ? err.message : "No se pudieron cargar las reservas.";
}
---

<AdminLayout title="Reservas | FARECOH" description="Seguimiento de reservas pendientes de pago" active="reservations">
  <AdminPageHeader
    client:load
    title="Reservas"
    section="Operaciones"
    description="Gestione reservas web: confirme pagos, contacte compradores o libere boletos."
    currentDate={currentDate}
    staffProfile={staffProfile}
    authConfigured={authConfigured}
  />

  <AdminPage>
    {pageError && (
      <div class="rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-800" role="alert">
        Error al cargar reservas: {pageError}
      </div>
    )}

    {migrationWarning && (
      <div class="rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900" role="status">
        {migrationWarning}
      </div>
    )}

    {!pageError && (
      <ReservationsPanel
        client:load
        reservations={reservations}
        sellers={sellers}
        convertedToSoldToday={convertedToSoldToday}
        formMessage={formMessage || undefined}
        formError={formError}
        cancelMessage={cancelMessage || undefined}
        cancelError={cancelError}
      />
    )}
  </AdminPage>
</AdminLayout>
