---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AdminPage from "@/components/admin/ui/AdminPage.astro";
import { AdminPageHeader } from "@/components/admin/react/AdminPageHeader";
import { TicketsInventoryTable } from "@/components/admin/react/TicketsInventoryTable";
import { supabase } from "@/lib/supabase";
import { getPublicSupabaseConfig, isAuthConfigured, type UserProfile } from "@/lib/auth";
import { formatSiteDate } from "@/lib/locale";

const staffProfile = Astro.locals.staffProfile as UserProfile | undefined;
const authConfigured = isAuthConfigured(getPublicSupabaseConfig());
const currentDate = formatSiteDate(new Date(), { month: "short", day: "numeric", year: "numeric" });

const { data: tickets = [] } = await supabase
  .from("tickets")
  .select("ticket_code, qr_token, status, buyer_name, buyer_phone, seller_name, sale_location, sold_at, validated_at")
  .order("ticket_code", { ascending: true });

const sellers = Array.from(new Set(tickets.map((t) => t.seller_name).filter(Boolean))) as string[];
const locations = Array.from(new Set(tickets.map((t) => t.sale_location).filter(Boolean))) as string[];
---

<AdminLayout title="Boletos | FARECOH" description="Administración de boletos físicos" active="tickets">
  <AdminPageHeader
    client:load
    title="Boletos"
    section="Inventario"
    description="Consulte, filtre y gestione el estado de los 500 boletos del evento."
    currentDate={currentDate}
    staffProfile={staffProfile}
    authConfigured={authConfigured}
  />

  <AdminPage mobileFab>
    <TicketsInventoryTable client:load tickets={tickets} sellers={sellers} locations={locations} />
  </AdminPage>
</AdminLayout>
