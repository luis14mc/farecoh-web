---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { AdminPageHeader } from "@/components/admin/react/AdminPageHeader";
import { ReportsAdminPanel } from "@/components/admin/react/ReportsAdminPanel";
import { createSupabaseServerClient, getPublicSupabaseConfig, isAuthConfigured, type UserProfile } from "@/lib/auth";
import { getPinkFloydEvent } from "@/lib/events";
import { formatSiteCurrency, formatSiteDate, formatSiteNumber } from "@/lib/locale";
import { calculateAdminReportMetrics } from "@/services/admin-stats";
import { calculateSellerReports } from "@/services/seller-stats";

const supabase = createSupabaseServerClient(Astro);
const staffProfile = Astro.locals.staffProfile as UserProfile | undefined;
const authConfigured = isAuthConfigured(getPublicSupabaseConfig());
const currentDate = formatSiteDate(new Date(), { month: "short", day: "numeric", year: "numeric" });

const event = await getPinkFloydEvent();
const ticketPrice = event.ticket_price;

const { data: tickets = [] } = await supabase.from("tickets").select("status, seller_id, seller_name, validated_at");
const { data: sellers = [] } = await supabase.from("sellers").select("*");
const { data: sales = [] } = await supabase.from("sales").select("amount");

const metricsData = calculateAdminReportMetrics({
  capacity: event.total_tickets,
  ticketPrice,
  tickets: tickets.map((t) => ({ status: t.status, validated_at: t.validated_at })),
});

const grossRevenue = sales.reduce((sum, row) => sum + Number(row.amount), 0);

const sellerReports = calculateSellerReports({
  ticketPrice,
  sellers: sellers ?? [],
  tickets: tickets.map((t) => ({
    seller_id: t.seller_id,
    seller_name: t.seller_name,
    status: t.status,
  })),
});

const metrics = [
  { label: "Boletos vendidos", value: formatSiteNumber(metricsData.ticketsSold) },
  { label: "Boletos validados", value: formatSiteNumber(metricsData.ticketsValidated) },
  { label: "Recaudación bruta", value: formatSiteCurrency(grossRevenue) },
];

const reportRows = sellerReports
  .filter((row) => row.ticketsSold > 0)
  .map((row) => ({
    sellerName: row.sellerName,
    type: row.sellerType,
    salesCount: row.salesCount,
    ticketsSold: row.ticketsSold,
    revenue: row.revenue,
  }));
---

<AdminLayout title="Reportes | FARECOH" description="Reportes administrativos de ventas, boletos y check-in" active="reports">
  <AdminPageHeader
    client:load
    title="Reportes"
    section="Análisis"
    description="Exportaciones y métricas por vendedor."
    currentDate={currentDate}
    staffProfile={staffProfile}
    authConfigured={authConfigured}
  />

  <div class="mx-auto w-full max-w-7xl space-y-6 px-4 py-6 pb-24 md:px-8 md:py-8 md:pb-8">
    <ReportsAdminPanel client:load eventName={event.name} metrics={metrics} reportRows={reportRows} />
  </div>
</AdminLayout>
