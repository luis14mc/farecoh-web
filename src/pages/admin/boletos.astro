---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AdminHeader from "@/components/admin/AdminHeader.astro";
---

<AdminLayout title="Boletos | FARECOH" description="Administración de boletos físicos" active="boletos">
  <AdminHeader title="Boletos Físicos" section="Boletos" />

  <div class="px-margin py-8 space-y-stack-lg max-w-container-max pb-24 md:pb-8">
    <div class="rounded-lg border border-outline-variant bg-surface-container-lowest text-on-surface shadow-sm">
      <div class="grid grid-cols-1 gap-4 border-b border-outline-variant bg-surface-container-low p-6 md:grid-cols-4">
        <label class="block">
          <span class="text-caption font-caption font-bold uppercase text-on-surface-variant">Código</span>
          <input id="code-filter" placeholder="PF-000001" class="mt-2 w-full rounded border border-outline-variant bg-surface px-3 py-2 font-mono text-body-md outline-none focus:border-primary" />
        </label>
        <label class="block">
          <span class="text-caption font-caption font-bold uppercase text-on-surface-variant">Estado</span>
          <select id="status-filter" class="mt-2 w-full rounded border border-outline-variant bg-surface px-3 py-2 text-body-md outline-none focus:border-primary">
            <option value="all">Todos</option>
            <option value="available">Disponible</option>
            <option value="assigned">Asignado</option>
            <option value="reserved">Reservado</option>
            <option value="paid">Pagado</option>
            <option value="validated">Validado</option>
            <option value="cancelled">Anulado</option>
          </select>
        </label>
        <label class="block">
          <span class="text-caption font-caption font-bold uppercase text-on-surface-variant">Vendedor</span>
          <select id="seller-filter" class="mt-2 w-full rounded border border-outline-variant bg-surface px-3 py-2 text-body-md outline-none focus:border-primary">
            <option value="all">Todos</option>
          </select>
        </label>
        <label class="block">
          <span class="text-caption font-caption font-bold uppercase text-on-surface-variant">Punto de venta</span>
          <input id="location-filter" placeholder="Escuela Nacional de Música" class="mt-2 w-full rounded border border-outline-variant bg-surface px-3 py-2 text-body-md outline-none focus:border-primary" />
        </label>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full min-w-[980px] text-left" id="tickets-table">
          <thead class="bg-surface-container-low">
            <tr>
              <th class="px-4 py-4 text-label-md font-label-md font-bold uppercase text-on-surface-variant">Código</th>
              <th class="px-4 py-4 text-label-md font-label-md font-bold uppercase text-on-surface-variant">Estado</th>
              <th class="px-4 py-4 text-label-md font-label-md font-bold uppercase text-on-surface-variant">Comprador</th>
              <th class="px-4 py-4 text-label-md font-label-md font-bold uppercase text-on-surface-variant">Teléfono</th>
              <th class="px-4 py-4 text-label-md font-label-md font-bold uppercase text-on-surface-variant">Vendedor</th>
              <th class="px-4 py-4 text-label-md font-label-md font-bold uppercase text-on-surface-variant">Punto</th>
              <th class="px-4 py-4 text-label-md font-label-md font-bold uppercase text-on-surface-variant">Fecha venta</th>
              <th class="px-4 py-4 text-label-md font-label-md font-bold uppercase text-on-surface-variant">Acción</th>
            </tr>
          </thead>
          <tbody id="tickets-body" class="divide-y divide-outline-variant"></tbody>
        </table>
      </div>

      <div class="flex items-center justify-between border-t border-outline-variant bg-surface-container-low p-6">
        <span id="results-count" class="text-caption font-caption text-on-surface-variant">Cargando boletos...</span>
        <a href="/admin/ventas" class="rounded bg-primary px-4 py-2 text-label-md font-label-md font-bold text-on-primary hover:bg-secondary">Registrar venta</a>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  import {
    formatPhysicalDate,
    getSellers,
    getTickets,
    seedPhysicalTicketing,
  } from "@/services/physical-store";

  const statusLabel = {
    available: "Disponible",
    assigned: "Asignado",
    reserved: "Reservado",
    paid: "Pagado",
    validated: "Validado",
    cancelled: "Anulado",
  };

  const statusClass = {
    available: "bg-slate-100 text-slate-700",
    assigned: "bg-blue-100 text-blue-700",
    reserved: "bg-yellow-100 text-yellow-700",
    paid: "bg-green-100 text-green-700",
    validated: "bg-primary-container text-primary",
    cancelled: "bg-red-100 text-red-700",
  };

  const matches = (value: string | null | undefined, filter: string) =>
    String(value || "").toLowerCase().includes(String(filter || "").toLowerCase());

  function renderSellerFilter() {
    const select = document.getElementById("seller-filter") as HTMLSelectElement;
    if (!select) return;

    const sellers = getSellers();
    select.innerHTML = `<option value="all">Todos</option>${sellers.map((seller) => `<option value="${seller.id}">${seller.name}${seller.active ? "" : " (inactivo)"}</option>`).join("")}`;
  }

  function render() {
    const codeFilter = (document.getElementById("code-filter") as HTMLInputElement)?.value || "";
    const statusFilter = (document.getElementById("status-filter") as HTMLSelectElement)?.value || "all";
    const sellerFilter = (document.getElementById("seller-filter") as HTMLSelectElement)?.value || "all";
    const locationFilter = (document.getElementById("location-filter") as HTMLInputElement)?.value || "";

    const tickets = getTickets().filter((ticket) => {
      return matches(ticket.code, codeFilter)
        && (statusFilter === "all" || ticket.status === statusFilter)
        && (sellerFilter === "all" || ticket.seller_id === sellerFilter)
        && matches(ticket.sale_location, locationFilter);
    });

    const body = document.getElementById("tickets-body");
    if (body) {
      body.innerHTML = tickets.map((ticket) => `
        <tr class="hover:bg-surface-container-low">
          <td class="px-4 py-3 font-mono font-bold text-primary">${ticket.code}</td>
          <td class="px-4 py-3"><span class="inline-block rounded-full px-3 py-1 text-caption font-caption font-bold ${statusClass[ticket.status]}">${statusLabel[ticket.status]}</span></td>
          <td class="px-4 py-3 font-semibold text-on-surface">${ticket.buyer_name || "-"}</td>
          <td class="px-4 py-3 text-on-surface-variant">${ticket.buyer_phone || "-"}</td>
          <td class="px-4 py-3 text-on-surface-variant">${ticket.seller_name || "-"}</td>
          <td class="px-4 py-3 text-on-surface-variant">${ticket.sale_location || "-"}</td>
          <td class="px-4 py-3 text-on-surface-variant">${formatPhysicalDate(ticket.sold_at)}</td>
          <td class="px-4 py-3"><a class="text-primary font-bold hover:underline" href="/admin/ventas?code=${ticket.code}">Vender</a></td>
        </tr>
      `).join("");
    }

    const count = document.getElementById("results-count");
    if (count) count.textContent = `Mostrando ${tickets.length} de ${getTickets().length} boletos`;
  }

  seedPhysicalTicketing();
  renderSellerFilter();
  render();

  ["code-filter", "status-filter", "seller-filter", "location-filter"].forEach((id) => {
    document.getElementById(id)?.addEventListener("input", render);
    document.getElementById(id)?.addEventListener("change", render);
  });
</script>
