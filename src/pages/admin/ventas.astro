---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AdminHeader from "@/components/admin/AdminHeader.astro";
---

<AdminLayout title="Ventas Físicas | FARECOH" description="Registro de venta física de boletos" active="ventas">
  <AdminHeader title="Venta Física" section="Ventas" />

  <div class="px-margin py-8 max-w-container-max pb-24 md:pb-8 space-y-stack-lg">
    <section class="grid gap-gutter lg:grid-cols-3">
      <form id="sale-form" class="rounded-lg border border-outline-variant bg-surface-container-lowest p-6 shadow-sm lg:col-span-1">
        <h2 class="text-headline-sm font-headline-sm text-on-surface">Marcar boleto vendido/pagado</h2>
        <p class="mt-1 text-body-md font-body-md text-on-surface-variant">Venta presencial sin pago online.</p>

        <div class="mt-6 space-y-4">
          <label class="block">
            <span class="text-caption font-caption font-bold uppercase text-on-surface-variant">Código boleto</span>
            <input id="code-input" name="code" required placeholder="PF-000001" class="mt-2 w-full rounded border border-outline-variant bg-surface px-3 py-3 font-mono text-body-md outline-none focus:border-primary" />
          </label>
          <label class="block">
            <span class="text-caption font-caption font-bold uppercase text-on-surface-variant">Nombre comprador</span>
            <input name="buyer_name" required class="mt-2 w-full rounded border border-outline-variant bg-surface px-3 py-3 text-body-md outline-none focus:border-primary" />
          </label>
          <label class="block">
            <span class="text-caption font-caption font-bold uppercase text-on-surface-variant">Teléfono</span>
            <input name="buyer_phone" required class="mt-2 w-full rounded border border-outline-variant bg-surface px-3 py-3 text-body-md outline-none focus:border-primary" />
          </label>
          <label class="block">
            <span class="text-caption font-caption font-bold uppercase text-on-surface-variant">Correo opcional</span>
            <input name="buyer_email" type="email" class="mt-2 w-full rounded border border-outline-variant bg-surface px-3 py-3 text-body-md outline-none focus:border-primary" />
          </label>
          <label class="block">
            <span class="text-caption font-caption font-bold uppercase text-on-surface-variant">Vendedor</span>
            <select id="seller-select" name="seller_id" required class="mt-2 w-full rounded border border-outline-variant bg-surface px-3 py-3 text-body-md outline-none focus:border-primary">
              <option value="">Seleccione un vendedor</option>
            </select>
            <p class="mt-2 text-caption text-on-surface-variant">
              <a href="/admin/vendedores" class="font-bold text-primary hover:underline">Registrar vendedor</a>
            </p>
          </label>
          <label class="block">
            <span class="text-caption font-caption font-bold uppercase text-on-surface-variant">Punto de venta</span>
            <input name="sale_location" required placeholder="Escuela Nacional de Música" class="mt-2 w-full rounded border border-outline-variant bg-surface px-3 py-3 text-body-md outline-none focus:border-primary" />
          </label>
          <label class="block">
            <span class="text-caption font-caption font-bold uppercase text-on-surface-variant">Método de pago</span>
            <select name="payment_method" required class="mt-2 w-full rounded border border-outline-variant bg-surface px-3 py-3 text-body-md outline-none focus:border-primary">
              <option value="">Seleccione</option>
              <option value="Efectivo">Efectivo</option>
              <option value="Transferencia">Transferencia</option>
              <option value="POS">POS</option>
              <option value="Cortesía">Cortesía</option>
            </select>
          </label>
          <label class="block">
            <span class="text-caption font-caption font-bold uppercase text-on-surface-variant">Referencia opcional</span>
            <input name="payment_reference" class="mt-2 w-full rounded border border-outline-variant bg-surface px-3 py-3 text-body-md outline-none focus:border-primary" />
          </label>
        </div>

        <button class="mt-6 w-full rounded bg-primary px-4 py-3 text-label-md font-label-md font-bold text-on-primary transition-colors hover:bg-secondary" type="submit">
          Marcar como vendido/pagado
        </button>
        <p id="sale-message" class="mt-4 hidden rounded p-3 text-body-md font-body-md"></p>
      </form>

      <div class="space-y-stack-lg lg:col-span-2">
        <section class="rounded-lg border border-outline-variant bg-surface-container-lowest p-6 shadow-sm">
          <h3 class="text-headline-sm font-headline-sm text-on-surface">Estado del boleto</h3>
          <div id="ticket-preview" class="mt-4 rounded border border-outline-variant bg-surface p-5 text-body-md text-on-surface-variant">Ingrese un código para consultar.</div>
        </section>

        <section class="rounded-lg border border-outline-variant bg-surface-container-lowest shadow-sm">
          <div class="border-b border-outline-variant p-6">
            <h3 class="text-headline-sm font-headline-sm text-on-surface">Últimas ventas físicas</h3>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full min-w-[760px] text-left">
              <thead class="bg-surface-container-low">
                <tr>
                  <th class="px-4 py-3 text-label-md font-label-md font-bold uppercase text-on-surface-variant">Código</th>
                  <th class="px-4 py-3 text-label-md font-label-md font-bold uppercase text-on-surface-variant">Comprador</th>
                  <th class="px-4 py-3 text-label-md font-label-md font-bold uppercase text-on-surface-variant">Vendedor</th>
                  <th class="px-4 py-3 text-label-md font-label-md font-bold uppercase text-on-surface-variant">Punto</th>
                  <th class="px-4 py-3 text-label-md font-label-md font-bold uppercase text-on-surface-variant">Fecha</th>
                </tr>
              </thead>
              <tbody id="recent-sales" class="divide-y divide-outline-variant"></tbody>
            </table>
          </div>
        </section>
      </div>
    </section>
  </div>
</AdminLayout>

<script>
  import {
    formatPhysicalDate,
    getActiveSellers,
    getSellerById,
    getTickets,
    isTicketCode,
    normalizeTicketCode,
    PHYSICAL_STATUS_LABELS,
    seedPhysicalTicketing,
    setTickets,
  } from "@/services/physical-store";
  import { SELLER_TYPE_LABELS } from "@/types/sellers";

  function showMessage(text: string, type: "success" | "error" = "success") {
    const node = document.getElementById("sale-message");
    if (!node) return;
    node.textContent = text;
    node.className = `mt-4 rounded p-3 text-body-md font-body-md ${type === "error" ? "bg-red-100 text-red-700" : "bg-green-100 text-green-700"}`;
  }

  function renderSellerOptions() {
    const select = document.getElementById("seller-select") as HTMLSelectElement;
    if (!select) return;

    const sellers = getActiveSellers();
    select.innerHTML = `<option value="">Seleccione un vendedor</option>${sellers.map((seller) => `<option value="${seller.id}">${seller.name} (${SELLER_TYPE_LABELS[seller.type]})</option>`).join("")}`;

    if (!sellers.length) {
      showMessage("No hay vendedores activos. Registre uno en Vendedores.", "error");
    }
  }

  function findTicket(ticketCode: string) {
    return getTickets().find((ticket) => ticket.code === normalizeTicketCode(ticketCode));
  }

  function renderPreview() {
    const input = document.getElementById("code-input") as HTMLInputElement;
    const preview = document.getElementById("ticket-preview");
    if (!input || !preview) return;

    const ticketCode = normalizeTicketCode(input.value);
    if (!ticketCode) {
      preview.innerHTML = "Ingrese un código para consultar.";
      return;
    }
    if (!isTicketCode(ticketCode)) {
      preview.innerHTML = `<span class="text-red-700 font-bold">Formato inválido. Use PF-000001.</span>`;
      return;
    }

    const ticket = findTicket(ticketCode);
    if (!ticket) {
      preview.innerHTML = `<span class="text-red-700 font-bold">Boleto inexistente.</span>`;
      return;
    }

    preview.innerHTML = `<div class="grid gap-2 sm:grid-cols-2"><p><strong>Código:</strong> ${ticket.code}</p><p><strong>Estado:</strong> ${PHYSICAL_STATUS_LABELS[ticket.status]}</p><p><strong>Vendedor:</strong> ${ticket.seller_name || "-"}</p><p><strong>Punto:</strong> ${ticket.sale_location || "-"}</p><p><strong>Comprador:</strong> ${ticket.buyer_name || "-"}</p><p><strong>Vendido:</strong> ${formatPhysicalDate(ticket.sold_at)}</p></div>`;
  }

  function renderRecentSales() {
    const body = document.getElementById("recent-sales");
    if (!body) return;

    const sales = getTickets()
      .filter((ticket) => ticket.status === "paid" || ticket.status === "validated")
      .sort((a, b) => String(b.sold_at).localeCompare(String(a.sold_at)))
      .slice(0, 12);

    body.innerHTML = sales.length
      ? sales.map((ticket) => `<tr><td class="px-4 py-3 font-mono font-bold text-primary">${ticket.code}</td><td class="px-4 py-3">${ticket.buyer_name || "-"}</td><td class="px-4 py-3">${ticket.seller_name || "-"}</td><td class="px-4 py-3">${ticket.sale_location || "-"}</td><td class="px-4 py-3">${formatPhysicalDate(ticket.sold_at)}</td></tr>`).join("")
      : `<tr><td colspan="5" class="px-4 py-8 text-center text-on-surface-variant">No hay ventas registradas.</td></tr>`;
  }

  seedPhysicalTicketing();
  renderSellerOptions();

  const initialCode = new URLSearchParams(window.location.search).get("code");
  if (initialCode) {
    const codeInput = document.getElementById("code-input") as HTMLInputElement;
    if (codeInput) codeInput.value = normalizeTicketCode(initialCode);
  }

  renderPreview();
  renderRecentSales();

  document.getElementById("code-input")?.addEventListener("input", renderPreview);

  document.getElementById("sale-form")?.addEventListener("submit", (event) => {
    event.preventDefault();
    const form = new FormData(event.currentTarget as HTMLFormElement);
    const ticketCode = normalizeTicketCode(String(form.get("code") || ""));
    const sellerId = String(form.get("seller_id") || "");
    const seller = getSellerById(sellerId);

    if (!seller || !seller.active) {
      showMessage("Seleccione un vendedor registrado y activo.", "error");
      return;
    }

    const tickets = getTickets();
    const index = tickets.findIndex((ticket) => ticket.code === ticketCode);

    if (index === -1) return showMessage("No se puede vender: boleto inexistente.", "error");

    const ticket = tickets[index];
    if (ticket.status === "cancelled") return showMessage("No se puede vender: boleto anulado.", "error");
    if (ticket.status === "validated") return showMessage("No se puede vender: boleto ya utilizado/validado.", "error");
    if (ticket.status === "paid") return showMessage("Este boleto ya está vendido/pagado.", "error");
    if (!["available", "assigned", "reserved"].includes(ticket.status)) return showMessage("Estado no permitido para venta.", "error");

    tickets[index] = {
      ...ticket,
      status: "paid",
      buyer_name: String(form.get("buyer_name") || "").trim(),
      buyer_phone: String(form.get("buyer_phone") || "").trim(),
      buyer_email: String(form.get("buyer_email") || "").trim() || null,
      seller_id: seller.id,
      seller_name: seller.name,
      sale_location: String(form.get("sale_location") || "").trim(),
      payment_method: String(form.get("payment_method") || "").trim(),
      payment_reference: String(form.get("payment_reference") || "").trim() || null,
      sold_at: new Date().toISOString(),
    };

    setTickets(tickets);
    showMessage(`${ticketCode} marcado como vendido/pagado.`);
    renderPreview();
    renderRecentSales();
  });
</script>
