---
import "../../styles/global.css";
import { getPublicSupabaseConfig, isAuthConfigured } from "@/lib/auth";
import { SITE_LANG } from "@/lib/locale";

const { supabaseUrl, supabaseAnonKey } = getPublicSupabaseConfig();
const authConfigured = isAuthConfigured({ supabaseUrl, supabaseAnonKey });
const authError = Astro.url.searchParams.get("error");

// Guard: immediately redirect to /admin/login without preserving query params if URL contains password or email query params
const emailParam = Astro.url.searchParams.get("email");
const passwordParam = Astro.url.searchParams.get("password");
if (emailParam || passwordParam) {
  return Astro.redirect("/admin/login");
}
---

<!doctype html>
<html lang={SITE_LANG} class="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Acceso Administrativo | FARECOH</title>
  </head>
  <body class="min-h-screen bg-surface text-on-surface font-body-md text-body-md" data-supabase-url={supabaseUrl} data-supabase-anon-key={supabaseAnonKey} data-auth-configured={authConfigured ? "true" : "false"}>
    <main class="flex min-h-screen items-center justify-center px-margin py-12">
      <section class="w-full max-w-md rounded-lg border border-outline-variant bg-surface-container-lowest p-6 shadow-sm">
        <p class="text-label-md font-label-md font-bold uppercase tracking-wider text-primary">Panel administrativo</p>
        <h1 class="mt-2 text-headline-md font-headline-md text-on-surface">Iniciar sesión</h1>
        <p class="mt-2 text-body-md font-body-md text-on-surface-variant">Use su cuenta autorizada de FARECOH.</p>

        {!authConfigured && (
          <p class="mt-4 rounded bg-yellow-100 p-3 text-body-md text-yellow-800">
            Supabase Auth no está configurado. Defina PUBLIC_SUPABASE_URL y PUBLIC_SUPABASE_ANON_KEY en Vercel y vuelva a desplegar.
          </p>
        )}

        {authError && (
          <p class="mt-4 rounded bg-red-100 p-3 text-body-md text-red-700">{authError}</p>
        )}

        <form id="login-form" onsubmit="event.preventDefault();" class="mt-6 space-y-4">
          <label class="block">
            <span class="text-caption font-caption font-bold uppercase text-on-surface-variant">Correo</span>
            <input id="email" name="email" type="email" required autocomplete="email" disabled={!authConfigured} class="mt-2 w-full rounded border border-outline-variant bg-surface px-3 py-3 text-body-md outline-none focus:border-primary disabled:cursor-not-allowed disabled:opacity-60" />
          </label>
          <label class="block">
            <span class="text-caption font-caption font-bold uppercase text-on-surface-variant">Contraseña</span>
            <input id="password" name="password" type="password" required autocomplete="current-password" disabled={!authConfigured} class="mt-2 w-full rounded border border-outline-variant bg-surface px-3 py-3 text-body-md outline-none focus:border-primary disabled:cursor-not-allowed disabled:opacity-60" />
          </label>
          <button id="login-button" disabled={!authConfigured} class="w-full rounded bg-primary px-4 py-3 text-label-md font-label-md font-bold text-on-primary transition-colors hover:bg-secondary disabled:cursor-not-allowed disabled:opacity-60" type="submit">
            Entrar
          </button>
          <div class="mt-4 text-center">
            <button id="toggle-recovery" class="text-caption font-bold text-primary hover:underline cursor-pointer" type="button">Olvidé mi contraseña</button>
          </div>
        </form>

        <form id="recovery-form" onsubmit="event.preventDefault();" class="mt-6 space-y-4 hidden">
          <label class="block">
            <span class="text-caption font-caption font-bold uppercase text-on-surface-variant">Correo electrónico</span>
            <input id="recovery-email" name="email" type="email" required autocomplete="email" disabled={!authConfigured} class="mt-2 w-full rounded border border-outline-variant bg-surface px-3 py-3 text-body-md outline-none focus:border-primary disabled:cursor-not-allowed disabled:opacity-60" />
          </label>
          <button id="recovery-button" disabled={!authConfigured} class="w-full rounded bg-primary px-4 py-3 text-label-md font-label-md font-bold text-on-primary transition-colors hover:bg-secondary disabled:cursor-not-allowed disabled:opacity-60" type="submit">
            Enviar correo de recuperación
          </button>
          <div class="mt-4 text-center">
            <button id="toggle-login" class="text-caption font-bold text-primary hover:underline cursor-pointer" type="button">Volver a iniciar sesión</button>
          </div>
        </form>

        <p id="login-message" class="mt-4 hidden rounded p-3 text-body-md font-body-md"></p>
      </section>
    </main>

    <script>
      import { createBrowserClient } from "@supabase/ssr";

      // Guard: immediately redirect to /admin/login without preserving query params if URL contains password or email query params
      if (window.location.search) {
        const params = new URLSearchParams(window.location.search);
        if (params.has("email") || params.has("password")) {
          window.location.href = "/admin/login";
        }
      }

      const body = document.body;
      const supabaseUrl = body.dataset.supabaseUrl || "";
      const supabaseAnonKey = body.dataset.supabaseAnonKey || "";
      const authConfigured = body.dataset.authConfigured === "true";

      const loginForm = document.getElementById("login-form");
      const loginButton = document.getElementById("login-button");
      const recoveryForm = document.getElementById("recovery-form");
      const recoveryButton = document.getElementById("recovery-button");
      const toggleRecovery = document.getElementById("toggle-recovery");
      const toggleLogin = document.getElementById("toggle-login");
      const message = document.getElementById("login-message");
      const emailInput = document.getElementById("email") as HTMLInputElement | null;
      const passwordInput = document.getElementById("password") as HTMLInputElement | null;
      const recoveryEmailInput = document.getElementById("recovery-email") as HTMLInputElement | null;
      const supabase = authConfigured ? createBrowserClient(supabaseUrl, supabaseAnonKey) : null;

      function showMessage(text: string, type = "error") {
        if (!message) return;
        message.textContent = text;
        message.className = `mt-4 rounded p-3 text-body-md font-body-md ${type === "error" ? "bg-red-100 text-red-700" : "bg-green-100 text-green-700"}`;
        message.classList.remove("hidden");
      }

      function hideMessage() {
        message?.classList.add("hidden");
      }

      toggleRecovery?.addEventListener("click", () => {
        loginForm?.classList.add("hidden");
        recoveryForm?.classList.remove("hidden");
        hideMessage();
      });

      toggleLogin?.addEventListener("click", () => {
        recoveryForm?.classList.add("hidden");
        loginForm?.classList.remove("hidden");
        hideMessage();
      });

      loginForm?.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (!loginButton || !loginForm || !supabase || !emailInput || !passwordInput) {
          showMessage("Autenticación no disponible. Configure Supabase en el entorno de despliegue.");
          return;
        }

        let email = emailInput.value.trim();
        let password = passwordInput.value;

        loginButton.disabled = true;
        loginButton.textContent = "Validando...";

        const { data: authData, error } = await supabase.auth.signInWithPassword({ email, password });
        if (error || !authData.user) {
          password = "";
          passwordInput.value = "";
          showMessage("Credenciales inválidas.");
          loginButton.disabled = false;
          loginButton.textContent = "Entrar";
          return;
        }

        const { data: profile, error: profileError } = await supabase
          .from("users")
          .select("id, role_id, active")
          .eq("auth_user_id", authData.user.id)
          .eq("active", true)
          .single();

        if (profileError || !profile) {
          password = "";
          passwordInput.value = "";
          await supabase.auth.signOut();
          showMessage("Usuario autenticado pero sin perfil administrativo activo.");
          loginButton.disabled = false;
          loginButton.textContent = "Entrar";
          return;
        }

        password = "";
        passwordInput.value = "";
        showMessage("Sesión iniciada. Redirigiendo...", "success");
        const redirect = new URLSearchParams(window.location.search).get("redirect") || "/admin";
        window.location.href = redirect;
      });

      recoveryForm?.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (!recoveryButton || !recoveryForm || !supabase || !recoveryEmailInput) {
          showMessage("Autenticación no disponible.");
          return;
        }

        const email = recoveryEmailInput.value.trim();

        recoveryButton.disabled = true;
        recoveryButton.textContent = "Enviando...";

        const { error } = await supabase.auth.resetPasswordForEmail(email, {
          redirectTo: `${window.location.origin}/admin/reset-password`
        });

        if (error) {
          showMessage("Error al enviar correo de recuperación: " + error.message);
          recoveryButton.disabled = false;
          recoveryButton.textContent = "Enviar correo de recuperación";
          return;
        }

        showMessage("Correo de recuperación enviado con éxito. Revise su bandeja de entrada.", "success");
        (recoveryForm as HTMLFormElement).reset();
        recoveryButton.disabled = false;
        recoveryButton.textContent = "Enviar correo de recuperación";
      });
    </script>
  </body>
</html>
