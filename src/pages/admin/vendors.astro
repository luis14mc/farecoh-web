---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AdminPage from "@/components/admin/ui/AdminPage.astro";
import { AdminPageHeader } from "@/components/admin/react/AdminPageHeader";
import { VendorsAdminPanel } from "@/components/admin/react/VendorsAdminPanel";
import { createSupabaseServerClient, getPublicSupabaseConfig, isAuthConfigured, type UserProfile } from "@/lib/auth";
import { formatSiteDate } from "@/lib/locale";

const supabase = createSupabaseServerClient(Astro);
const staffProfile = Astro.locals.staffProfile as UserProfile | undefined;
const authConfigured = isAuthConfigured(getPublicSupabaseConfig());
const currentDate = formatSiteDate(new Date(), { month: "short", day: "numeric", year: "numeric" });

let formMessage = "";
let formError = false;

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const action = String(data.get("action") || "");
    const id = String(data.get("seller_id") || "");

    if (action === "create" || action === "update") {
      const name = String(data.get("name") || "").trim();
      const phone = String(data.get("phone") || "").trim();
      const email = String(data.get("email") || "").trim().toLowerCase();
      const type = String(data.get("type") || "") as "vendor" | "physical_point";

      if (!name || !phone || !email || !type) {
        throw new Error("Complete todos los campos obligatorios.");
      }

      if (action === "create") {
        const { error } = await supabase.from("sellers").insert({ name, phone, email, type, active: true });
        if (error) throw error;
        formMessage = `${name} registrado correctamente.`;
      } else {
        const { error } = await supabase.from("sellers").update({ name, phone, email, type }).eq("id", id);
        if (error) throw error;
        formMessage = `${name} actualizado correctamente.`;
      }
    } else if (action === "deactivate") {
      const { error } = await supabase.from("sellers").update({ active: false }).eq("id", id);
      if (error) throw error;
      formMessage = "Vendedor desactivado.";
    } else if (action === "activate") {
      const { error } = await supabase.from("sellers").update({ active: true }).eq("id", id);
      if (error) throw error;
      formMessage = "Vendedor reactivado.";
    }
  } catch (err: unknown) {
    formError = true;
    formMessage = err instanceof Error ? err.message : "Error al procesar la solicitud.";
  }
}

const { data: sellers = [] } = await supabase.from("sellers").select("*").order("name", { ascending: true });
---

<AdminLayout title="Vendedores | FARECOH" description="Administración de vendedores y puntos físicos" active="vendors">
  <AdminPageHeader
    client:load
    title="Vendedores"
    section="Operaciones"
    description="Administre vendedores y puntos físicos de venta."
    currentDate={currentDate}
    staffProfile={staffProfile}
    authConfigured={authConfigured}
  />

  <AdminPage>
    <VendorsAdminPanel client:load sellers={sellers} formMessage={formMessage} formError={formError} />
  </AdminPage>
</AdminLayout>
