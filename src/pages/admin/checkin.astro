---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AdminHeader from "@/components/admin/AdminHeader.astro";
---

<AdminLayout title="Control de acceso | FARECOH" description="Validación de ingreso de boletos físicos" active="checkin">
  <AdminHeader title="Control de acceso" section="Administración" />

  <div class="px-margin py-8 max-w-2xl mx-auto pb-24 md:pb-8">
    <section class="rounded-lg border border-outline-variant bg-surface-container-lowest p-6 text-on-surface shadow-sm">
      <h2 class="text-headline-sm font-headline-sm text-on-surface">Validar ingreso</h2>
      <p class="mt-1 text-body-md font-body-md text-on-surface-variant">Busque el código impreso del boleto físico.</p>

      <div class="mt-6 flex flex-col gap-3 sm:flex-row">
        <input id="checkin-code" placeholder="PF-000001" class="min-w-0 flex-1 rounded border border-outline-variant bg-surface px-4 py-3 font-mono text-body-lg outline-none focus:border-primary" />
        <button id="search-ticket" class="rounded bg-primary px-5 py-3 text-label-md font-label-md font-bold text-on-primary hover:bg-secondary">Buscar</button>
      </div>

      <div id="checkin-message" class="mt-5 hidden rounded p-4 text-body-md font-body-md"></div>
      <div id="ticket-result" class="mt-5 hidden rounded border border-outline-variant bg-surface p-5"></div>
      <button id="validate-ticket" class="mt-5 hidden w-full rounded bg-secondary px-5 py-3 text-label-md font-label-md font-bold text-on-secondary hover:opacity-90">Validar ingreso</button>
    </section>
  </div>
</AdminLayout>

<script>
  import { supabase } from "@/lib/supabase";

  const PHYSICAL_STATUS_LABELS: Record<string, string> = {
    available: "Disponible",
    assigned: "Asignado",
    reserved: "Reservado",
    sold: "Vendido",
    validated: "Validado",
    cancelled: "Anulado",
  };

  let activeTicket: any = null;

  function showMessage(text: string, type: "error" | "warning" | "success" | "info") {
    const node = document.getElementById("checkin-message");
    if (!node) return;
    const classes = {
      error: "bg-red-100 text-red-700 font-bold",
      warning: "bg-yellow-100 text-yellow-800",
      success: "bg-green-100 text-green-700 font-bold",
      info: "bg-blue-100 text-blue-700",
    };
    node.textContent = text;
    node.className = `mt-5 rounded p-4 text-body-md font-body-md ${classes[type] || classes.info}`;
    node.classList.remove("hidden");
  }

  function formatDate(isoString: string | null) {
    if (!isoString) return "-";
    return new Date(isoString).toLocaleString("es-HN", {
      dateStyle: "medium",
      timeStyle: "short",
    });
  }

  function renderTicket(ticket: any) {
    const result = document.getElementById("ticket-result");
    const button = document.getElementById("validate-ticket");
    if (!result || !button) return;

    if (!ticket) {
      result.classList.add("hidden");
      button.classList.add("hidden");
      return;
    }

    result.classList.remove("hidden");
    result.innerHTML = `
      <div class="space-y-3">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-caption font-caption font-bold uppercase text-primary">Boleto</p>
            <h3 class="font-mono text-headline-sm font-headline-sm text-on-surface">${ticket.ticket_code}</h3>
          </div>
          <span class="rounded-full bg-surface-container-high px-3 py-1 text-caption font-caption font-bold">
            ${PHYSICAL_STATUS_LABELS[ticket.status] || ticket.status}
          </span>
        </div>
        <dl class="grid gap-3 sm:grid-cols-2">
          <div>
            <dt class="text-caption font-caption font-bold uppercase text-on-surface-variant">Comprador</dt>
            <dd class="font-semibold text-on-surface">${ticket.buyer_name || "-"}</dd>
          </div>
          <div>
            <dt class="text-caption font-caption font-bold uppercase text-on-surface-variant">Teléfono</dt>
            <dd class="text-on-surface">${ticket.buyer_phone || "-"}</dd>
          </div>
          <div>
            <dt class="text-caption font-caption font-bold uppercase text-on-surface-variant">Vendedor</dt>
            <dd class="text-on-surface">${ticket.seller_name || "-"}</dd>
          </div>
          <div>
            <dt class="text-caption font-caption font-bold uppercase text-on-surface-variant">Punto</dt>
            <dd class="text-on-surface">${ticket.sale_location || "-"}</dd>
          </div>
          <div>
            <dt class="text-caption font-caption font-bold uppercase text-on-surface-variant">Venta</dt>
            <dd class="text-on-surface">${formatDate(ticket.sold_at)}</dd>
          </div>
          <div>
            <dt class="text-caption font-caption font-bold uppercase text-on-surface-variant">Validación</dt>
            <dd class="text-on-surface">${formatDate(ticket.validated_at)}</dd>
          </div>
        </dl>
      </div>
    `;

    if (ticket.status === "sold") {
      button.classList.remove("hidden");
    } else {
      button.classList.add("hidden");
    }
  }

  async function searchTicket() {
    const codeEl = document.getElementById("checkin-code") as HTMLInputElement | null;
    const ticketCode = (codeEl?.value || "").trim().toUpperCase();
    activeTicket = null;

    if (!ticketCode) {
      showMessage("Ingrese un código de boleto.", "warning");
      renderTicket(null);
      return;
    }

    if (!/^PF-\d{6}$/.test(ticketCode)) {
      showMessage("Formato inválido. Use PF-000001.", "error");
      renderTicket(null);
      return;
    }

    showMessage("Buscando boleto...", "info");

    const { data: ticket, error } = await supabase
      .from("tickets")
      .select("*")
      .eq("ticket_code", ticketCode)
      .single();

    if (error || !ticket) {
      showMessage("Boleto inexistente.", "error");
      renderTicket(null);
      return;
    }

    activeTicket = ticket;
    renderTicket(ticket);

    if (ticket.status === "sold") {
      showMessage("Boleto vendido. Puede validar ingreso.", "success");
    } else if (ticket.status === "validated") {
      showMessage("Boleto ya utilizado.", "error");
    } else if (ticket.status === "reserved") {
      showMessage("Boleto reservado, pendiente de pago.", "warning");
    } else if (ticket.status === "available" || ticket.status === "assigned") {
      showMessage("Boleto no vendido aún.", "warning");
    } else if (ticket.status === "cancelled") {
      showMessage("Boleto anulado.", "error");
    }
  }

  async function validateTicket() {
    if (!activeTicket) return;

    showMessage("Validando boleto...", "info");

    const { data, error } = await supabase.rpc("validate_ticket", {
      p_ticket_code: activeTicket.ticket_code,
      p_validated_by: "admin-checkin",
    });

    if (error) {
      showMessage("Error al validar: " + error.message, "error");
      return;
    }

    const result = data?.[0];
    if (!result?.ok) {
      showMessage(result?.message || "No se pudo validar el boleto.", "error");
      return;
    }

    activeTicket = {
      ...activeTicket,
      status: "validated",
      validated_at: result.validated_at,
    };
    showMessage("Ingreso validado correctamente.", "success");
    renderTicket(activeTicket);
  }

  document.getElementById("search-ticket")?.addEventListener("click", searchTicket);
  document.getElementById("validate-ticket")?.addEventListener("click", validateTicket);
  document.getElementById("checkin-code")?.addEventListener("keydown", (event) => {
    if (event.key === "Enter") searchTicket();
  });
</script>
