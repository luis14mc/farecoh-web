---
import AdminAuthLayout from "@/layouts/AdminAuthLayout.astro";
import { getPublicSupabaseConfig, isAuthConfigured } from "@/lib/auth";

const { supabaseUrl, supabaseAnonKey } = getPublicSupabaseConfig();
const authConfigured = isAuthConfigured({ supabaseUrl, supabaseAnonKey });
---

<AdminAuthLayout
  title="Establecer Nueva Contraseña | FARECOH"
  supabaseUrl={supabaseUrl}
  supabaseAnonKey={supabaseAnonKey}
  authConfigured={authConfigured}
>
  <main class="flex min-h-screen items-center justify-center px-margin py-12">
    <section class="w-full max-w-md rounded-lg border border-outline-variant bg-surface-container-lowest p-6 shadow-sm">
      <p class="label-caps text-primary">Seguridad de cuenta</p>
      <h1 class="mt-2 headline-md text-on-surface">Nueva contraseña</h1>
      <p class="mt-2 body-md text-on-surface-variant">Establezca una nueva contraseña segura para su perfil administrativo.</p>

      {!authConfigured && (
        <p class="mt-4 rounded bg-yellow-100 p-3 body-md text-yellow-800">
          Supabase Auth no está configurado.
        </p>
      )}

      <form id="reset-password-form" class="mt-6 space-y-4">
        <label class="block">
          <span class="label-caps text-on-surface-variant">Nueva contraseña</span>
          <input id="password" name="password" type="password" required minlength="6" disabled={!authConfigured} class="mt-2 w-full rounded border border-outline-variant bg-surface px-3 py-3 body-md outline-none focus:border-primary disabled:cursor-not-allowed disabled:opacity-60" />
        </label>
        <label class="block">
          <span class="label-caps text-on-surface-variant">Confirmar contraseña</span>
          <input id="confirm-password" name="confirm-password" type="password" required minlength="6" disabled={!authConfigured} class="mt-2 w-full rounded border border-outline-variant bg-surface px-3 py-3 body-md outline-none focus:border-primary disabled:cursor-not-allowed disabled:opacity-60" />
        </label>
        <button id="reset-button" disabled={!authConfigured} class="w-full rounded bg-primary px-4 py-3 label-caps text-on-primary transition-colors hover:bg-secondary disabled:cursor-not-allowed disabled:opacity-60" type="submit">
          Restablecer contraseña
        </button>
      </form>

      <p id="reset-message" class="mt-4 hidden rounded p-3 body-md"></p>

      <div class="mt-6 text-center">
        <a href="/admin/login" class="label-caps text-primary hover:underline">Volver a iniciar sesión</a>
      </div>
    </section>
  </main>

  <script>
    import { createBrowserClient } from "@supabase/ssr";

    const body = document.body;
    const supabaseUrl = body.dataset.supabaseUrl || "";
    const supabaseAnonKey = body.dataset.supabaseAnonKey || "";
    const authConfigured = body.dataset.authConfigured === "true";

    const form = document.getElementById("reset-password-form");
    const button = document.getElementById("reset-button") as HTMLButtonElement | null;
    const message = document.getElementById("reset-message");
    const passwordInput = document.getElementById("password") as HTMLInputElement | null;
    const confirmPasswordInput = document.getElementById("confirm-password") as HTMLInputElement | null;
    const supabase = authConfigured ? createBrowserClient(supabaseUrl, supabaseAnonKey) : null;

    function showMessage(text: string, type = "error") {
      if (!message) return;
      message.textContent = text;
      message.className = `mt-4 rounded p-3 body-md ${type === "error" ? "bg-red-100 text-red-700" : "bg-green-100 text-green-700"}`;
      message.classList.remove("hidden");
    }

    async function checkSession() {
      if (!supabase) return;

      const {
        data: { session },
      } = await supabase.auth.getSession();
      if (!session) {
        showMessage("No se ha detectado una sesión de recuperación activa. Solicite un nuevo correo de restablecimiento.");
        if (button) button.disabled = true;
      }
    }

    void checkSession();

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!button || !form || !supabase || !passwordInput || !confirmPasswordInput) {
        showMessage("Autenticación no disponible.");
        return;
      }

      const password = passwordInput.value;
      const confirmPassword = confirmPasswordInput.value;

      if (password !== confirmPassword) {
        showMessage("Las contraseñas no coinciden.");
        return;
      }

      button.disabled = true;
      button.textContent = "Actualizando...";

      const { error } = await supabase.auth.updateUser({ password });
      if (error) {
        showMessage("Error al actualizar la contraseña: " + error.message);
        button.disabled = false;
        button.textContent = "Restablecer contraseña";
        return;
      }

      showMessage("Contraseña restablecida con éxito. Redirigiendo al panel...", "success");
      setTimeout(() => {
        window.location.href = "/admin";
      }, 1500);
    });
  </script>
</AdminAuthLayout>
