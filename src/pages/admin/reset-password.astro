---
import "../../styles/global.css";
import { getPublicSupabaseConfig, isAuthConfigured } from "@/lib/auth";
import { SITE_LANG } from "@/lib/locale";

const { supabaseUrl, supabaseAnonKey } = getPublicSupabaseConfig();
const authConfigured = isAuthConfigured({ supabaseUrl, supabaseAnonKey });
---

<!doctype html>
<html lang={SITE_LANG} class="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Establecer Nueva Contraseña | FARECOH</title>
  </head>
  <body class="min-h-screen bg-surface text-on-surface font-body-md text-body-md" data-supabase-url={supabaseUrl} data-supabase-anon-key={supabaseAnonKey} data-auth-configured={authConfigured ? "true" : "false"}>
    <main class="flex min-h-screen items-center justify-center px-margin py-12">
      <section class="w-full max-w-md rounded-lg border border-outline-variant bg-surface-container-lowest p-6 shadow-sm animate-fade-in">
        <p class="text-label-md font-label-md font-bold uppercase tracking-wider text-primary">Seguridad de cuenta</p>
        <h1 class="mt-2 text-headline-md font-headline-md text-on-surface">Nueva contraseña</h1>
        <p class="mt-2 text-body-md font-body-md text-on-surface-variant">Establezca una nueva contraseña segura para su perfil administrativo.</p>

        {!authConfigured && (
          <p class="mt-4 rounded bg-yellow-100 p-3 text-body-md text-yellow-800">
            Supabase Auth no está configurado.
          </p>
        )}

        <form id="reset-password-form" class="mt-6 space-y-4">
          <label class="block">
            <span class="text-caption font-caption font-bold uppercase text-on-surface-variant">Nueva contraseña</span>
            <input id="password" name="password" type="password" required minlength="6" disabled={!authConfigured} class="mt-2 w-full rounded border border-outline-variant bg-surface px-3 py-3 text-body-md outline-none focus:border-primary disabled:cursor-not-allowed disabled:opacity-60" />
          </label>
          <label class="block">
            <span class="text-caption font-caption font-bold uppercase text-on-surface-variant">Confirmar contraseña</span>
            <input id="confirm-password" name="confirm-password" type="password" required minlength="6" disabled={!authConfigured} class="mt-2 w-full rounded border border-outline-variant bg-surface px-3 py-3 text-body-md outline-none focus:border-primary disabled:cursor-not-allowed disabled:opacity-60" />
          </label>
          <button id="reset-button" disabled={!authConfigured} class="w-full rounded bg-primary px-4 py-3 text-label-md font-label-md font-bold text-on-primary transition-colors hover:bg-secondary disabled:cursor-not-allowed disabled:opacity-60" type="submit">
            Restablecer contraseña
          </button>
        </form>

        <p id="reset-message" class="mt-4 hidden rounded p-3 text-body-md font-body-md"></p>
        
        <div class="mt-6 text-center">
          <a href="/admin/login" class="text-caption font-bold text-primary hover:underline">Volver a iniciar sesión</a>
        </div>
      </section>
    </main>

    <script>
      import { createBrowserClient } from "@supabase/ssr";

      const body = document.body;
      const supabaseUrl = body.dataset.supabaseUrl || "";
      const supabaseAnonKey = body.dataset.supabaseAnonKey || "";
      const authConfigured = body.dataset.authConfigured === "true";

      const form = document.getElementById("reset-password-form");
      const button = document.getElementById("reset-button") as HTMLButtonElement | null;
      const message = document.getElementById("reset-message");
      const passwordInput = document.getElementById("password") as HTMLInputElement | null;
      const confirmPasswordInput = document.getElementById("confirm-password") as HTMLInputElement | null;
      const supabase = authConfigured ? createBrowserClient(supabaseUrl, supabaseAnonKey) : null;

      function showMessage(text: string, type = "error") {
        if (!message) return;
        message.textContent = text;
        message.className = `mt-4 rounded p-3 text-body-md font-body-md ${type === "error" ? "bg-red-100 text-red-700" : "bg-green-100 text-green-700"}`;
        message.classList.remove("hidden");
      }

      // Check if session exists (user clicked confirmation link and was logged in automatically)
      async function checkSession() {
        if (!supabase) return;
        
        const { data: { session } } = await supabase.auth.getSession();
        if (!session) {
          showMessage("No se ha detectado una sesión de recuperación activa. Solicite un nuevo correo de restablecimiento.");
          if (button) button.disabled = true;
        }
      }

      checkSession();

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (!button || !form || !supabase || !passwordInput || !confirmPasswordInput) {
          showMessage("Autenticación no disponible.");
          return;
        }

        let password = passwordInput.value;
        let confirmPassword = confirmPasswordInput.value;

        if (password !== confirmPassword) {
          showMessage("Las contraseñas no coinciden.");
          return;
        }

        button.disabled = true;
        button.textContent = "Actualizando...";

        const { error } = await supabase.auth.updateUser({ password });
        if (error) {
          showMessage("Error al actualizar la contraseña: " + error.message);
          button.disabled = false;
          button.textContent = "Restablecer contraseña";
          return;
        }

        showMessage("Contraseña restablecida con éxito. Redirigiendo al panel...", "success");
        setTimeout(() => {
          window.location.href = "/admin";
        }, 1500);
      });
    </script>
  </body>
</html>
