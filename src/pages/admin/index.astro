---
import AdminLayout from "@/layouts/AdminLayout.astro";
import PageHeader from "@/components/admin/ui/PageHeader.astro";
import AdminPage from "@/components/admin/ui/AdminPage.astro";
import Card from "@/components/admin/ui/Card.astro";
import StatsCard from "@/components/admin/StatsCard.astro";
import TicketSearch from "@/components/admin/TicketSearch.astro";
import SalesTable from "@/components/admin/SalesTable.astro";
import RecentReservations from "@/components/admin/RecentReservations.astro";
import RecentCheckins from "@/components/admin/RecentCheckins.astro";
import SalesByPoint from "@/components/admin/SalesByPoint.astro";
import { supabase } from "@/lib/supabase";
import { formatSiteCurrency } from "@/lib/locale";

const { data: sales = [] } = await supabase
  .from("sales")
  .select("amount, seller_name, created_at")
  .order("created_at", { ascending: true });

const salesByDayMap: Record<string, number> = {};
sales?.forEach((sale: any) => {
  const dayStr = new Date(sale.created_at).toLocaleDateString("es-HN", {
    day: "numeric",
    month: "short",
  });
  salesByDayMap[dayStr] = (salesByDayMap[dayStr] || 0) + Number(sale.amount);
});
const salesByDay = Object.entries(salesByDayMap).slice(-7);
const maxDaySales = Math.max(...salesByDay.map(([_, amt]) => amt), 1);

const salesBySellerMap: Record<string, number> = {};
sales?.forEach((sale: any) => {
  const seller = sale.seller_name || "Desconocido";
  salesBySellerMap[seller] = (salesBySellerMap[seller] || 0) + Number(sale.amount);
});
const salesBySeller = Object.entries(salesBySellerMap)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 5);
const maxSellerSales = Math.max(...salesBySeller.map(([_, amt]) => amt), 1);
---

<AdminLayout
  title="Panel administrativo | FARECOH"
  description="Panel de administración de boletería de FARECOH"
  active="dashboard"
>
  <PageHeader title="Panel de control" section="Dashboard" description="Resumen operativo del evento Pink Floyd." />

  <AdminPage>
    <StatsCard />

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
      <Card>
        <h3 class="text-sm font-semibold text-on-surface">Ventas por día</h3>
        <p class="mt-1 text-xs text-on-surface-variant">Tendencia de recaudación diaria</p>
        {salesByDay.length > 0 ? (
          <div class="mt-5 space-y-4">
            {salesByDay.map(([day, amount]) => {
              const pct = (amount / maxDaySales) * 100;
              return (
                <div class="space-y-1.5">
                  <div class="flex justify-between text-sm">
                    <span class="font-medium">{day}</span>
                    <span class="font-semibold text-primary">{formatSiteCurrency(amount)}</span>
                  </div>
                  <div class="h-2 w-full overflow-hidden rounded-full bg-surface-container-low">
                    <div class="h-full rounded-full bg-primary transition-all" style={`width: ${pct}%`}></div>
                  </div>
                </div>
              );
            })}
          </div>
        ) : (
          <p class="py-8 text-sm text-on-surface-variant">No hay registros de ventas recientes.</p>
        )}
      </Card>

      <Card>
        <h3 class="text-sm font-semibold text-on-surface">Ventas por vendedor</h3>
        <p class="mt-1 text-xs text-on-surface-variant">Top vendedores de boletería física</p>
        {salesBySeller.length > 0 ? (
          <div class="mt-5 space-y-4">
            {salesBySeller.map(([seller, amount]) => {
              const pct = (amount / maxSellerSales) * 100;
              return (
                <div class="space-y-1.5">
                  <div class="flex justify-between gap-3 text-sm">
                    <span class="truncate font-medium">{seller}</span>
                    <span class="shrink-0 font-semibold text-secondary">{formatSiteCurrency(amount)}</span>
                  </div>
                  <div class="h-2 w-full overflow-hidden rounded-full bg-surface-container-low">
                    <div class="h-full rounded-full bg-secondary-container transition-all" style={`width: ${pct}%`}></div>
                  </div>
                </div>
              );
            })}
          </div>
        ) : (
          <p class="py-8 text-sm text-on-surface-variant">No hay registros de vendedores activos.</p>
        )}
      </Card>

      <SalesByPoint />
    </div>

    <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
      <RecentReservations />
      <RecentCheckins />
    </div>

    <div class="grid grid-cols-1 items-start gap-4 lg:grid-cols-3">
      <section class="lg:col-span-1">
        <TicketSearch />
      </section>
      <section class="lg:col-span-2">
        <SalesTable />
      </section>
    </div>
  </AdminPage>
</AdminLayout>
