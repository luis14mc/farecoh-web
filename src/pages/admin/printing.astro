---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { AdminPageHeader } from "@/components/admin/react/AdminPageHeader";
import { PrintingExportPanel } from "@/components/admin/react/PrintingExportPanel";
import { createSupabaseServerClient, getPublicSupabaseConfig, isAuthConfigured, type UserProfile } from "@/lib/auth";
import { formatSiteDate } from "@/lib/locale";

const supabase = createSupabaseServerClient(Astro);
const staffProfile = Astro.locals.staffProfile as UserProfile | undefined;
const authConfigured = isAuthConfigured(getPublicSupabaseConfig());
const currentDate = formatSiteDate(new Date(), { month: "short", day: "numeric", year: "numeric" });

const { data: events = [] } = await supabase
  .from("events")
  .select("id, slug, name")
  .order("name", { ascending: true });

const { data: batches = [] } = await supabase
  .from("ticket_batches")
  .select("id, event_id, name, start_code, end_code")
  .order("created_at", { ascending: false });
---

<AdminLayout title="Impresión Canva | FARECOH" description="Exportación CSV para Canva Bulk Create" active="printing">
  <AdminPageHeader
    client:load
    title="Impresión Canva"
    section="Exportación"
    description="Prepare CSV con QR para diseño e impresión de boletos físicos."
    currentDate={currentDate}
    staffProfile={staffProfile}
    authConfigured={authConfigured}
  />

  <div class="mx-auto w-full max-w-3xl space-y-6 px-4 py-6 pb-24 md:px-8 md:py-8 md:pb-8">
    <PrintingExportPanel client:load events={events} batches={batches} />
  </div>
</AdminLayout>
