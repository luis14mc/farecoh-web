---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AdminPage from "@/components/admin/ui/AdminPage.astro";
import { AdminPageHeader } from "@/components/admin/react/AdminPageHeader";
import { UsersAdminPanel } from "@/components/admin/react/UsersAdminPanel";
import { createSupabaseServerClient, ROLE_LABELS, type StaffRole, getPublicSupabaseConfig, isAuthConfigured, type UserProfile } from "@/lib/auth";
import { supabaseAdmin } from "@/lib/supabase";
import { formatSiteDate } from "@/lib/locale";

const supabase = createSupabaseServerClient(Astro);
let formMessage = "";
let formError = false;
let lastFormAction = "";

const currentProfile = Astro.locals.staffProfile as UserProfile | undefined;
const staffProfile = currentProfile;
const authConfigured = isAuthConfigured(getPublicSupabaseConfig());
const currentDate = formatSiteDate(new Date(), { month: "short", day: "numeric", year: "numeric" });
const isSuperAdmin = currentProfile?.role === "super_admin";

async function getRoleId(roleName: string): Promise<string | null> {
  const { data } = await supabase.from("roles").select("id").eq("name", roleName).single();
  return data?.id ?? null;
}

if (Astro.request.method === "POST") {
  try {
    if (!isSuperAdmin) {
      throw new Error("No tiene permisos para realizar esta acción.");
    }

    const data = await Astro.request.formData();
    const action = String(data.get("action") || "");
    lastFormAction = action;
    const id = String(data.get("profile_id") || "");

    if (action === "create") {
      const email = String(data.get("email") || "").trim().toLowerCase();
      const password = String(data.get("password") || "");
      const fullName = String(data.get("full_name") || "").trim();
      const roleName = String(data.get("role") || "");

      if (!email || !password || !fullName || !roleName) {
        throw new Error("Complete todos los campos obligatorios.");
      }

      if (!supabaseAdmin) {
        throw new Error("SUPABASE_SERVICE_ROLE_KEY no está configurada.");
      }

      const roleId = await getRoleId(roleName);
      if (!roleId) throw new Error("Rol inválido.");

      const { data: authData, error: authErr } = await supabaseAdmin.auth.admin.createUser({
        email,
        password,
        email_confirm: true,
        user_metadata: { full_name: fullName },
      });

      if (authErr || !authData.user) {
        throw new Error("Error en Supabase Auth: " + (authErr?.message || "Usuario no creado."));
      }

      const { error: profileErr } = await supabase.from("users").insert({
        auth_user_id: authData.user.id,
        email,
        full_name: fullName,
        role_id: roleId,
        active: true,
      });

      if (profileErr) {
        await supabaseAdmin.auth.admin.deleteUser(authData.user.id);
        throw profileErr;
      }

      formMessage = `Usuario ${fullName} creado correctamente.`;
    } else if (action === "update") {
      const fullName = String(data.get("full_name") || "").trim();
      const roleName = String(data.get("role") || "");

      if (!fullName || !roleName) {
        throw new Error("Complete todos los campos obligatorios.");
      }

      const roleId = await getRoleId(roleName);
      if (!roleId) throw new Error("Rol inválido.");

      const { error: profileErr } = await supabase
        .from("users")
        .update({ full_name: fullName, role_id: roleId })
        .eq("id", id);

      if (profileErr) throw profileErr;
      formMessage = "Usuario actualizado correctamente.";
    } else if (action === "toggle_active") {
      if (!supabaseAdmin) {
        throw new Error("SUPABASE_SERVICE_ROLE_KEY no está configurada.");
      }

      const { data: profile, error: fetchErr } = await supabase
        .from("users")
        .select("auth_user_id, active, full_name")
        .eq("id", id)
        .single();

      if (fetchErr || !profile) {
        throw new Error("Usuario no encontrado.");
      }

      const nextActiveState = !profile.active;

      const { error: profileErr } = await supabase.from("users").update({ active: nextActiveState }).eq("id", id);

      if (profileErr) throw profileErr;

      const { error: authUpdateErr } = await supabaseAdmin.auth.admin.updateUserById(profile.auth_user_id, {
        ban_duration: nextActiveState ? "none" : "876600h",
      });

      if (authUpdateErr) throw authUpdateErr;

      formMessage = `Usuario ${profile.full_name} ${nextActiveState ? "reactivado" : "desactivado"} correctamente.`;
    }
  } catch (err: unknown) {
    formError = true;
    formMessage = err instanceof Error ? err.message : "Error al procesar la solicitud.";
  }
}

const { data: staffProfiles = [] } = await supabase
  .from("users")
  .select("*, roles(name)")
  .order("created_at", { ascending: false });

const roleLabel = (roleName: string) => ROLE_LABELS[roleName as StaffRole] ?? roleName;

const users = (staffProfiles ?? []).map((profile) => ({
  id: profile.id,
  auth_user_id: profile.auth_user_id,
  email: profile.email,
  full_name: profile.full_name,
  active: profile.active,
  created_at: profile.created_at,
  roleName: profile.roles?.name ?? "",
  roleLabel: roleLabel(profile.roles?.name ?? ""),
  createdLabel: formatSiteDate(profile.created_at),
}));
---

<AdminLayout title="Usuarios | FARECOH" description="Administración de usuarios del panel" active="users">
  <AdminPageHeader
    client:load
    title="Usuarios"
    section="Accesos"
    description="Gestione cuentas y roles del panel administrativo."
    currentDate={currentDate}
    staffProfile={staffProfile}
    authConfigured={authConfigured}
  />

  <AdminPage mobileFab>
    <UsersAdminPanel
      client:load
      users={users}
      isSuperAdmin={isSuperAdmin}
      currentAuthUserId={currentProfile?.auth_user_id}
      formMessage={formMessage || undefined}
      formError={formError}
      lastFormAction={lastFormAction || undefined}
    />
  </AdminPage>
</AdminLayout>
