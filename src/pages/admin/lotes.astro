---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AdminHeader from "@/components/admin/AdminHeader.astro";
---

<AdminLayout title="Lotes de Boletos | FARECOH" description="Administración de lotes físicos" active="lotes">
  <AdminHeader title="Lotes de Boletos" section="Boletos físicos" />

  <div class="px-margin py-8 max-w-container-max pb-24 md:pb-8 space-y-stack-lg">
    <section class="rounded-lg border border-outline-variant bg-surface-container-lowest p-6 shadow-sm">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="text-label-md font-label-md font-bold uppercase tracking-wider text-primary">Lote inicial</p>
          <h2 class="mt-1 text-headline-md font-headline-md text-on-surface">LOTE GENERAL 001</h2>
          <p class="mt-2 text-body-md font-body-md text-on-surface-variant">Rango operativo: PF-000001 - PF-000500</p>
        </div>
        <button id="reset-seed" class="inline-flex items-center justify-center gap-2 rounded border border-outline-variant px-4 py-3 text-label-md font-label-md font-bold text-on-surface transition-colors hover:bg-surface-container-high">
          <span class="material-symbols-outlined">restart_alt</span>
          Reinicializar demo local
        </button>
      </div>
    </section>

    <section class="grid gap-gutter lg:grid-cols-3">
      <form id="assignment-form" class="rounded-lg border border-outline-variant bg-surface-container-lowest p-6 shadow-sm lg:col-span-1">
        <h3 class="text-headline-sm font-headline-sm text-on-surface">Asignar rango</h3>
        <p class="mt-1 text-body-md font-body-md text-on-surface-variant">Entrega boletos a un vendedor registrado.</p>

        <div class="mt-6 space-y-4">
          <label class="block">
            <span class="text-caption font-caption font-bold uppercase text-on-surface-variant">Desde</span>
            <input name="start_code" required placeholder="PF-000001" class="mt-2 w-full rounded border border-outline-variant bg-surface px-3 py-3 font-mono text-body-md outline-none focus:border-primary" />
          </label>
          <label class="block">
            <span class="text-caption font-caption font-bold uppercase text-on-surface-variant">Hasta</span>
            <input name="end_code" required placeholder="PF-000050" class="mt-2 w-full rounded border border-outline-variant bg-surface px-3 py-3 font-mono text-body-md outline-none focus:border-primary" />
          </label>
          <label class="block">
            <span class="text-caption font-caption font-bold uppercase text-on-surface-variant">Vendedor</span>
            <select id="seller-select" name="seller_id" required class="mt-2 w-full rounded border border-outline-variant bg-surface px-3 py-3 text-body-md outline-none focus:border-primary">
              <option value="">Seleccione un vendedor</option>
            </select>
            <p class="mt-2 text-caption text-on-surface-variant">
              <a href="/admin/vendedores" class="font-bold text-primary hover:underline">Registrar vendedor</a>
            </p>
          </label>
          <label class="block">
            <span class="text-caption font-caption font-bold uppercase text-on-surface-variant">Punto físico</span>
            <input name="location" required placeholder="Escuela Nacional de Música" class="mt-2 w-full rounded border border-outline-variant bg-surface px-3 py-3 text-body-md outline-none focus:border-primary" />
          </label>
        </div>

        <button class="mt-6 w-full rounded bg-primary px-4 py-3 text-label-md font-label-md font-bold text-on-primary transition-colors hover:bg-secondary" type="submit">
          Asignar rango
        </button>
        <p id="assignment-message" class="mt-4 hidden rounded p-3 text-body-md font-body-md"></p>
      </form>

      <div class="rounded-lg border border-outline-variant bg-surface-container-lowest shadow-sm lg:col-span-2">
        <div class="border-b border-outline-variant p-6">
          <h3 class="text-headline-sm font-headline-sm text-on-surface">Resumen de lote</h3>
          <p class="mt-1 text-body-md font-body-md text-on-surface-variant">Estado actual de los boletos físicos.</p>
        </div>
        <div class="grid gap-4 p-6 sm:grid-cols-3" id="batch-stats"></div>
        <div class="border-t border-outline-variant p-6">
          <h4 class="text-label-md font-label-md font-bold uppercase tracking-wider text-on-surface-variant">Asignaciones</h4>
          <div id="assignments-list" class="mt-4 space-y-3"></div>
        </div>
      </div>
    </section>
  </div>
</AdminLayout>

<script>
  import {
    getActiveSellers,
    getSellerById,
    getTickets,
    normalizeTicketCode,
    parseTicketCode,
    seedPhysicalTicketing,
    setTickets,
  } from "@/services/physical-store";
  import { SELLER_TYPE_LABELS } from "@/types/sellers";

  function showMessage(text: string, type: "success" | "error" = "success") {
    const message = document.getElementById("assignment-message");
    if (!message) return;
    message.textContent = text;
    message.className = `mt-4 rounded p-3 text-body-md font-body-md ${type === "error" ? "bg-red-100 text-red-700" : "bg-green-100 text-green-700"}`;
  }

  function renderSellerOptions() {
    const select = document.getElementById("seller-select") as HTMLSelectElement;
    if (!select) return;

    const sellers = getActiveSellers();
    select.innerHTML = `<option value="">Seleccione un vendedor</option>${sellers.map((seller) => `<option value="${seller.id}">${seller.name} (${SELLER_TYPE_LABELS[seller.type]})</option>`).join("")}`;
  }

  function render() {
    const tickets = getTickets();
    const stats = [
      ["Disponibles", tickets.filter((ticket) => ticket.status === "available").length],
      ["Asignados", tickets.filter((ticket) => ticket.status === "assigned").length],
      ["Vendidos", tickets.filter((ticket) => ticket.status === "paid").length],
      ["Validados", tickets.filter((ticket) => ticket.status === "validated").length],
      ["Anulados", tickets.filter((ticket) => ticket.status === "cancelled").length],
      ["Total", tickets.length],
    ];

    const statsNode = document.getElementById("batch-stats");
    if (statsNode) {
      statsNode.innerHTML = stats.map(([label, value]) => `<article class="rounded border border-outline-variant bg-surface p-4"><p class="text-caption font-caption font-bold uppercase text-on-surface-variant">${label}</p><p class="mt-1 text-headline-md font-headline-md text-on-surface">${value}</p></article>`).join("");
    }

    const assignments = new Map<string, { count: number; min: string; max: string; location: string }>();
    tickets.filter((ticket) => ticket.seller_id || ticket.seller_name).forEach((ticket) => {
      const sellerName = ticket.seller_name || "Sin vendedor";
      const key = `${ticket.seller_id || sellerName}::${ticket.sale_location || "Sin punto"}`;
      const current = assignments.get(key) || { count: 0, min: ticket.code, max: ticket.code, location: ticket.sale_location || "Sin punto" };
      current.count += 1;
      if ((parseTicketCode(ticket.code) ?? 0) < (parseTicketCode(current.min) ?? 0)) current.min = ticket.code;
      if ((parseTicketCode(ticket.code) ?? 0) > (parseTicketCode(current.max) ?? 0)) current.max = ticket.code;
      assignments.set(key, current);
    });

    const list = document.getElementById("assignments-list");
    if (list) {
      list.innerHTML = assignments.size
        ? Array.from(assignments.entries()).map(([key, item]) => {
            const sellerId = key.split("::")[0];
            const seller = getSellerById(sellerId);
            const sellerLabel = seller?.name || sellerId;
            return `<div class="rounded border border-outline-variant bg-surface p-4"><p class="font-bold text-on-surface">${sellerLabel}</p><p class="text-body-md text-on-surface-variant">${item.min} - ${item.max} · ${item.count} boletos · ${item.location}</p></div>`;
          }).join("")
        : `<p class="text-body-md text-on-surface-variant">No hay rangos asignados todavía.</p>`;
    }
  }

  seedPhysicalTicketing();
  renderSellerOptions();
  render();

  document.getElementById("reset-seed")?.addEventListener("click", () => {
    if (!confirm("Esto reiniciará los 500 boletos locales. ¿Continuar?")) return;
    seedPhysicalTicketing(true);
    renderSellerOptions();
    render();
    showMessage("Lote local reinicializado.");
  });

  document.getElementById("assignment-form")?.addEventListener("submit", (event) => {
    event.preventDefault();
    const form = new FormData(event.currentTarget as HTMLFormElement);
    const start = normalizeTicketCode(String(form.get("start_code") || ""));
    const end = normalizeTicketCode(String(form.get("end_code") || ""));
    const startNumber = parseTicketCode(start);
    const endNumber = parseTicketCode(end);
    const sellerId = String(form.get("seller_id") || "");
    const location = String(form.get("location") || "").trim();
    const seller = getSellerById(sellerId);

    if (!seller || !seller.active) {
      showMessage("Seleccione un vendedor registrado y activo.", "error");
      return;
    }

    if (!startNumber || !endNumber || startNumber > endNumber) {
      showMessage("Rango inválido. Use formato PF-000001 a PF-000500.", "error");
      return;
    }

    const tickets = getTickets();
    let updated = 0;
    const nextTickets = tickets.map((ticket) => {
      const number = parseTicketCode(ticket.code);
      if (number !== null && number >= startNumber && number <= endNumber && ["available", "assigned"].includes(ticket.status)) {
        updated += 1;
        return {
          ...ticket,
          status: "assigned" as const,
          seller_id: seller.id,
          seller_name: seller.name,
          sale_location: location,
        };
      }
      return ticket;
    });

    setTickets(nextTickets);
    render();
    showMessage(`${updated} boletos asignados a ${seller.name} en ${location}.`);
    (event.currentTarget as HTMLFormElement).reset();
    renderSellerOptions();
  });
</script>
