---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AdminPage from "@/components/admin/ui/AdminPage.astro";
import { AdminPageHeader } from "@/components/admin/react/AdminPageHeader";
import { BatchesAdminPanel } from "@/components/admin/react/BatchesAdminPanel";
import { createSupabaseServerClient, getPublicSupabaseConfig, isAuthConfigured, type UserProfile } from "@/lib/auth";
import { getPinkFloydEventFallback } from "@/lib/events";
import { formatSiteDate } from "@/lib/locale";
import { formatTicketCode, parseTicketSequence } from "@/services/ticket-code";
import { countTicketsByStatus, countTicketsSold } from "@/services/admin-stats";

const supabase = createSupabaseServerClient(Astro);
const staffProfile = Astro.locals.staffProfile as UserProfile | undefined;
const authConfigured = isAuthConfigured(getPublicSupabaseConfig());
const currentDate = formatSiteDate(new Date(), { month: "short", day: "numeric", year: "numeric" });
const event = getPinkFloydEventFallback();

const { data: pinkFloydEvent } = await supabase.from("events").select("id").eq("slug", "pink-floyd").single();
const eventId = pinkFloydEvent?.id;

let formMessage = "";
let formError = false;

function normalizeTicketCode(ticketCode: string): string {
  return ticketCode.trim().toUpperCase();
}

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const startCode = normalizeTicketCode(String(data.get("start_code") || ""));
    const endCode = normalizeTicketCode(String(data.get("end_code") || ""));
    const sellerId = String(data.get("seller_id") || "");
    const location = String(data.get("location") || "").trim();

    const startSeq = parseTicketSequence(startCode);
    const endSeq = parseTicketSequence(endCode);

    if (startSeq === null || endSeq === null || startSeq > endSeq) {
      throw new Error("Rango de boletos inválido. Use el formato PF-000001 a PF-000500.");
    }

    if (!sellerId) {
      throw new Error("Seleccione un vendedor registrado.");
    }

    if (!location) {
      throw new Error("Especifique un punto físico o ubicación.");
    }

    const { data: seller, error: sellerErr } = await supabase
      .from("sellers")
      .select("*")
      .eq("id", sellerId)
      .single();

    if (sellerErr || !seller) {
      throw new Error("El vendedor seleccionado no existe.");
    }

    if (!seller.active) {
      throw new Error("El vendedor seleccionado está inactivo.");
    }

    const { data: pinkFloydEvent, error: eventErr } = await supabase
      .from("events")
      .select("id")
      .eq("slug", "pink-floyd")
      .single();

    if (eventErr || !pinkFloydEvent) {
      throw new Error("Evento Pink Floyd no encontrado.");
    }

    const { data: ticketsInRange = [], error: ticketsErr } = await supabase
      .from("tickets")
      .select("id, ticket_code, status")
      .eq("event_id", pinkFloydEvent.id);

    if (ticketsErr) throw ticketsErr;

    const matchedTickets = ticketsInRange.filter((t) => {
      const seq = parseTicketSequence(t.ticket_code);
      return seq !== null && seq >= startSeq && seq <= endSeq;
    });

    if (matchedTickets.length === 0) {
      throw new Error("No se encontraron boletos en el rango especificado.");
    }

    const unavailableTickets = matchedTickets.filter((t) => t.status !== "available" && t.status !== "assigned");
    if (unavailableTickets.length > 0) {
      throw new Error(
        `Hay boletos vendidos, validados o anulados en este rango (ej. ${unavailableTickets[0].ticket_code}).`,
      );
    }

    const batchName = `Lote ${startCode} - ${endCode}`;
    const { data: newBatch, error: batchErr } = await supabase
      .from("ticket_batches")
      .insert({
        event_id: pinkFloydEvent.id,
        name: batchName,
        start_code: startCode,
        end_code: endCode,
        total_tickets: matchedTickets.length,
        assigned_seller_id: sellerId,
        location,
      })
      .select()
      .single();

    if (batchErr || !newBatch) throw batchErr || new Error("Error al crear el lote en la base de datos.");

    const ticketIds = matchedTickets.map((t) => t.id);
    const { error: updateErr } = await supabase
      .from("tickets")
      .update({
        status: "assigned",
        batch_id: newBatch.id,
        seller_name: seller.name,
        sale_location: location,
      })
      .in("id", ticketIds);

    if (updateErr) throw updateErr;

    const userEmail = Astro.locals.staffProfile?.email || "Admin";
    await supabase.from("audit_logs").insert({
      action: "batch.assigned",
      entity: "ticket_batches",
      entity_id: newBatch.id,
      performed_by: userEmail,
    });

    formMessage = `${matchedTickets.length} boletos asignados correctamente a ${seller.name} en ${location}.`;
  } catch (err: unknown) {
    formError = true;
    formMessage = err instanceof Error ? err.message : "Error al procesar la asignación.";
  }
}

const { data: tickets = [] } = eventId
  ? await supabase.from("tickets").select("status").eq("event_id", eventId)
  : { data: [] as { status: string }[] };

const { data: sellers = [] } = await supabase
  .from("sellers")
  .select("id, name, type")
  .eq("active", true)
  .order("name", { ascending: true });

const { data: batches = [] } = await supabase
  .from("ticket_batches")
  .select("id, name, start_code, end_code, location, created_at")
  .order("created_at", { ascending: false });

const stats = {
  available: countTicketsByStatus(tickets, "available"),
  assigned: countTicketsByStatus(tickets, "assigned"),
  reserved: countTicketsByStatus(tickets, "reserved"),
  sold: countTicketsSold(tickets),
  validated: countTicketsByStatus(tickets, "validated"),
  cancelled: countTicketsByStatus(tickets, "cancelled"),
  total: tickets.length,
};

const rangeStart = formatTicketCode(1);
const rangeEnd = formatTicketCode(event.total_tickets);
---

<AdminLayout title="Lotes de Boletos | FARECOH" description="Administración de lotes físicos" active="batches">
  <AdminPageHeader
    client:load
    title="Lotes de boletos"
    section="Inventario"
    description="Asigne rangos de códigos a vendedores y puntos de venta."
    currentDate={currentDate}
    staffProfile={staffProfile}
    authConfigured={authConfigured}
  />

  <AdminPage>
    <BatchesAdminPanel
      client:load
      lotLabel="LOTE GENERAL 001"
      rangeStart={rangeStart}
      rangeEnd={rangeEnd}
      sellers={sellers}
      batches={batches}
      stats={stats}
      formMessage={formMessage}
      formError={formError}
    />
  </AdminPage>
</AdminLayout>
