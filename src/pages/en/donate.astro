---
import Layout from "@/layouts/Layout.astro";
import DonatePage from "@/components/DonatePage.astro";
import { getDictionary } from "@/i18n";

const lang = "en";
const t = getDictionary(lang);
---

<Layout title={t.meta.donateTitle} description={t.meta.donateDescription} lang={lang} active="donate">
  <DonatePage lang={lang} />
</Layout>
