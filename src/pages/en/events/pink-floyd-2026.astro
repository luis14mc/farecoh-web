---
import Layout from "@/layouts/Layout.astro";
import PinkFloydPage from "@/components/PinkFloydPage.astro";
import { getDictionary } from "@/i18n";

const lang = "en";
const t = getDictionary(lang);
---

<Layout title={t.meta.eventTitle} description={t.meta.eventDescription} lang={lang} active="pinkFloyd" variant="event">
  <PinkFloydPage lang={lang} />
</Layout>
